{# templates/_boilerplate/layouts/layout-base.twig #}
<!DOCTYPE html>
<html lang="en-US">
<head>

    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

    {# 1. CSS & Fonts #}
    <link rel="stylesheet" href="https://use.typekit.net/hty7zmt.css">
    {# 1. Fetch the Global Set by its handle #}
    {% set settings = craft.app.globals.getSetByHandle('siteSettings') %}

    {# 2. Check if the global set exists before using it #}
    {% if settings %}
        {% set siteFavicon = settings.faviconField.one() %}
        {% set siteWebclip = settings.webclipField.one() %}

        {# Favicon Implementation #}
        {% if siteFavicon %}
            <link rel="icon" type="{{ siteFavicon.mimeType }}" href="{{ siteFavicon.url }}">
            <link rel="shortcut icon" href="{{ siteFavicon.url }}">
        {% else %}
            {# Fallback to manual path if field is empty #}
            <link rel="icon" type="image/svg+xml" href="/images/favicon_32x32.svg">
        {% endif %}

        {# Webclip Implementation #}
        {% if siteWebclip %}
            <link rel="apple-touch-icon" href="{{ siteWebclip.url }}">
        {% else %}
            {# Fallback to manual path for 256x256 #}
            <link rel="apple-touch-icon" href="/images/webclip_256x256.svg">
        {% endif %}

    {% else %}
        {# 3. Total Fallback if the 'siteSettings' handle itself is wrong #}
        <link rel="icon" type="image/svg+xml" href="/images/favicon_32x32.svg">
        <link rel="apple-touch-icon" href="/images/webclip_256x256.svg">
    {% endif %}
    <script src="https://cdn.tailwindcss.com"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'foxplan-yellow': 'var(--foxplan-yellow)',
                        'foxplan-charcoal-brown': 'var(--foxplan-charcoal-brown)',
                        'foxplan-neutral-beige': 'var(--foxplan-neutral-beige)',
                        'foxplan-white': 'var(--foxplan-white)',
                        'foxplan-tint-line': 'var(--foxplan-tint-line)',
                    },
                    fontFamily: {
                        'serif': ['"Season Serif"', 'serif'],
                        'sans-aktiv': ['"aktiv-grotesk"', 'sans-serif'],
                    },
                    screens: {
                        'sm': '640px',
                        'md': '768px',
                        'lg': '1280px',
                    },
                }
            }
        }
    </script>

    <style>

        :root {
            --foxplan-yellow: #FBC938;
            --foxplan-neutral-beige: #F9EFD8;
            --foxplan-white: #FEFCF7;
            --foxplan-charcoal-brown: #270E15;
            --foxplan-tint-line: #CECECE;
        }
        [x-cloak] {
            display: none !important;
        }

        /* Hide scrollbar for Chrome, Safari and Opera */
        html::-webkit-scrollbar {
            display: none;
        }

        /* Hide scrollbar for IE, Edge and Firefox */
        html {
            -ms-overflow-style: none;
            scrollbar-width: none;
            overscroll-behavior-y: none;
            background-color: var(--foxplan-neutral-beige);
        }

        html, body {
            margin: 0 !important;
            padding: 0 !important;
            width: 100%;
            overflow-x: hidden;
        }


        .font-serif {
            font-family: 'Season Serif', serif;
        }

        .font-aktiv {
            font-family: 'aktiv-grotesk', sans-serif;
        }


    </style>

    {# 2. Animation Libraries #}
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>

    {# 3. Alpine.js #}
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
</head>

<body class="antialiased font-aktiv text-foxplan-charcoal-brown bg-foxplan-neutral-beige">

{{ include("_components/nav/nav.twig", { navigationTheme: navigationTheme ?? null }, withContext = true) }}

<main class="w-full">
    {% block blockAppBody %}{% endblock %}
</main>

<script>
    // used for not showing empty space
    gsap.registerPlugin(ScrollTrigger);
</script>
</body>
</html>