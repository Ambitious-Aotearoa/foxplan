{# templates/_boilerplate/layouts/layout-base.twig #}
<!DOCTYPE html>
<html lang="en-US">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>


    {# CSS & Fonts #}
    <link rel="stylesheet" href="https://use.typekit.net/hty7zmt.css">
    {# @font-face is now declared in main.css and compiled into the Vite bundle #}

    {# Vite-managed CSS + JS (compiled from src/js/app.js → web/dist/assets/) #}
    {# In dev: connects to the Vite dev server. In prod: reads the manifest. #}
    {{ craft.vite.script('src/js/app.js') }}

    {# Favicon and Webclip #}
    {% set siteFavicon = siteSettings.faviconField.one() %}
    {% set siteWebclip = siteSettings.webclipField.one() %}

    {% if siteFavicon %}
        <link rel="icon" type="{{ siteFavicon.mimeType }}" href="{{ siteFavicon.url }}">
    {% endif %}

    {% if siteWebclip %}
        <link rel="apple-touch-icon" sizes="256x256" href="{{ siteWebclip.url }}">
    {% endif %}

    {# Tailwind, Alpine, and GSAP are all bundled via Vite — no CDN scripts needed #}
</head>

<body class="antialiased font-aktiv text-foxplan-charcoal-brown bg-foxplan-neutral-beige" style="opacity: 0;">

{# Wrap the nav in a block called 'navigation' #}
{% block navigation %}
    {{ include("_components/nav/nav.twig", { navigationTheme: navigationTheme ?? null }, withContext = true) }}
{% endblock %}

<main class="w-full">
    {% block blockAppBody %}{% endblock %}
</main>

<script>
    // Reveal page once styles AND fonts are loaded — prevents FOUC
    (function() {
        function reveal() {
            document.body.style.transition = 'opacity 0.2s ease-in';
            document.body.style.opacity = '1';
        }
        // Wait for fonts to finish loading, then reveal
        if (document.fonts && document.fonts.ready) {
            document.fonts.ready.then(reveal);
        } else {
            // Fallback for older browsers
            window.addEventListener('load', reveal);
        }
        // Safety net — always reveal after 1.5s no matter what
        setTimeout(reveal, 1500);
    })();
</script>
</body>
</html>