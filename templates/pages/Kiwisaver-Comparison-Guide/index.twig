{% extends "_boilerplate/_layouts/layout-base.twig" %}

{# 1. Check for the "thanks" parameter in the URL #}
{% set isThankYou = craft.app.request.getParam('thanks') == '1' %}

{# 2. Navigation Logic #}
{% block navigation %}
    {% if isThankYou %}
        {{ include("_components/nav/nav.twig", {
            isThankYou: true,
            theme: {
                backgroundColor: 'bg-foxplan-yellow',
                textColor: 'text-foxplan-charcoal-brown',
                logoColor: 'text-foxplan-charcoal-brown',
                navLinkColor: 'text-foxplan-charcoal-brown'
            }
        }) }}
    {% else %}
        {{ include("_components/nav/nav-landing-page.twig", {
            theme: {
                backgroundColor: 'bg-foxplan-yellow'
            }
        }) }}
    {% endif %}
{% endblock %}

{% block blockAppBody %}

    {% if isThankYou %}
        {# --- THANK YOU STATE --- #}
        <section class="bg-foxplan-charcoal-brown w-full min-h-screen overflow-hidden relative">
            <div class="hidden md:block absolute left-0 top-0 bottom-0 h-full z-30 pointer-events-none"
                 style="background-color: #FBC938; width: clamp(0.5rem, 1vw, 1rem);"></div>

            <div class="pt-16 pb-20 px-4 md:pl-12 lg:pl-16 md:pr-6 lg:pr-12 max-w-[1920px] mx-auto">
                <div class="w-full mt-16 mb-12 lg:mb-20">
                    <h1 class="font-serif tracking-tight text-foxplan-yellow"
                        style="font-size: clamp(3.5rem, 9vw, 8.5rem); line-height: 0.95; word-break: keep-all;">
                        {{ entry.mainHeadline ?? entry.title | nl2br }}
                    </h1>
                </div>

                <div class="flex flex-col lg:flex-row w-full items-start gap-12 lg:gap-24">
                    <div class="w-full lg:w-[50%] flex flex-col">
                        <div class="max-w-2xl">
                            <div class="font-aktiv leading-[1.3] text-foxplan-yellow mb-10"
                                 style="font-size: clamp(1.1rem, 1.4vw, 1.5rem); font-weight: 300;">
                                {{ entry.largeParagraph2 | raw }}
                            </div>
                            <div class="font-aktiv leading-snug text-foxplan-yellow opacity-85"
                                 style="font-size: 1rem; font-weight: 300; max-width: 500px;">
                                {{ entry.bodyText5 | raw }}
                            </div>
                        </div>
                    </div>

                    <div class="w-full lg:w-[50%] flex justify-start lg:justify-end">
                        <div class="w-full overflow-hidden" style="min-height: 700px;">
                            <div class="calendly-inline-widget"
                                 data-url="https://calendly.com/foxplansales/discovery-phone-call-clone?hide_event_type_details=1&background_color=f4f1ea&text_color=2d2926&primary_color=e9bc44"
                                 style="min-width:320px;height:700px;">
                            </div>
                            <script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>
                        </div>
                    </div>
                </div>
            </div>
        </section>

    {% else %}
        {# --- NORMAL LANDING PAGE STATE --- #}
        <div class="pt-20">
            {# 1. Hero Section #}
            {{ include('_sections/hero-sections/hero-kiwisaver-comparison.twig', {
                props: {
                    backgroundColor: 'bg-foxplan-yellow',
                    buttonText: 'Download the guide',
                    buttonUrl: '#Form'
                }
            }) }}

            {# 2. KiwiSaver Strategies Section #}
            {{ include('_sections/content-sections/kiwisaver-fund-types.twig', {
                props: {
                    block: entry,
                    mainTitle: entry.mainTitle ?? 'How we work with you',
                    paragraphHeading: entry.paragraphHeading ?? '',
                    backgroundColor: 'bg-foxplan-charcoal-brown',
                    textColor: 'text-foxplan-yellow'
                }
            }) }}

            {# 3. Image with text #}
            {% include '_sections/content-sections/kiwisaver-image-text.twig' with {
                entry: entry,
                props: {
                    textColor: "text-foxplan-charcoal-brown",
                    panelBgColor: "#84B8D8"
                }
            } %}

            {# 4. Get the Guide #}
            {% include '_sections/content-sections/get-the-guide.twig' with {
                entry: entry,
                props: {
                    backgroundColor: "bg-foxplan-yellow",
                    textColor: "text-foxplan-charcoal-brown"
                }
            } %}
        </div>
    {% endif %}

    {# 5. Footer #}
    {{ include('_components/footer/footer-High-fidelity.twig', {
        props: {
            backgroundColor: 'bg-foxplan-neutral-beige',
            textColor: 'text-foxplan-charcoal-brown',
            logoColor: 'text-foxplan-charcoal-brown',
            buttonColor: isThankYou ? 'bg-foxplan-charcoal-brown' : 'bg-foxplan-charcoal-beige',
            buttonTextColor: 'text-foxplan-neutral-beige',
            foxplanText: 'foxplan'
        }
    }) }}

{% endblock %}