{% extends "_boilerplate/_layouts/layout-base.twig" %}

{% set navigationTheme = {
    backgroundColor: 'bg-foxplan-neutral-beige',
    textColor: 'text-foxplan-charcoal-brown',
    actionBgColor: 'bg-foxplan-charcoal-brown'
} %}

{% block blockAppBody %}

    {# 1. Hero Section #}
    <section class="bg-foxplan-neutral-beige w-full pt-24 pb-12 border-b border-black/5">
        <div class="w-full px-[20px]">
            <h1 class="font-serif tracking-tight text-foxplan-charcoal-brown break-normal mb-8"
                style="font-size: clamp(2.5rem, 5vw + 1rem, 5.5rem); line-height: 0.85; word-break: keep-all;">
                KiwiSaver Calculator
            </h1>
            <p class="max-w-2xl opacity-70 font-medium leading-snug"
               style="font-size: clamp(1.125rem, 1vw + 0.5rem, 1.5rem);">
                Whether you're investing for retirement or a first home deposit, use our KiwiSaver investment calculator to find out how regular contributions and the right fund choice can get you closer to your goal.
            </p>
        </div>
    </section>

    {#
        SINGLE ALPINE SCOPE — all state lives here so the calculator
        include and the projections graph below share the same reactive data.
    #}
    <div x-data="{

        {# --- Inputs --- #}
        localAge: 40,
        localEmployment: 'employed',
        localSalary: 45000,
        localBalance: 10000,
        localVoluntary: 0,
        localSchemeIdx: 3,
        localContribution: 3,
        localEmployerContribution: 3,
        useLifeCycle: false,
        openDropdown: null,

        schemes: [
            { name: 'Defensive',    rate: 0.025, fee: 0.0050 },
            { name: 'Conservative', rate: 0.035, fee: 0.0065 },
            { name: 'Balanced',     rate: 0.045, fee: 0.0085 },
            { name: 'Growth',       rate: 0.055, fee: 0.0100 },
            { name: 'Aggressive',   rate: 0.065, fee: 0.0120 }
        ],

        {# --- Derived helpers --- #}

        {# Net annual return after fees #}
        get netAnnualRate() {
            if (this.useLifeCycle) {
                {# Life cycle: blended 4.5% gross, ~0.85% fee #}
                return 0.045 - 0.0085;
            }
            const s = this.schemes[this.localSchemeIdx];
            return s.rate - s.fee;
        },

        {# Does this person get an employer contribution? #}
        get hasEmployer() {
            return this.localEmployment === 'employed';
        },

        {#
            Government Member Tax Credit (MTC):
            - Employed/self-employed: IRD matches 50c per $1 contributed, capped at $521.43/yr
            - Not working: no MTC
            - Requires min $1,042.86 member contribution to get full credit
        #}
        get govContribAnnual() {
            if (this.localEmployment === 'not working') return 0;
            const annualMemberContrib = this.localEmployment === 'self-employed'
                ? parseFloat(this.localVoluntary) * 12
                : (this.localSalary * (this.localContribution / 100)) + (parseFloat(this.localVoluntary) * 12);
            return Math.min(521.43, annualMemberContrib * 0.5);
        },

        {# Monthly total going into the fund #}
        get monthlyContribution() {
            const salaryCombined = this.hasEmployer
                ? this.localSalary * ((this.localContribution + this.localEmployerContribution) / 100) / 12
                : (this.localEmployment === 'self-employed'
                    ? this.localSalary * (this.localContribution / 100) / 12
                    : 0);
            const voluntary = parseFloat(this.localVoluntary);
            const gov = this.govContribAnnual / 12;
            return salaryCombined + voluntary + gov;
        },

        {# --- Main projection calculation --- #}
        get totalSavings() {
            const yearsToRetire = 65 - this.localAge;
            if (yearsToRetire <= 0) return this.localBalance;

            const monthlyRate = this.netAnnualRate / 12;
            const months = yearsToRetire * 12;
            const mc = this.monthlyContribution;

            const fvBalance = this.localBalance * Math.pow(1 + monthlyRate, months);
            const fvContributions = monthlyRate > 0
                ? mc * ((Math.pow(1 + monthlyRate, months) - 1) / monthlyRate)
                : mc * months;

            return Math.round(fvBalance + fvContributions);
        },

        {#
            Year-by-year balances from current age to 90
            Used to draw the SVG chart curve
        #}
        get projectionPoints() {
            const points = [];
            const monthlyRate = this.netAnnualRate / 12;
            const mc = this.monthlyContribution;
            let balance = this.localBalance;
            const startAge = this.localAge;
            const retirementAge = 65;
            const endAge = 90;

            for (let age = startAge; age <= endAge; age++) {
                points.push({ age, balance: Math.round(balance) });

                if (age < endAge) {
                    if (age < retirementAge) {
                        {# Accumulation phase — contributions + growth #}
                        for (let m = 0; m < 12; m++) {
                            balance = (balance + mc) * (1 + monthlyRate);
                        }
                    } else {
                        {# Drawdown phase — withdraw weeklyAmount * 52 per year #}
                        const annualDrawdown = this.weeklyAmount * 52;
                        const monthlyDrawdown = annualDrawdown / 12;
                        for (let m = 0; m < 12; m++) {
                            balance = Math.max(0, (balance - monthlyDrawdown) * (1 + monthlyRate));
                        }
                    }
                }
            }
            return points;
        },

        {# Weekly drawdown over 25 years post-retirement at 3% #}
        get weeklyAmount() {
            const weeks = 25 * 52;
            const weeklyRate = 0.03 / 52;
            if (this.totalSavings <= 0) return 0;
            return Math.round(
                this.totalSavings * (weeklyRate / (1 - Math.pow(1 + weeklyRate, -weeks)))
            );
        },

        {# SVG polyline points string from projectionPoints #}
        get svgPoints() {
            const pts = this.projectionPoints;
            if (!pts.length) return '';
            const maxVal = Math.max(...pts.map(p => p.balance)) * 1.1;
            const minAge = pts[0].age;
            const maxAge = pts[pts.length - 1].age;
            const ageRange = maxAge - minAge;
            return pts.map(p => {
                const x = ageRange > 0 ? ((p.age - minAge) / ageRange) * 100 : 0;
                const y = maxVal > 0 ? (1 - p.balance / maxVal) * 100 : 100;
                return x.toFixed(2) + ',' + y.toFixed(2);
            }).join(' ');
        },

        get svgMaxVal() {
            const pts = this.projectionPoints;
            if (!pts.length) return 100000;
            return Math.max(...pts.map(p => p.balance)) * 1.1;
        },

        {# Retirement point as SVG x% for the vertical marker #}
        get retirementX() {
            const minAge = this.localAge;
            const maxAge = 90;
            const range = maxAge - minAge;
            if (range <= 0) return 100;
            return (((65 - minAge) / range) * 100).toFixed(2);
        },

        updateProjections() {
            document.getElementById('projections-section')?.scrollIntoView({ behavior: 'smooth' });
        }

    }" @click.away="openDropdown = null">

        {# 2. Calculator Section #}
        <section class="bg-foxplan-neutral-beige w-full">
            {% include '_sections/calculator/kiwisaver-calculator.twig' %}
        </section>

        {# 3. Projections Section #}
        <section id="projections-section" class="bg-foxplan-neutral-beige w-full py-24 border-t border-black/5 overflow-hidden">
            <div class="w-full px-[20px] md:px-[40px] lg:px-[80px]">

                {# Header #}
                <div class="flex flex-col md:flex-row justify-between items-baseline mb-16 border-b border-black/5 pb-8">
                    <h2 class="font-serif tracking-tight text-foxplan-charcoal-brown break-normal"
                        style="font-size: clamp(2.25rem, 4vw + 1rem, 4.5rem); line-height: 0.85; word-break: keep-all;">
                        Projections
                    </h2>
                    <div class="flex items-center gap-6 mt-6 md:mt-0">
                        <div class="flex items-center gap-2">
                            <div class="w-3 h-3 rounded-full bg-foxplan-yellow"></div>
                            <span class="text-[10px] font-bold uppercase tracking-[0.2em] opacity-60">Balance</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <div class="w-px h-4 border-l-2 border-dashed border-foxplan-charcoal-brown opacity-30"></div>
                            <span class="text-[10px] font-bold uppercase tracking-[0.2em] opacity-60">Retirement at 65</span>
                        </div>
                    </div>
                </div>

                {# Summary stats above chart #}
                <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-12">
                    <div>
                        <div class="text-[10px] font-bold uppercase tracking-[0.2em] opacity-40 mb-1">Balance at 65</div>
                        <div class="font-serif text-foxplan-charcoal-brown" style="font-size: clamp(1.25rem, 2vw, 1.75rem);"
                             x-text="'$' + totalSavings.toLocaleString()"></div>
                    </div>
                    <div>
                        <div class="text-[10px] font-bold uppercase tracking-[0.2em] opacity-40 mb-1">Weekly Drawdown</div>
                        <div class="font-serif text-foxplan-charcoal-brown" style="font-size: clamp(1.25rem, 2vw, 1.75rem);"
                             x-text="'$' + weeklyAmount.toLocaleString()"></div>
                    </div>
                    <div>
                        <div class="text-[10px] font-bold uppercase tracking-[0.2em] opacity-40 mb-1">Govt Contribution (yr)</div>
                        <div class="font-serif text-foxplan-charcoal-brown" style="font-size: clamp(1.25rem, 2vw, 1.75rem);"
                             x-text="'$' + govContribAnnual.toFixed(0)"></div>
                    </div>
                    <div>
                        <div class="text-[10px] font-bold uppercase tracking-[0.2em] opacity-40 mb-1">Monthly into Fund</div>
                        <div class="font-serif text-foxplan-charcoal-brown" style="font-size: clamp(1.25rem, 2vw, 1.75rem);"
                             x-text="'$' + Math.round(monthlyContribution).toLocaleString()"></div>
                    </div>
                </div>

                {# SVG Chart #}
                <div class="relative w-full flex">

                    {# Y-axis labels #}
                    <div class="flex flex-col justify-between text-[11px] font-bold opacity-30 pr-6 text-right w-24 shrink-0"
                         style="height: 400px;">
                        <span x-text="'$' + Math.round(svgMaxVal).toLocaleString()"></span>
                        <span x-text="'$' + Math.round(svgMaxVal * 0.75).toLocaleString()"></span>
                        <span x-text="'$' + Math.round(svgMaxVal * 0.5).toLocaleString()"></span>
                        <span x-text="'$' + Math.round(svgMaxVal * 0.25).toLocaleString()"></span>
                        <span>$0</span>
                    </div>

                    {# Chart area #}
                    <div class="flex-1 relative border-l border-b border-black/10" style="height: 400px;">
                        <svg class="w-full h-full overflow-visible" viewBox="0 0 100 100" preserveAspectRatio="none">

                            {# Horizontal grid lines #}
                            <line x1="0" y1="25" x2="100" y2="25" stroke="currentColor" stroke-width="0.3" stroke-dasharray="2,2" opacity="0.15"/>
                            <line x1="0" y1="50" x2="100" y2="50" stroke="currentColor" stroke-width="0.3" stroke-dasharray="2,2" opacity="0.15"/>
                            <line x1="0" y1="75" x2="100" y2="75" stroke="currentColor" stroke-width="0.3" stroke-dasharray="2,2" opacity="0.15"/>

                            {# Retirement age vertical marker #}
                            <line :x1="retirementX" y1="0" :x2="retirementX" y2="100"
                                  stroke="#270E15" stroke-width="0.5" stroke-dasharray="3,2" opacity="0.3"/>

                            {# Area fill under curve #}
                            <polyline
                                :points="'0,100 ' + svgPoints + ' 100,100'"
                                fill="rgba(251, 201, 56, 0.2)"
                                stroke="none"
                            />

                            {# The curve itself #}
                            <polyline
                                :points="svgPoints"
                                fill="none"
                                stroke="#FBC938"
                                stroke-width="0.8"
                                stroke-linejoin="round"
                                stroke-linecap="round"
                            />

                        </svg>

                        {# X-axis age labels #}
                        <div class="absolute -bottom-8 w-full flex justify-between">
                            <span class="text-[11px] font-bold opacity-40" x-text="localAge"></span>
                            <span class="text-[11px] font-bold opacity-40"
                                  :style="'position: absolute; left: ' + retirementX + '%; transform: translateX(-50%);'">65</span>
                            <span class="text-[11px] font-bold opacity-40">90</span>
                        </div>
                        <div class="absolute -bottom-16 left-1/2 -translate-x-1/2 text-[10px] font-bold tracking-[0.4em] uppercase opacity-40">Age (Years)</div>
                    </div>
                </div>

                {# Assumptions footnote #}
                <div class="mt-24 text-[11px] opacity-40 leading-relaxed max-w-2xl">
                    <strong class="uppercase tracking-widest">Assumptions:</strong>
                    Projections are illustrative only. Returns are shown after fund fees (
                    <span x-text="useLifeCycle ? '0.85' : (schemes[localSchemeIdx].fee * 100).toFixed(2)"></span>% p.a.).
                    Government member tax credit applied where eligible (max $521.43/yr).
                    Drawdown phase assumes 3% p.a. return over 25 years (age 65–90).
                    Past performance is not a guarantee of future returns.
                </div>

            </div>
        </section>
    </div>

    {# 4. Footer #}
    {{ include('_components/footer/footer-High-fidelity.twig', {
        props: {
            backgroundColor: 'bg-foxplan-charcoal-brown',
            textColor: 'text-foxplan-yellow',
            logoColor: 'text-foxplan-yellow',
            buttonColor: 'bg-foxplan-yellow',
            buttonTextColor: 'text-foxplan-charcoal-brown'
        }
    }) }}

{% endblock %}
