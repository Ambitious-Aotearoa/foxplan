{% extends "_boilerplate/_layouts/layout-base.twig" %}

{% set navigationTheme = {
    backgroundColor: 'bg-foxplan-charcoal-brown',
    textColor: 'text-foxplan-yellow',
    actionBgColor: 'bg-foxplan-charcoal-brown',
    searchBgColor: 'lg:bg-foxplan-yellow',
    ctaBgColor: 'bg-foxplan-yellow',
    ctaTextColor: 'text-foxplan-charcoal-brown',
    searchColour: 'text-foxplan-yellow lg:text-foxplan-charcoal-brown'
} %}

{% block blockAppBody %}

    {# 1. Hero Section #}
    {{ include('_sections/hero-sections/hero-arrow.twig', {
        props: {
            backgroundColor: 'bg-foxplan-charcoal-brown',
            textColor: 'text-foxplan-yellow',
            arrowColor: 'text-foxplan-yellow',
            buttonText: '',
        }
    }) }}

{#    {2. about-the-pod }#}
    {{ include('_sections/content-sections/about-podcast.twig', {
        data: {
            backgroundColor: 'bg-foxplan-yellow',
            borderColor: 'border-foxplan-charcoal-brown',
            textColor: 'text-foxplan-charcoal-brown',
            topLabel: entry.mainTitle ?? 'ABOUT THE POD',
            bodyText: entry.largeParagraph ?? '',
            showLogo: true
        }
    }) }}

    {# 3. All Episodes List #}
    {{ include('_sections/content-sections/episode-list.twig', {
        data: {
            sectionTitle: 'All episodes',
            backgroundColor: 'bg-foxplan-neutral-beige',
            textColor: 'text-foxplan-charcoal-brown',
            seeAllUrl: 'https://www.buzzsprout.com/2249822'
        }
    }) }}


    {# newsletter-dollar-and-sense #}
    {{ include('_sections/newsletter/newsletter-dollar-and-sense.twig', {
        data: {
            backgroundColor: 'bg-foxplan-neutral-beige',
            headingColor: 'text-foxplan-charcoal-brown',
            bodyColor: 'text-foxplan-charcoal-brown',
            borderColor: 'border-foxplan-charcoal-brown',
        }
    }) }}

    {# footer #}
    {{ include('_components/footer/footer-High-fidelity.twig', {
        props: {
            backgroundColor: 'bg-foxplan-charcoal-brown',
            textColor: 'text-foxplan-yellow',
            logoColor: 'text-foxplan-yellow',
            buttonColor: 'bg-foxplan-yellow',
            buttonTextColor: 'text-foxplan-charcoal-brown',
            separatorColor: 'text-foxplan-yellow'
        }
    }) }}

{% endblock %}