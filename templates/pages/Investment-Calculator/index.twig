{% extends "_boilerplate/_layouts/layout-base.twig" %}

{% set navigationTheme = {
    backgroundColor: 'bg-foxplan-neutral-beige',
    textColor: 'text-foxplan-charcoal-brown',
    actionBgColor: 'bg-foxplan-charcoal-brown'
} %}

{% block blockAppBody %}

    {# 1. Hero Section #}
    <section class="bg-foxplan-neutral-beige w-full pt-24 pb-12 border-b border-black/5">
        <div class="w-full px-[20px]">
            <h1 class="font-serif tracking-tight text-foxplan-charcoal-brown break-normal mb-8"
                style="font-size: clamp(2.5rem, 5vw + 1rem, 5.5rem); line-height: 0.85; word-break: keep-all;">
                Savings Calculator
            </h1>
            <p class="max-w-2xl opacity-70 font-medium leading-snug"
               style="font-size: clamp(1.125rem, 1vw + 0.5rem, 1.5rem);">
                Whether you're saving for a house deposit, a big life goal or simply building a financial cushion, use our calculator to see how your regular contributions and interest rate can compound over time.
            </p>
        </div>
    </section>

    {#
        SINGLE ALPINE SCOPE — all state lives here so the calculator
        include and the projections chart share the same reactive data.
    #}
    <div x-data="{

        localAge: 30,
        localGoalAge: 65,
        localFreq: 'Monthly',
        localContribution: 500,
        localBalance: 10000,
        localRateIdx: 2,
        localCompound: 'Monthly',
        openDropdown: null,

        ratePresets: [
            { label: '2% — Term Deposit (Low)',   rate: 0.02 },
            { label: '3% — Conservative',          rate: 0.03 },
            { label: '4.5% — Balanced',            rate: 0.045 },
            { label: '6% — Growth',                rate: 0.06 },
            { label: '7.5% — Aggressive',          rate: 0.075 }
        ],

        get periodsPerYear() {
            return this.localFreq === 'Weekly' ? 52 : (this.localFreq === 'Fortnightly' ? 26 : 12);
        },

        get compoundPerYear() {
            return this.localCompound === 'Monthly' ? 12 : (this.localCompound === 'Quarterly' ? 4 : 1);
        },

        get annualRate() {
            return this.ratePresets[this.localRateIdx].rate;
        },

        get yearsToGoal() {
            return Math.max(0, this.localGoalAge - this.localAge);
        },

        get finalBalance() {
            const n = this.yearsToGoal;
            if (n <= 0) return Math.round(this.localBalance);
            const r = this.annualRate;
            const c = this.compoundPerYear;
            const pmt = this.localContribution;
            const p = this.periodsPerYear;

            // Compound interest on starting balance
            const fvBalance = this.localBalance * Math.pow(1 + r / c, c * n);

            // Future value of regular contributions
            // Convert contribution to annual then calculate FV of annuity
            const annualContrib = pmt * p;
            const fvContrib = r > 0
                ? annualContrib * ((Math.pow(1 + r, n) - 1) / r)
                : annualContrib * n;

            return Math.round(fvBalance + fvContrib);
        },

        get totalContributions() {
            return Math.round(this.localContribution * this.periodsPerYear * this.yearsToGoal);
        },

        get interestEarned() {
            return Math.max(0, this.finalBalance - this.localBalance - this.totalContributions);
        },

        get projectionPoints() {
            const points = [];
            const r = this.annualRate;
            const c = this.compoundPerYear;
            const pmt = this.localContribution;
            const p = this.periodsPerYear;
            const annualContrib = pmt * p;
            const startAge = this.localAge;
            const endAge = Math.max(this.localGoalAge, startAge + 1);

            for (let age = startAge; age <= endAge; age++) {
                const n = age - startAge;
                const fvBalance = this.localBalance * Math.pow(1 + r / c, c * n);
                const fvContrib = r > 0
                    ? annualContrib * ((Math.pow(1 + r, n) - 1) / r)
                    : annualContrib * n;
                points.push({ age, balance: Math.round(fvBalance + fvContrib) });
            }
            return points;
        },

        get svgMaxVal() {
            const pts = this.projectionPoints;
            if (!pts.length) return 100000;
            return Math.max(...pts.map(p => p.balance)) * 1.1;
        },

        get svgPoints() {
            const pts = this.projectionPoints;
            if (!pts.length) return '';
            const maxVal = this.svgMaxVal;
            const minAge = pts[0].age;
            const maxAge = pts[pts.length - 1].age;
            const ageRange = maxAge - minAge || 1;
            return pts.map(p => {
                const x = ((p.age - minAge) / ageRange) * 100;
                const y = maxVal > 0 ? (1 - p.balance / maxVal) * 100 : 100;
                return x.toFixed(2) + ',' + y.toFixed(2);
            }).join(' ');
        },

        updateProjections() {
            document.getElementById('projections-section')?.scrollIntoView({ behavior: 'smooth' });
        }

    }" @click.away="openDropdown = null">

        {# 2. Calculator Section #}
        <section class="bg-foxplan-neutral-beige w-full">
            {% include '_sections/calculator/saving-calculator.twig' %}
        </section>

        {# 3. Projections Section #}
        <section id="projections-section" class="bg-foxplan-neutral-beige w-full py-24 border-t border-black/5 overflow-hidden">
            <div class="w-full px-[20px] md:px-[40px] lg:px-[80px]">

                {# Header #}
                <div class="flex flex-col md:flex-row justify-between items-baseline mb-16 border-b border-black/5 pb-8">
                    <h2 class="font-serif tracking-tight text-foxplan-charcoal-brown break-normal"
                        style="font-size: clamp(2.25rem, 4vw + 1rem, 4.5rem); line-height: 0.85; word-break: keep-all;">
                        Projections
                    </h2>
                    <div class="flex items-center gap-6 mt-6 md:mt-0">
                        <div class="flex items-center gap-2">
                            <div class="w-3 h-3 rounded-full bg-foxplan-yellow"></div>
                            <span class="text-[10px] font-bold uppercase tracking-[0.2em] opacity-60">Balance</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <div class="w-3 h-3 bg-foxplan-charcoal-brown opacity-30"></div>
                            <span class="text-[10px] font-bold uppercase tracking-[0.2em] opacity-60">Contributions</span>
                        </div>
                    </div>
                </div>

                {# Summary stats #}
                <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-12">
                    <div>
                        <div class="text-[10px] font-bold uppercase tracking-[0.2em] opacity-40 mb-1">Final Balance</div>
                        <div class="font-serif text-foxplan-charcoal-brown" style="font-size: clamp(1.25rem, 2vw, 1.75rem);"
                             x-text="'$' + finalBalance.toLocaleString()"></div>
                    </div>
                    <div>
                        <div class="text-[10px] font-bold uppercase tracking-[0.2em] opacity-40 mb-1">Total Contributions</div>
                        <div class="font-serif text-foxplan-charcoal-brown" style="font-size: clamp(1.25rem, 2vw, 1.75rem);"
                             x-text="'$' + totalContributions.toLocaleString()"></div>
                    </div>
                    <div>
                        <div class="text-[10px] font-bold uppercase tracking-[0.2em] opacity-40 mb-1">Interest Earned</div>
                        <div class="font-serif text-foxplan-charcoal-brown" style="font-size: clamp(1.25rem, 2vw, 1.75rem);"
                             x-text="'$' + interestEarned.toLocaleString()"></div>
                    </div>
                    <div>
                        <div class="text-[10px] font-bold uppercase tracking-[0.2em] opacity-40 mb-1">Duration</div>
                        <div class="font-serif text-foxplan-charcoal-brown" style="font-size: clamp(1.25rem, 2vw, 1.75rem);"
                             x-text="yearsToGoal + ' years'"></div>
                    </div>
                </div>

                {# SVG Chart #}
                <div class="relative w-full flex">

                    {# Y-axis labels #}
                    <div class="flex flex-col justify-between text-[11px] font-bold opacity-30 pr-6 text-right w-24 shrink-0"
                         style="height: 400px;">
                        <span x-text="'$' + Math.round(svgMaxVal).toLocaleString()"></span>
                        <span x-text="'$' + Math.round(svgMaxVal * 0.75).toLocaleString()"></span>
                        <span x-text="'$' + Math.round(svgMaxVal * 0.5).toLocaleString()"></span>
                        <span x-text="'$' + Math.round(svgMaxVal * 0.25).toLocaleString()"></span>
                        <span>$0</span>
                    </div>

                    {# Chart area #}
                    <div class="flex-1 relative border-l border-b border-black/10" style="height: 400px;">
                        <svg class="w-full h-full overflow-visible" viewBox="0 0 100 100" preserveAspectRatio="none">

                            {# Grid lines #}
                            <line x1="0" y1="25" x2="100" y2="25" stroke="currentColor" stroke-width="0.3" stroke-dasharray="2,2" opacity="0.15"/>
                            <line x1="0" y1="50" x2="100" y2="50" stroke="currentColor" stroke-width="0.3" stroke-dasharray="2,2" opacity="0.15"/>
                            <line x1="0" y1="75" x2="100" y2="75" stroke="currentColor" stroke-width="0.3" stroke-dasharray="2,2" opacity="0.15"/>

                            {# Contributions area (charcoal, below the curve) #}
                            <polyline
                                :points="'0,100 ' + projectionPoints.map((p, i) => {
                                    const maxAge = projectionPoints[projectionPoints.length-1].age;
                                    const minAge = projectionPoints[0].age;
                                    const ageRange = maxAge - minAge || 1;
                                    const x = ((p.age - minAge) / ageRange) * 100;
                                    const contribVal = localBalance + (localContribution * periodsPerYear * (p.age - localAge));
                                    const y = svgMaxVal > 0 ? (1 - Math.min(contribVal, p.balance) / svgMaxVal) * 100 : 100;
                                    return x.toFixed(2) + ',' + y.toFixed(2);
                                }).join(' ') + ' 100,100'"
                                fill="rgba(39, 14, 21, 0.12)"
                                stroke="none"
                            />

                            {# Total balance area fill #}
                            <polyline
                                :points="'0,100 ' + svgPoints + ' 100,100'"
                                fill="rgba(251, 201, 56, 0.2)"
                                stroke="none"
                            />

                            {# The curve #}
                            <polyline
                                :points="svgPoints"
                                fill="none"
                                stroke="#FBC938"
                                stroke-width="0.8"
                                stroke-linejoin="round"
                                stroke-linecap="round"
                            />

                        </svg>

                        {# X-axis labels #}
                        <div class="absolute -bottom-8 w-full flex justify-between">
                            <span class="text-[11px] font-bold opacity-40" x-text="localAge"></span>
                            <span class="text-[11px] font-bold opacity-40" x-text="localGoalAge"></span>
                        </div>
                        <div class="absolute -bottom-16 left-1/2 -translate-x-1/2 text-[10px] font-bold tracking-[0.4em] uppercase opacity-40">Age (Years)</div>
                    </div>
                </div>

                {# Assumptions footnote #}
                <div class="mt-24 text-[11px] opacity-40 leading-relaxed max-w-2xl">
                    <strong class="uppercase tracking-widest">Assumptions:</strong>
                    Projections are illustrative only. Returns shown assume a fixed annual rate of
                    <span x-text="(annualRate * 100).toFixed(1)"></span>%,
                    compounded <span x-text="localCompound.toLowerCase()"></span>,
                    with <span x-text="localFreq.toLowerCase()"></span> contributions of
                    $<span x-text="localContribution.toLocaleString()"></span>.
                    Past performance is not a guarantee of future returns. This calculator does not account for tax, inflation, or fees.
                </div>

            </div>
        </section>
    </div>

    {# 4. Footer #}
    {{ include('_components/footer/footer-High-fidelity.twig', {
        props: {
            backgroundColor: 'bg-foxplan-charcoal-brown',
            textColor: 'text-foxplan-yellow',
            logoColor: 'text-foxplan-yellow',
            buttonColor: 'bg-foxplan-yellow',
            buttonTextColor: 'text-foxplan-charcoal-brown'
        }
    }) }}

{% endblock %}
