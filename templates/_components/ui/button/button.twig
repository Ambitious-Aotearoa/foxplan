{# _components/ui/button/button.twig #}

{% set defaults = {
    text: 'Learn More',
    style: 'primary',
    url: none,
    backgroundColor: null,
    textColor: null,
    classes: '',
    attributes: {}
} %}

{% set props = defaults | merge(props | default({})) %}

{# Dynamic Color Logic #}
{% set bgClass = props.backgroundColor ?: 'bg-foxplan-charcoal-brown' %}
{% set textClass = props.textColor ?: 'text-foxplan-neutral-beige' %}

{% set buttonClasses = [
    'group relative inline-flex items-center justify-center overflow-hidden',
    'font-aktiv cursor-pointer transition-all duration-300 uppercase tracking-widest font-bold',
    'appearance-none border-0 border-solid',
    'py-2 px-3 md:px-4 lg:px-8 whitespace-nowrap',
    bgClass,
    textClass,
    'hover:opacity-80 active:opacity-100',
    props.classes
] | filter | join(' ') %}

{# FIX: Fluid font size from 12px to 14px #}
{% set textScaleStyle = 'font-size: clamp(0.75rem, 0.9vw, 0.875rem);' %}
{% set tag = props.url ? 'a' : 'button' %}

<{{ tag }} class="{{ buttonClasses }}" style="{{ textScaleStyle }}" {% if props.url %}href="{{ props.url }}"{% endif %}{% for attrName, attrValue in props.attributes %} {{ attrName }}="{{ attrValue }}"{% endfor %}>

    <span class="btn__text flex items-center justify-center gap-1.5 md:gap-2 lg:gap-4">
        {{ props.text }}
        <svg class="transition-transform duration-300 shrink-0"
             style="width: clamp(0.9rem, 1.1vw, 1.3rem); height: clamp(0.9rem, 1.1vw, 1.3rem);"
             viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M13.5 4.5L17.5 8.5L13.5 12.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M2.5 15.5V11.5C2.5 9.84315 3.84315 8.5 5.5 8.5H17.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
    </span>
</{{ tag }}>