{# templates/_components/ui/card/card.twig #}
{% set defaults = {
    year: '1996',
    title: 'Title',
    text: 'Text...',
    textColor: 'text-foxplan-charcoal-brown',
    accentColor: 'text-foxplan-charcoal-brown',
    squareColor: 'bg-foxplan-charcoal-brown',
    titleColor: 'text-foxplan-charcoal-brown'
} %}
{% set data = defaults | merge(props | default({})) %}


<div class="w-full h-full {{ data.cardBg }} flex items-start lg:items-center shadow-lg rounded-sm overflow-hidden will-change-transform">

    {# Mobile padding reduced to 1.5rem to fit content on small screens #}
    <div class="flex flex-col lg:grid lg:grid-cols-[30%_70%] w-full items-start text-left px-6 md:px-20 lg:py-0"
         style="padding-top: 1.5rem; padding-bottom: 2rem;">

        {# --- YEAR & SQUARE SECTION --- #}
        <div class="flex items-center gap-3 whitespace-nowrap mb-4 lg:mb-0">
            <div class="w-3 h-3 {{ data.squareColor }}"></div>
            <span class="font-aktiv text-sm font-bold tracking-[0.2em] uppercase {{ data.accentColor }}">
                {{ data.year }}
            </span>
        </div>

        {# --- TITLE AND TEXT SECTION --- #}
        <div class="w-full">
            <h3 class="font-serif leading-[1.0] lg:leading-[0.9] tracking-tight {{ data.titleColor }} mb-2 lg:mb-10"
                style="font-size: clamp(2.5rem, 6vw, 5.5rem);">
                {{ data.title }}
            </h3>
            <p class="font-aktiv font-light leading-relaxed {{ data.textColor }} opacity-90"
               style="font-size: 1.125rem;">
                {{ data.text }}
            </p>
        </div>
    </div>
</div>