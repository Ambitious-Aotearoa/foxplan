{# templates/_components/ui/accordion/accordion.twig #}

{% set defaults = {
    items: [],
    defaultOpen: -1,
    backgroundColor: 'bg-foxplan-white',
    textColor: 'text-foxplan-charcoal-brown',
    iconBgColor: 'bg-[#E5E5E5]',
    iconTextColor: 'text-white',
    titleFont: 'font-serif',
    titleCase: 'normal',
    titleWeight: 'font-normal',
    contentFont: 'font-aktiv',
    contentWeight: 'font-light',
    contentOpacity: 'opacity-100',
    contentLeading: 'leading-relaxed',
    classes: ''
} %}

{% set props = defaults | merge(props | default({})) %}

<div class="space-y-1 md:space-y-2 {{ props.classes }}" x-data="{ openItem: {{ props.defaultOpen }} }">
    {% if props.items and props.items|length > 0 %}
        {% for item in props.items %}
            {% set hasContent = item.ExpandableBodyText is not empty %}

            <div class="{{ props.backgroundColor }} overflow-hidden lg:mr-[20px] max-w-5xl transition-all duration-300 ease-out transform hover:scale-[1.01] hover:z-20 relative shadow-sm flex flex-col"
                 :class="openItem === {{ loop.index0 }} ? 'z-10 shadow-md' : 'z-0'">

                <button class="w-full flex-1 flex items-center justify-between text-left group transition-colors duration-200

               min-h-[4rem] md:min-h-[4.5rem] lg:min-h-[5rem]"
                        {% if hasContent %}
                    @click="openItem = openItem === {{ loop.index0 }} ? -1 : {{ loop.index0 }}"
                {% else %}
                    disabled
                        {% endif %}>

                    {# TITLE AREA #}
                    <div class="flex-1 px-6 md:px-10 py-2">
                        <h3 class="{{ props.titleFont }} {{ props.titleCase }} {{ props.titleWeight }} {{ props.textColor }} transition-transform duration-300 group-hover:translate-x-1"
                            style="font-size: clamp(1.2rem, 1.8vw, 1.75rem);
                   line-height: 1.15;
                   display: -webkit-box;
                   -webkit-line-clamp: 2;
                   -webkit-box-orient: vertical;
                   overflow: hidden;">
                            {{ item.expandableHeadingTitle|default('Item ' ~ loop.index) }}
                        </h3>
                    </div>

                    {# ICON AREA #}
                    {% if hasContent %}
                        <div class="flex-shrink-0 pr-6 md:pr-10">
                            <div class="w-8 h-8 md:w-9 md:h-9 {{ props.iconBgColor }} flex items-center justify-center transition-all duration-300 group-hover:bg-foxplan-charcoal-brown group-hover:text-white">
                <span class="{{ props.iconTextColor }} text-lg md:text-xl font-light leading-none"
                      x-text="openItem === {{ loop.index0 }} ? '−' : '+'">
                </span>
                            </div>
                        </div>
                    {% endif %}
                </button>

                {% if hasContent %}
                    <div x-show="openItem === {{ loop.index0 }}" x-collapse style="display: none;">
                        <div class="pb-8 px-6 md:px-10">

                            <div class="{{ props.contentFont }} {{ props.contentWeight }} {{ props.textColor }} {{ props.contentLeading }} {{ props.contentOpacity }}
                                        max-w-3xl
                                        [&_ul]:list-none [&_ul]:p-0 [&_ul]:m-0
                                        [&_li]:flex [&_li]:items-start [&_li]:gap-3 [&_li]:mb-2
                                        [&_li]:before:content-['•'] [&_li]:before:font-bold [&_li]:before:shrink-0"
                                 style="font-size: clamp(1.1rem, 1.3vw, 1.25rem);">
                                {{ item.ExpandableBodyText|raw }}
                            </div>
                        </div>
                    </div>
                {% endif %}
            </div>
        {% endfor %}
    {% endif %}
</div>