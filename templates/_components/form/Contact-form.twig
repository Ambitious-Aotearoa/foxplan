{# templates/_components/form/Contact-form.twig #}

{% set labelClasses = 'text-sm font-semibold uppercase tracking-wider mb-2 block text-foxplan-charcoal-brown font-aktiv' %}
{% set inputClasses = 'w-full py-2 border-b border-foxplan-charcoal-brown focus:outline-none bg-transparent placeholder-foxplan-charcoal-brown/60 font-aktiv transition-colors duration-200' %}

{% set insightTags = craft.tags.group('insights').all() %}
{% set serviceOptions = insightTags|map(t => t.title) %}

<form action="" method="post" accept-charset="UTF-8" class="contact-form" id="foxplan-js-form">
    {{ actionInput('contact-form/send') }}
    {{ csrfInput() }}
    {{ craft.contactFormExtensions.recaptcha | raw }}

    {# --- HYBRID TRIGGER --- #}
    <input type="hidden" name="message[formType]" value="contact">
    <input type="hidden" name="redirect" value="{{ 'pages/Thank-You'|hash }}">

    <div class="grid grid-cols-12 gap-x-8 gap-y-12 pb-12">

        {# First Name #}
        <div class="col-span-12 md:col-span-6">
            <label for="fromName" class="{{ labelClasses }}">First Name</label>
            <input type="text" id="fromName" name="fromName" placeholder="John"
                   class="{{ inputClasses }}" required>
        </div>

        {# Last Name #}
        <div class="col-span-12 md:col-span-6">
            <label for="last_name" class="{{ labelClasses }}">Last Name</label>
            <input type="text" id="last_name" name="fields[LastName]" placeholder="Doe"
                   class="{{ inputClasses }}" required
                   oninput="document.getElementById('msg-lastname').value = this.value">
            <input type="hidden" id="msg-lastname" name="message[LastName]">
        </div>

        {# Interest #}
        <div class="col-span-12 md:col-span-6">
            <label for="interest" class="{{ labelClasses }}">I am interested in</label>
            <select id="interest" name="fields[Interest]" class="{{ inputClasses }}" required
                    onchange="document.getElementById('msg-interest').value = this.value">
                <option value="" disabled selected>Select a service</option>
                {% for service in serviceOptions %}
                    <option value="{{ service }}">{{ service }}</option>
                {% endfor %}
            </select>
            <input type="hidden" id="msg-interest" name="message[Interest]">
        </div>

        {# Best Time to Call #}
        <div class="col-span-12 md:col-span-6">
            <label for="call_time" class="{{ labelClasses }}">Best time to call</label>
            <select id="call_time" name="fields[BestTimeToCall]" class="{{ inputClasses }}" required
                    onchange="document.getElementById('msg-calltime').value = this.value">
                <option value="" disabled selected>Select a time</option>
                <option value="Morning">Morning</option>
                <option value="Afternoon">Afternoon</option>
                <option value="Evening">Evening</option>
            </select>
            <input type="hidden" id="msg-calltime" name="message[BestTimeToCall]">
        </div>

        {# Phone #}
        <div class="col-span-12 md:col-span-6">
            <label for="phone" class="{{ labelClasses }}">Phone</label>
            <input type="tel" id="phone" name="fields[Phone]" placeholder="1234 567 890"
                   class="{{ inputClasses }}"
                   oninput="document.getElementById('msg-phone').value = this.value">
            <input type="hidden" id="msg-phone" name="message[Phone]">
        </div>

        {# Email #}
        <div class="col-span-12 md:col-span-6">
            <label for="fromEmail" class="{{ labelClasses }}">Email</label>
            <input type="email" id="fromEmail" name="fromEmail" placeholder="johndoe@email.com"
                   class="{{ inputClasses }}" required>
        </div>

        {# Message #}
        <div class="col-span-12">
            <label for="message_body" class="{{ labelClasses }}">Message</label>
            <textarea id="message_body" name="message[Body]" rows="4"
                      class="{{ inputClasses }} resize-none" required></textarea>
        </div>

        {# Submit Button #}
        <div class="col-span-12 mt-4">
            <button type="submit" id="form-submit-btn"
                    class="bg-foxplan-charcoal-brown text-foxplan-white py-4 px-12 uppercase tracking-widest text-xs font-bold transition-all cursor-default opacity-100">
                {{ props.submitText ?? 'Submit' }}
            </button>
        </div>
    </div>
</form>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const form = document.getElementById('foxplan-js-form');
        const btn = document.getElementById('form-submit-btn');

        form.reset();

        const updateCursor = () => {
            const isValid = form.checkValidity();
            if (isValid) {
                btn.classList.add('cursor-pointer');
                btn.classList.remove('cursor-default');
            } else {
                btn.classList.add('cursor-default');
                btn.classList.remove('cursor-pointer');
            }
        };

        form.addEventListener('input', updateCursor);
        form.addEventListener('change', updateCursor);

        form.addEventListener('submit', function() {
            setTimeout(() => {
                this.reset();
                updateCursor();
            }, 100);
        });

        updateCursor();
    });

    window.addEventListener('pageshow', function(event) {
        if (event.persisted || (window.performance && window.performance.navigation.type === 2)) {
            window.location.reload();
        }
    });
</script>