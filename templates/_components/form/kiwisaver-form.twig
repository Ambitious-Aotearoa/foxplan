{# templates/_components/forms/kiwisaver-form.twig #}

{% set colors = {
    text: 'text-foxplan-charcoal-brown',
    border: 'border-foxplan-charcoal-brown',
    buttonBg: 'bg-foxplan-charcoal-brown',
    buttonText: 'text-foxplan-white'
} %}

<div class="w-full max-w-4xl">

    {# Body Text #}
    <p class="font-aktiv {{ colors.text }} mb-12 font-light max-w-3xl"
       style="font-size: clamp(1.1rem, 1.5vw, 1.6rem); line-height: 1.15; letter-spacing: -0.01em; margin-top: 0;">
        Fill in your details to receive your free KiwiSaver Guide and learn how to maximise your investment as you navigate life's biggest milestones.
    </p>

    <form action="" method="post" class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-10">
        {{ csrfInput() }}
        {{ actionInput('contact-form/send') }}
        {{ redirectInput('/thank-you-landing') }}

        {# Hidden required fields for Contact Form plugin #}
        <input type="hidden" name="subject" value="KiwiSaver Guide Request">
        <input type="hidden" name="message[body]" value="New KiwiSaver guide request submission">

        {# Row 1: First name | Last name #}
        <div class="relative">
            <input type="text" name="fromName" id="firstName" placeholder="First name" required
                   class="w-full bg-transparent border-b {{ colors.border }} py-2 focus:outline-none placeholder:{{ colors.text }} font-aktiv text-lg">
        </div>

        <div class="relative">
            <input type="text" name="message[lastName]" id="lastName" placeholder="Last name" required
                   class="w-full bg-transparent border-b {{ colors.border }} py-2 focus:outline-none placeholder:{{ colors.text }} font-aktiv text-lg">
        </div>

        {# Row 2: Email address — full width #}
        <div class="relative col-span-full">
            <input type="email" name="fromEmail" id="email" placeholder="Email address" required
                   class="w-full bg-transparent border-b {{ colors.border }} py-2 focus:outline-none placeholder:{{ colors.text }} font-aktiv text-lg">
        </div>

        {# Row 3: Phone number | I prefer to be called #}
        <div class="relative">
            <input type="tel" name="message[phone]" id="phone" placeholder="Phone number" required
                   class="w-full bg-transparent border-b {{ colors.border }} py-2 focus:outline-none placeholder:{{ colors.text }} font-aktiv text-lg">
        </div>

        <div class="relative" x-data="{ open: false }">
            <select name="message[preference]"
                    @click="open = !open"
                    @blur="open = false"
                    class="w-full bg-transparent border-b {{ colors.border }} py-2 focus:outline-none appearance-none cursor-pointer font-aktiv text-lg {{ colors.text }}">
                <option value="" disabled selected>I prefer to be called</option>
                <option value="morning">In the morning</option>
                <option value="afternoon">In the afternoon</option>
                <option value="evening">In the evening</option>
            </select>
            <div class="absolute right-0 bottom-3 pointer-events-none transition-transform duration-300"
                 :class="open ? 'rotate-180' : ''">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"></path>
                </svg>
            </div>
        </div>

        {# Disclaimer #}
        <div class="col-span-full pt-2">
            <p class="text-sm leading-tight opacity-70 {{ colors.text }} font-aktiv max-w-xl">
                By downloading this guide, you consent to being contacted by a FoxPlan adviser for general followup purposes. You can opt out at any time. See our
                <a href="/privacy" class="underline underline-offset-2 hover:opacity-100">Privacy Policy</a> at foxplan.nz/privacy
            </p>
        </div>

        {# Submit Button #}
        <div class="col-span-full pt-4">
            {% include '_components/ui/button/button.twig' with {
                props: {
                    text: 'SUBMIT',
                    backgroundColor: colors.buttonBg,
                    textColor: colors.buttonText,
                    attributes: { 'type': 'submit' }
                }
            } only %}
        </div>

    </form>
</div>