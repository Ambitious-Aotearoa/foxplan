{# templates/_components/footer/footer.twig #}

{% set defaults = {
    backgroundColor: 'bg-foxplan-neutral-beige',
    textColor: 'text-foxplan-charcoal-brown',
    logoColor: 'text-foxplan-charcoal-brown',
    logoPath: '@webroot/dist/images/FoxPlan_Logo.svg',
    buttonColor: 'bg-foxplan-charcoal-brown',
    buttonTextColor: 'text-foxplan-white',
    separatorColor: 'text-foxplan-charcoal-brown'
} %}

{% set data = defaults | merge(props | default({})) %}

{% set ctaTitleStyles = 'font-size: clamp(2rem, 5vw, 3rem); line-height: 1;' %}
{% set paraStyles = 'font-size: clamp(1rem, 0.5vw + 0.6rem, 1.25rem); line-height: 1.4;' %}
{% set preheadStyles = 'font-size: clamp(0.75rem, 0.3vw + 0.65rem, 0.875rem); line-height: 1; letter-spacing: 0.1em;' %}

<footer
        class="relative w-full overflow-hidden"
        style="clip-path: polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%);"
        x-data="{
        ratio: 0,
        ticking: false,
        updateRatio() {
            if (!this.ticking) {
                window.requestAnimationFrame(() => {
                    const rect = this.$el.getBoundingClientRect();
                    const windowHeight = window.innerHeight;
                    if (rect.top < windowHeight) {
                        const visible = windowHeight - rect.top;
                        this.ratio = Math.min(1, Math.max(0, visible / rect.height));
                    } else {
                        this.ratio = 0;
                    }
                    this.ticking = false;
                });
                this.ticking = true;
            }
        },
        setHeight() {
            const inner = this.$el.querySelector('.footer-inner');
            if (inner) {
                // Footer needs viewportHeight to scroll into view,
                // PLUS footerContentHeight to fully reveal the content.
                // Without this, short viewports can never scroll far enough
                // to see the top of the footer.
                const h = inner.scrollHeight + window.innerHeight;
                this.$el.style.minHeight = h + 'px';
            }
        }
    }"
        @scroll.window="updateRatio()"
        @resize.window="updateRatio(); setHeight()"
        x-init="$nextTick(() => setHeight()); updateRatio()"
>
    <div class="footer-inner fixed bottom-0 left-0 w-full {{ data.backgroundColor }} flex flex-col justify-start sm:justify-end"
         style="will-change: transform; backface-visibility: hidden; transform: translateZ(0);">

        {# Animation Wrapper #}
        <div
                class="max-w-full mx-auto px-4 md:px-6 lg:px-8 pt-20 sm:pt-20 pb-12 relative z-10 w-full transition-all duration-150 ease-out"
                :style="`transform: scale(${0.9 + (ratio * 0.1)}) translateZ(0); opacity: ${0.5 + (ratio * 0.5)};`"
        >


            <div class="grid grid-cols-1 sm:grid-cols-12 gap-y-4 items-start">

                {# BRANDING & CTA (Left Side) #}
                <div class="sm:col-span-5 flex flex-col">
                    <div class="mb-6 md:mb-12 {{ data.logoColor }} hidden sm:block">
                        {{ svg(alias(data.logoPath))|attr({ class: 'w-32 md:w-28 h-auto fill-current', alt: 'FoxPlan Logo' }) }}
                    </div>
                    <h2 class="font-serif tracking-tight {{ data.textColor }} md:max-w-[300px] lg:max-w-md mb-4 md:mb-6 pr-2 md:pr-0" style="{{ ctaTitleStyles }} ">
                        Ready to reach your financial goals?
                    </h2>
                    <p class="{{ data.textColor }} opacity-90  max-w-[250px]  md:max-w-[300px] mb-4 md:mb-10" style="{{ paraStyles }}">
                        Book a chat with one of our financial advisers to get started.
                    </p>
                    <div class="mt-2 sm:mt-4">
                        {% include '_components/ui/button/button.twig' with {
                            props: { text: 'LEARN MORE', url: '/contact-us', style: 'primary', backgroundColor: data.buttonColor, textColor: data.buttonTextColor }
                        } only %}
                    </div>
                </div>

                {# RIGHT SIDE: LINKS GRID #}
                <div class="sm:col-span-7 pt-6 sm:pt-10 flex flex-col">
                    <div class="grid grid-cols-2 sm:grid-cols-3 gap-y-4 sm:gap-y-12 gap-x-8">

                        {# Column 1 #}
                        <div class="flex flex-col gap-y-3 sm:gap-y-4">
                            <a href="/mortgages" class="font-bold {{ data.textColor }} flex items-start gap-2 group" style="{{ preheadStyles }}">
                                <span class="{{ data.separatorColor }} opacity-40 mt-0.5">|</span>
                                <span class="transition-opacity duration-300 group-hover:opacity-70 uppercase">MORTGAGES</span>
                            </a>
                            <a href="/financial-planning" class="font-bold {{ data.textColor }} flex items-start gap-2" style="{{ preheadStyles }}">
                                <span class="{{ data.separatorColor }} opacity-40 mt-0.5">|</span>
                                <span class="transition-opacity duration-300 group-hover:opacity-70 uppercase">FINANCIAL PLANNING</span>
                            </a>
                            <a href="/savings-investment" class="sm:hidden font-bold {{ data.textColor }} flex items-start gap-2 group" style="{{ preheadStyles }}">
                                <span class="{{ data.separatorColor }} opacity-40 mt-0.5">|</span>
                                <span class="transition-opacity duration-300 group-hover:opacity-70 uppercase">SAVINGS & INVESTMENT</span>
                            </a>
                            <div class="pt-2 sm:pt-4">
                                <h3 class="font-bold {{ data.textColor }} flex items-start gap-2 mb-2 sm:mb-3" style="{{ preheadStyles }}">
                                    <span class="{{ data.separatorColor }} opacity-40 mt-0.5">|</span> LOCATION
                                </h3>
                                <div class="pl-3 {{ data.textColor }} opacity-90" style="{{ paraStyles }}">
                                    <p>Level 8, 138 The Terrace</p>
                                    <p>Wellington 6011</p>
                                </div>
                            </div>
                        </div>

                        {# Column 2 #}
                        <div class="flex flex-col gap-y-3 sm:gap-y-4">
                            <a href="/insurance" class="font-bold {{ data.textColor }} flex items-start gap-2 group" style="{{ preheadStyles }}">
                                <span class="{{ data.separatorColor }} opacity-40 mt-0.5">|</span>
                                <span class="transition-opacity duration-300 group-hover:opacity-70 uppercase">INSURANCE</span>
                            </a>
                            <a href="/business" class="font-bold {{ data.textColor }} flex items-start gap-2 group" style="{{ preheadStyles }}">
                                <span class="{{ data.separatorColor }} opacity-40 mt-0.5">|</span>
                                <span class="transition-opacity duration-300 group-hover:opacity-70 uppercase">BUSINESS & ACCOUNTING</span>
                            </a>
                            <a href="/about" class="sm:hidden font-bold {{ data.textColor }} flex items-start gap-2 group" style="{{ preheadStyles }}">
                                <span class="{{ data.separatorColor }} opacity-40 mt-0.5">|</span>
                                <span class="transition-opacity duration-300 group-hover:opacity-70 uppercase">ABOUT US</span>
                            </a>
                            <div class="pt-2 sm:pt-4">
                                <h3 class="font-bold {{ data.textColor }} flex items-start gap-2 mb-2 sm:mb-3" style="{{ preheadStyles }}">
                                    <span class="{{ data.separatorColor }} opacity-40 mt-0.5">|</span> PHONE
                                </h3>
                                <div class=" pl-3 {{ data.textColor }} opacity-90" style="{{ paraStyles }}">
                                    <p>0800 NO STRESS</p>
                                    <p>(0800 667 873)</p>
                                    <br class="hidden sm:block">
                                    <p>Office (04) 918 4659</p>
                                </div>
                            </div>
                        </div>

                        {# Column 3 #}
                        <div class="flex flex-col gap-y-3 sm:gap-y-4">
                            <a href="/savings-investment" class="hidden sm:flex font-bold {{ data.textColor }} items-start gap-2 group" style="{{ preheadStyles }}">
                                <span class="{{ data.separatorColor }} opacity-40">|</span>
                                <span class="transition-opacity duration-300 group-hover:opacity-70 uppercase">SAVINGS & INVESTMENT</span>
                            </a>
                            <a href="/about" class="hidden sm:flex font-bold {{ data.textColor }} items-start gap-2 group" style="{{ preheadStyles }}">
                                <span class="{{ data.separatorColor }} opacity-40">|</span>
                                <span class="transition-opacity duration-300 group-hover:opacity-70 uppercase">ABOUT US</span>
                            </a>
                            <div class="pt-2 sm:pt-4">
                                <h3 class="font-bold {{ data.textColor }} flex items-start gap-2 mb-2 sm:mb-3" style="{{ preheadStyles }}">
                                    <span class="{{ data.separatorColor }} opacity-40">|</span> LEGAL
                                </h3>
                                <div class="pl-3 space-y-1 {{ data.textColor }} opacity-90" style="{{ paraStyles }}">
                                    <a href="/Privacy" class="block transition-opacity duration-300 hover:opacity-70">Privacy Policy</a>
                                    <a href="/Complaints-Policy" class="block transition-opacity duration-300 hover:opacity-70">Complaints</a>
                                    <a href="/Disclaimer" class="block transition-opacity duration-300 hover:opacity-70">Disclaimer</a>
                                    <a href="/Disclosure" class="block transition-opacity duration-300 hover:opacity-70">Disclosure</a>
                                </div>
                            </div>
                        </div>

                        {# --- SOCIAL LINKS --- #}
                        {% set isDarkBg = data.backgroundColor == 'bg-foxplan-charcoal-brown' %}
                        {% set socialIconColor = isDarkBg ? 'text-foxplan-charcoal-brown' : 'text-foxplan-neutral-beige' %}
                        {% set socialBoxColor  = isDarkBg ? 'bg-foxplan-yellow' : 'bg-foxplan-charcoal-brown' %}

                        <div class="flex items-end sm:col-start-3 mt-2">
                            <div class="flex gap-2">
                                {% if socialLinks.facebook ?? null %}
                                    <div class="hover:opacity-70 transition-opacity duration-300">
                                        {{ include('_components/ui/icons/facebook-icon.twig', {
                                            props: { iconColor: socialIconColor, boxColor: socialBoxColor, size: 'w-8 h-8', url: socialLinks.facebook }
                                        }) }}
                                    </div>
                                {% endif %}
                                {% if socialLinks.instagram ?? null %}
                                    <div class="hover:opacity-70 transition-opacity duration-300">
                                        {{ include('_components/ui/icons/instagram-icon.twig', {
                                            props: { iconColor: socialIconColor, boxColor: socialBoxColor, size: 'w-8 h-8', url: socialLinks.instagram }
                                        }) }}
                                    </div>
                                {% endif %}
                                {% if socialLinks.linkedin ?? null %}
                                    <div class="hover:opacity-70 transition-opacity duration-300">
                                        {{ include('_components/ui/icons/linkedin-icon.twig', {
                                            props: { iconColor: socialIconColor, boxColor: socialBoxColor, size: 'w-8 h-8', url: socialLinks.linkedin }
                                        }) }}
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# --- GIANT BACKGROUND TEXT --- #}
        <div class="w-full pointer-events-none p-0 m-0 overflow-visible relative z-0">
            <h1
                    class="w-full text-[28vw] font-bold leading-[0.7] select-none tracking-[-0.06em] text-center {{ data.textColor }}
                       transition-transform duration-75 ease-out"
                    :style="`transform: scale(${0.7 + (ratio * 0.3)}) translateY(${10 - (ratio * 10)}%) translateZ(0);`"
            >
                foxplan
            </h1>
        </div>
    </div>
</footer>