{# templates/_components/nav/nav.twig #}

{# --- 1. FETCH DATA --- #}
{% set navArticle = craft.entries()
    .section('article')
    .with(['featuredImage'])
    .one() %}

{% set staffMembers = craft.entries().section('staff').all() %}
{% set committeeMembers = craft.entries().section('investmentCommittee').all() %}

{% set policyPages = craft.entries()
    .section('pages')
    .slug(['disclaimer', 'privacy', 'complaints', 'disclosure', 'privacy-policy', 'complaints-policy'])
    .all() %}

{# --- 2. Theme Logic --- #}
{% set defaultTheme = {
    backgroundColor: 'bg-foxplan-white',
    textColor: 'text-foxplan-charcoal-brown',
    searchBgColor: 'bg-foxplan-charcoal-brown',
    ctaBgColor: 'bg-foxplan-charcoal-brown',
    iconColor: 'text-foxplan-white',
    logoFilter: 'fill-current',
    ctaTextColor: 'text-foxplan-white'
} %}

{% set theme = (navigationTheme is defined and navigationTheme is iterable) ? defaultTheme|merge(navigationTheme) : defaultTheme %}

{% set wordmarkPath = '@webroot/dist/images/foxplan_wordmark.svg' %}
{% set iconPath = '@webroot/dist/images/FoxPlan_Logo.svg' %}

{# --- 3. Navigation Data Structure --- #}
{% set megaMenuData = {
    'Insurance': [
        { title: 'Personal & Medical Insurance', url: '/Personal-Medical-Insurance', desc: 'Protect your finances and your family from illness or disability with our range of personal and medical insurance.' },
        { title: 'Business Insurance', url: '/business-insurance', desc: 'Support the continuity of your business after loss with co-shareholder or key person insurance.' },
        { title: 'Group & Workplace Insurance', url: '/group-workplace-insurance', desc: 'Get income protection, life, trauma or total and permanent disablement cover for business owners and their teams.' }
    ],
    'Savings & Investment': [
        { title: 'KiwiSaver', url: '/kiwisaver', desc: 'Get personalised advice from your KiwiSaver adviser around choosing a fund, managing your contributions and withdrawing your savings for a first home deposit. ' },
        { title: 'Retirement Planning', url: '/retirement-planning', desc: 'Start planning for a more prepared tomorrow with personalised retirement advice and legacy planning.' },
        { title: 'Savings', url: '/savings', desc: 'Our advisers can help you build sustainable habits that make it easier to budget and squirrel more money away for a rainy day. ' },
        { title: 'Investment', url: '/investment-planning', desc: 'Get personalised guidance for starting your investment journey, investing an inheritance and making your money last into retirement. ' }
    ],
    'Mortgages': [
        { title: 'Property Investment', url: '/property-investment', desc: 'Invest in your future with lending support for first time or experienced property investors.' },
        { title: 'Property Upgrade', url: '/property-upgrade', desc: 'Whether you’re selling your home, renovating or building, we aim to streamline the process.' },
        { title: 'First Home Buyers', url: '/first-home-buyers', desc: 'Support and guidance from budgeting, pre-approval and protection planning for reaching your property goals.' },
        { title: 'Refinancing & Refixing', url: '/refinancing-refixing', desc: 'Free up funds, consolidate your debts or explore potential savings on your mortgage with advice on refinancing or refixing.' }
    ],
    'Business & Accounting': [
        { title: 'Accounting', url: '/accounting', desc: 'Get personalised advice designed to support long-term clarity and growth in your business. ' },
        { title: 'Business Planning', url: '/business-planning', desc: 'Gain strategic advice for setting up your business or making your existing systems and processes run more smoothly. ' },
        { title: 'Employee Financial Wellbeing', url: '/employee-financial-wellbeing', desc: 'Our range of benefit packages, financial bootcamps and financial health checks are designed to support the financial wellbeing of your staff.' }
    ],
    'News': [
        { title: 'Insights', url: '/pages/Insights', desc: 'Get financial updates, insights and practical tips on financial planning, investments, mortgages, KiwiSaver and more.' },
        { title: 'Podcast', url: '/dollars-and-sense-podcast', desc: 'The Dollars & Sense podcast is hosted by qualified financial advisers Tim Ellis and Brodie Haggerty. Listen to smart financial advice for Kiwis in their prime.' }
    ],
    'About': [
        { title: 'About FoxPlan', url: '/about', desc: 'John and Sally Killick founded FoxPlan in 1996 to help Kiwis make confident, informed choices about every part of their financial lives.' },
        { title: 'Careers', url: '/careers', desc: 'We’re proud to grow a team of people who share our passion for helping Kiwis make confident financial decisions. Learn more about current opportunities for joining our ranks. ' },
        { title: 'Equity Partners', url: '/equity-partners', desc: 'Our equity programme helps financial advisers and accountants build and grow their businesses while sharing the support and success of FoxPlan. ' },
        { title: 'Meet the Team', url: '/pages/Meet-the-team', desc: 'Meet the Financial Advisers, Accountants, Wealth Managers and Management staff that make up our team. ' },
        { title: 'Suppliers', url: '/pages/Our-Suppliers', desc: 'We work with New Zealand’s most trusted financial institutions. View our list of bank and non-bank lenders and insurance suppliers here. ' },
        { title: 'Investment Committee', url: '/our-investment-committee', desc: 'Learn more about how Consilium provides CEFEX-certified research and strategies to ensure your investments are effectively managed for long-term success. ' }
    ]
} %}

{% set mainNavOrder = ['Financial Planning', 'Insurance', 'Savings & Investment', 'Business & Accounting', 'Mortgages', 'News', 'About'] %}

<nav class="w-full fixed top-0 left-0 right-0 z-[9999] font-aktiv"
     x-data="{
        openTab: null,
        mobileMenuOpen: false,
        activeMobileTab: null,
        searchOpen: false,
        searchQuery: '',
        isScrolled: false,

        allLinks: [
            {% for handle in mainNavOrder %}
                {% if handle not in ['News', 'About'] %}
                    {% set tabUrl = (handle == 'Financial Planning') ? url('financial-planning') : (handle == 'Business & Accounting') ? url('business') : url(handle|lower|replace({' & ': '-', ' ': '-'})) %}
                    { title: '{{ handle|e('js') }}', url: '{{ tabUrl|e('js') }}', category: 'Navigation' },
                {% endif %}
            {% endfor %}

            {% for handle, items in megaMenuData %}
                {% for item in items %}
                    { title: '{{ item.title|e('js') }}', url: '{{ item.url|e('js') }}', category: '{{ handle|capitalize|e('js') }}' },
                {% endfor %}
            {% endfor %}

            {% for person in staffMembers %}
                { title: '{{ person.title|e('js') }}', url: '{{ person.url|e('js') }}', category: 'Team Member' },
            {% endfor %}
            {% for person in committeeMembers %}
                { title: '{{ person.title|e('js') }}', url: '{{ person.url|e('js') }}', category: 'Investment Committee' },
            {% endfor %}

            {% for page in policyPages %}
                { title: '{{ page.title|e('js') }}', url: '{{ page.url|e('js') }}', category: 'Legal & Policy' },
            {% endfor %}
            { title: 'Disclaimer', url: '/pages/Disclaimer', category: 'Legal & Policy' },
            { title: 'Privacy Policy', url: '/pages/Privacy-Policy', category: 'Legal & Policy' },
            { title: 'Disclosure', url: '/pages/Disclosure', category: 'Legal & Policy' },
            { title: 'Complaints Policy', url: '/pages/Complaints-Policy', category: 'Legal & Policy' }
        ],

        get filteredResults() {
            if (this.searchQuery === '') return [];
            const q = this.searchQuery.toLowerCase();
            const uniqueResults = [];
            const map = new Map();
            const filtered = this.allLinks.filter(item => item.title.toLowerCase().includes(q));
            for (const item of filtered) {
                if(!map.has(item.url)){ map.set(item.url, true); uniqueResults.push(item); }
            }
            return uniqueResults;
        }
     }"
     @scroll.window="isScrolled = (window.pageYOffset > 50)"
     @keydown.escape.window="searchOpen = false; mobileMenuOpen = false; searchQuery = ''">

    {# --- HEADER CONTENT --- #}
    <div class="w-full {{ theme.backgroundColor }} relative z-[510] transition-all duration-300"
         @mouseleave="openTab = null">
        <div class="flex items-center h-16 lg:h-16">
            <a href="/"
               class="flex items-center h-full pl-4 lg:pl-6 pr-4 xl:pr-10 flex-none {{ theme.textColor }} pt-1.5 overflow-hidden">
                <div class="relative h-7 lg:h-9 xl:h-11 w-auto flex items-center">
                    <div class="transition-all duration-500 transform"
                         :class="isScrolled ? '-translate-y-full opacity-0' : 'translate-y-0 opacity-100'">
                        {{ svg(alias(wordmarkPath))|attr({ class: 'h-7 lg:h-9 xl:h-11 w-auto ' ~ theme.logoFilter }) }}
                    </div>
                    <div class="absolute inset-0 flex items-center transition-all duration-500 transform"
                         :class="isScrolled ? 'translate-y-0 opacity-100' : 'translate-y-full opacity-0'" x-cloak>
                        {{ svg(alias(iconPath))|attr({ class: 'h-6 lg:h-8 xl:h-9 w-auto ' ~ theme.logoFilter }) }}
                    </div>
                </div>
            </a>

            <div class="flex-grow flex-shrink flex items-center h-full overflow-hidden">
                <div class="hidden lg:flex items-center justify-around w-full mx-auto text-[12px] xl:text-[14px] font-medium {{ theme.textColor }} h-full">
                    {% for handle in mainNavOrder %}
                        {% set hasDropdown = megaMenuData[handle] is defined and megaMenuData[handle]|length > 0 %}
                        {% set isStatic = handle in ['News', 'About'] %}
                        {% set tabUrl = (handle == 'Financial Planning') ? url('financial-planning') : (handle == 'Business & Accounting') ? url('business') : (isStatic ? 'javascript:void(0)' : url(handle|lower|replace({' & ': '-', ' ': '-'}))) %}

                        <a href="{{ tabUrl }}"
                           class="h-full px-1 xl:px-2 flex items-center transition group {{ isStatic ? 'cursor-default' : 'hover:opacity-60' }}"
                           @mouseenter="openTab = {{ hasDropdown ? "'" ~ handle ~ "'" : 'null' }}">
                            <span class="flex items-center gap-0.5 xl:gap-1 whitespace-nowrap">
                                {{ handle }}
                                {% if hasDropdown %}
                                    <svg class="w-2.5 h-2.5 xl:w-3 xl:h-3 transition-transform duration-200"
                                         :class="openTab === '{{ handle }}' ? 'rotate-180' : ''" fill="none"
                                         stroke="currentColor" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7"
                                                                                         stroke-width="2"
                                                                                         stroke-linecap="round"
                                                                                         stroke-linejoin="round"/></svg>
                                {% endif %}
                            </span>
                        </a>
                    {% endfor %}
                </div>
            </div>

            <div class="flex flex-none justify-end items-stretch h-full">
                {# SEARCH BUTTON #}
                <button @click="searchOpen = true"
                        class="h-full px-4 lg:px-5 flex items-center justify-center cursor-pointer lg:{{ theme.searchBgColor }} lg:{{ theme.iconColor }} {{ theme.textColor }} lg:border-r border-foxplan-charcoal-brown/10">
                    <svg viewBox="0 0 20 20" fill="none" class="w-6 h-6 lg:w-4 xl:w-5 lg:h-4 xl:h-5">
                        <path d="M9.16667 15.8333C12.8486 15.8333 15.8333 12.8486 15.8333 9.16667C15.8333 5.48477 12.8486 2.5 9.16667 2.5C5.48477 2.5 2.5 5.48477 2.5 9.16667C2.5 12.8486 5.48477 15.8333 9.16667 15.8333Z"
                              stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M17.5 17.5L13.875 13.875" stroke="currentColor" stroke-width="1.5"
                              stroke-linecap="square" stroke-linejoin="round"/>
                    </svg>
                </button>

                {# HAMBURGER BUTTON #}
                <button @click="mobileMenuOpen = true"
                        class="lg:hidden h-full px-5 {{ theme.textColor }} flex flex-col justify-center items-end gap-1.5 cursor-pointer">
                    <span class="w-8 h-0.5 bg-current"></span>
                    <span class="w-5 h-0.5 bg-current"></span>
                    <span class="w-8 h-0.5 bg-current"></span>
                </button>

                <div class="hidden lg:block h-full">
                    {% include '_components/ui/button/button.twig' with {
                        props: {
                            text: 'GET IN TOUCH',
                            url: url('contact-us'),
                            backgroundColor: theme.ctaBgColor,
                            textColor: theme.ctaTextColor,
                            classes: 'h-full px-4 xl:px-8 flex items-center uppercase tracking-widest text-[11px] xl:text-sm font-bold rounded-none whitespace-nowrap'
                        }
                    } only %}
                </div>
            </div>
        </div>

        {# --- MEGAMENU --- #}
        {% for handle, items in megaMenuData %}
            {% set itemCount = items|length %}
            <div x-show="openTab === '{{ handle }}'"
                 x-transition:enter="transition ease-out duration-200"
                 x-transition:enter-start="opacity-0 -translate-y-1"
                 x-transition:enter-end="opacity-100 translate-y-0"
                 style="display: none;"
                 class="hidden lg:block absolute top-full left-0 right-0 z-[600]"
                 @mouseenter="openTab = '{{ handle }}'"
                 @mouseleave="openTab = null">

                <div class="px-8 w-full max-w-[1920px] mx-auto flex justify-center">
                    <div class="flex bg-[#FCF9F6] border border-foxplan-tint-line shadow-2xl overflow-hidden
                    {{ itemCount == 6 ? 'w-full min-h-[450px]' : 'max-w-6xl min-h-[420px]' }}">

                        {# LEFT SIDE: LINKS #}
                        <div class="{{ itemCount == 6 ? 'w-2/3' : 'w-3/5' }} grid {{ (itemCount == 2) ? 'grid-cols-1' : (itemCount == 6 ? 'grid-cols-3' : 'grid-cols-2') }}">
                            {% for subItem in items %}

                                <a href="{{ subItem.url }}"
                                   class="group/link border-r border-b border-foxplan-tint-line last:border-r-0 flex flex-col transition-colors duration-300 hover:bg-[#CECECE]
   {{ itemCount == 2 ? 'p-12 justify-center' : 'p-8 justify-start' }}">

                                    <div class="mb-4 border-l-[3px] border-foxplan-yellow pl-4">
                                        <p class="text-[13px] font-bold tracking-[0.15em] text-foxplan-charcoal-brown uppercase leading-tight group-hover/link:text-black transition-colors">
                                            {{ subItem.title }}
                                        </p>
                                    </div>

                                    <p class="text-[14px] text-foxplan-charcoal-brown leading-relaxed opacity-90 group-hover/link:opacity-100">
                                        {{ subItem.desc }}
                                    </p>
                                </a>
                            {% endfor %}

                            {% if itemCount == 3 %}
                                <div class="p-8 border-b border-foxplan-tint-line border-r"></div>
                            {% endif %}
                        </div>

                        {# RIGHT SIDE: ARTICLE #}
                        <div class="{{ itemCount == 6 ? 'w-1/3' : 'w-2/5' }} relative group overflow-hidden bg-foxplan-neutral-beige">
                            {% if navArticle %}
                                {% set navImg = navArticle.featuredImage.one() %}
                                <a href="{{ navArticle.url }}" class="block w-full h-full relative no-underline">
                                    {% if navImg %}
                                        <img src="{{ navImg.url }}"
                                             class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
                                             alt="{{ navArticle.title }}">
                                    {% endif %}
                                    <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/10 to-transparent"></div>
                                    <div class="absolute inset-0 p-10 flex flex-col justify-end">
                                    <span class="text-white/80 font-aktiv text-[10px] font-bold tracking-[0.2em] mb-3 uppercase">
                                        {{ navArticle.postDate | date('F j, Y') }}
                                    </span>
                                        <h3 class="text-white font-serif {{ itemCount < 6 ? 'text-2xl xl:text-3xl' : 'text-3xl xl:text-4xl' }} mb-6 leading-[1.1]">
                                            {{ navArticle.title }}
                                        </h3>
                                        <span class="text-white text-[11px] font-bold tracking-[0.2em] uppercase border-b border-white/40 pb-1 self-start group-hover:border-foxplan-yellow transition-colors">
                                        READ MORE
                                    </span>
                                    </div>
                                </a>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>

    {# --- MOBILE MENU OVERLAY --- #}
    {# --- MOBILE MENU OVERLAY --- #}
    <template x-teleport="body">
        <div x-show="mobileMenuOpen"
                {# 1. Overlay Slide Transition #}
             x-transition:enter="transition ease-out duration-300"
             x-transition:enter-start="translate-x-full"
             x-transition:enter-end="translate-x-0"
             x-transition:leave="transition ease-in duration-300"
             x-transition:leave-start="translate-x-0"
             x-transition:leave-end="translate-x-full"
             class="fixed inset-0 z-[10001] bg-foxplan-neutral-beige flex flex-col lg:hidden"
             style="display: none;"
             x-cloak>

            {# --- MOBILE HEADER --- #}
            <div class="flex items-center justify-between h-16 px-6 border-b border-foxplan-tint-line/50">
                <div class="w-32">
                    {# Assuming wordmarkPath is defined in your main nav context #}
                    {{ svg(alias(wordmarkPath))|attr({ class: 'h-8 w-auto fill-foxplan-charcoal-brown' }) }}
                </div>

                <button @click="mobileMenuOpen = false" class="p-2 text-foxplan-charcoal-brown focus:outline-none"
                        aria-label="Close Menu">
                    <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M18 6L6 18M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </button>
            </div>

            {# --- MOBILE NAVIGATION LINKS --- #}
            <div class="flex-grow flex flex-col px-8 py-10 overflow-y-auto">
                <div class="flex flex-col gap-1">
                    {% for handle in mainNavOrder %}
                        {% set hasDropdown = (megaMenuData[handle] is defined) and (megaMenuData[handle]|length > 0) %}
                        {% set isStatic = handle in ['News', 'About'] %}

                        {# Dynamic URL logic #}
                        {% set tabUrl = (handle == 'Financial Planning') ? url('financial-planning') : (handle == 'Business & Accounting') ? url('business') : (isStatic ? 'javascript:void(0)' : url(handle|lower|replace({' & ': '-', ' ': '-'}))) %}

                        <div class="border-b border-foxplan-tint-line py-6">
                            <div class="flex items-center justify-between font-aktiv uppercase tracking-[0.15em] text-foxplan-charcoal-brown">

                                {#
                                CLICK LOGIC: If 'News' or 'About', clicking the label toggles the menu.
                                Otherwise, it follows the link normally.
                                #}
                                <a href="{{ tabUrl }}"
                                   class="flex-grow select-none"
                                   style="font-size: clamp(1.5rem, 1.5vw + 0.5rem, 2rem);"
                                        {% if isStatic %}
                                    @click.prevent="activeMobileTab = (activeMobileTab === '{{ handle }}' ? null : '{{ handle }}')"
                                        {% endif %}>
                                    {{ handle }}
                                </a>

                                {% if hasDropdown %}
                                    <button @click="activeMobileTab = (activeMobileTab === '{{ handle }}' ? null : '{{ handle }}')"
                                            class="p-2 focus:outline-none">
                                        <svg class="w-5 h-5 transition-transform duration-300"
                                             :class="activeMobileTab === '{{ handle }}' ? 'rotate-180' : ''"
                                             fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path d="M19 9l-7 7-7-7" stroke-width="2" stroke-linecap="round"
                                                  stroke-linejoin="round"/>
                                        </svg>
                                    </button>
                                {% endif %}
                            </div>

                            {# --- DROPDOWN ITEMS --- #}
                            {% if hasDropdown %}
                                <div x-show="activeMobileTab === '{{ handle }}'"
                                     x-collapse
                                     class="mt-6 flex flex-col gap-5 pl-4 font-aktiv">
                                    {% for subItem in megaMenuData[handle] %}
                                        <a href="{{ subItem.url }}"
                                           class="opacity-60 active:opacity-100 transition-opacity"
                                           style="font-size: clamp(1.125rem, 1.5vw + 0.5rem, 1.5rem);">
                                            {{ subItem.title }}
                                        </a>
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>
                    {% endfor %}

                    {# --- STATIC FOOTER LINK --- #}
                    <a href="/contact-us"
                       class="border-b border-foxplan-charcoal-brown/10 py-8 font-aktiv uppercase tracking-[0.15em] text-foxplan-charcoal-brown"
                       style="font-size: clamp(1.5rem, 1.5vw + 0.5rem, 2rem);">
                        Contact
                    </a>
                </div>
            </div>
        </div>
    </template>

    {# --- SEARCH OVERLAY --- #}
    <template x-teleport="body">
        <div x-show="searchOpen" x-transition.opacity
             class="fixed inset-0 z-[10002] bg-foxplan-neutral-beige flex flex-col items-center pt-[10vh] lg:pt-[15vh] px-6"
             style="display: none;">
            <button @click="searchOpen = false; searchQuery = ''"
                    class="absolute top-6 right-6 lg:top-10 lg:right-10 text-foxplan-charcoal-brown p-2">
                <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M18 6L6 18M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </button>
            <div class="w-full max-w-4xl">
                <div class="text-center mb-8 lg:mb-12"><h2
                            class="text-[40px] lg:text-[80px] font-serif text-foxplan-charcoal-brown leading-tight mb-4">
                        Search anything</h2></div>

                <div class="relative border-b border-foxplan-charcoal-brown/30 pb-4 flex items-center">
                    <svg class="w-8 h-8 lg:w-10 lg:h-10 text-foxplan-charcoal-brown/40 mr-4" fill="none"
                         stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.2">
                        <circle cx="10.5" cy="10.5" r="7.5"/>
                        <line x1="21" y1="21" x2="15.8" y2="15.8"/>
                    </svg>
                    <input type="text" x-model="searchQuery" placeholder="Search by keyword, topic or title"
                           class="bg-transparent border-none outline-none text-xl lg:text-3xl w-full text-foxplan-charcoal-brown placeholder:text-foxplan-charcoal-brown/30 font-aktiv"
                           x-ref="searchInput"
                           x-effect="if(searchOpen) { setTimeout(() => $refs.searchInput.focus(), 100) }">
                </div>

                <div class="mt-8 max-h-[60vh] overflow-y-auto pb-20">
                    <template x-for="result in filteredResults" :key="result.url">
                        <a :href="result.url"
                           class="group flex items-center justify-between py-6 border-b border-foxplan-charcoal-brown/10 hover:px-4 transition-all">
                            <div>
                                <span class="text-[10px] tracking-widest uppercase text-foxplan-charcoal-brown/40 block mb-1"
                                      x-text="result.category"></span>
                                <h3 class="text-xl lg:text-2xl text-foxplan-charcoal-brown group-hover:text-black"
                                    x-text="result.title"></h3></div>
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path d="M5 12h14M12 5l7 7-7 7" stroke-width="2" stroke-linecap="round"
                                      stroke-linejoin="round"/>
                            </svg>
                        </a>
                    </template>
                </div>
            </div>
        </div>
    </template>
</nav>

<div class="h-16"></div>