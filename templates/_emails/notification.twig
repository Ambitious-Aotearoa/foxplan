{# _emails/notification.twig #}
{# Admin notification email  #}

{% set formName = submission.message.formName|default('Website Inquiry') %}

{# FoxPlan Brand Colors #}
{% set brandCharcoal = '#270E15' %}
{% set brandBeige = '#F7F2E0' %}
{% set brandTintLine = 'rgba(39, 14, 21, 0.1)' %}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>New FoxPlan Lead: {{ formName }}</title>
</head>
<body style="margin: 0; padding: 0; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; background-color: {{ brandBeige }};">
<table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: {{ brandBeige }};">
    <tr>
        <td style="padding: 40px 20px;">
            <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="600" style="max-width: 600px; margin: 0 auto; background-color: #ffffff; border: 1px solid {{ brandTintLine }};">

                {# --- HEADER --- #}
                <tr>
                    <td style="background-color: {{ brandCharcoal }}; padding: 30px 40px;">
                        <p style="margin: 0 0 5px 0; color: {{ brandBeige }}; font-size: 10px; font-weight: 700; uppercase; letter-spacing: 2px; opacity: 0.7;">INTERNAL NOTIFICATION</p>
                        <h1 style="margin: 0; color: {{ brandBeige }}; font-size: 22px; font-weight: 300; letter-spacing: -0.02em;">
                            New {{ formName }}
                        </h1>
                    </td>
                </tr>

                {# --- CONTACT INFO --- #}
                <tr>
                    <td style="padding: 40px 40px 30px 40px; border-bottom: 1px solid {{ brandTintLine }};">
                        <h2 style="margin: 0 0 20px 0; color: {{ brandCharcoal }}; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; opacity: 0.5;">
                            Contact Information
                        </h2>
                        <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                            {% set fields = {
                                'Name': (submission.message.firstName|default('') ~ ' ' ~ submission.message.lastName|default(''))|trim,
                                'Email': submission.fromEmail|default('Not provided'),
                                'Phone': submission.message.phone|default('Not provided'),
                                'Region': submission.message.region|default('Not provided')
                            } %}

                            {% for label, value in fields %}
                                <tr>
                                    <td style="padding: 8px 0; color: {{ brandCharcoal }}; font-size: 14px; width: 100px; font-weight: 600;">{{ label }}:</td>
                                    <td style="padding: 8px 0; color: {{ brandCharcoal }}; font-size: 14px; opacity: 0.8;">{{ value }}</td>
                                </tr>
                            {% endfor %}
                        </table>
                    </td>
                </tr>

                {# --- ADDITIONAL DETAILS (Optional fields) --- #}
                <tr>
                    <td style="padding: 30px 40px; border-bottom: 1px solid {{ brandTintLine }};">
                        <h2 style="margin: 0 0 20px 0; color: {{ brandCharcoal }}; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; opacity: 0.5;">
                            Inquiry Details
                        </h2>
                        <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                            <tr>
                                <td style="padding: 8px 0; color: {{ brandCharcoal }}; font-size: 14px; width: 100px; font-weight: 600;">Service:</td>
                                <td style="padding: 8px 0; color: {{ brandCharcoal }}; font-size: 14px; opacity: 0.8;">{{ submission.message.service|default('General Inquiry') }}</td>
                            </tr>
                            {% if submission.message.budget is defined %}
                                <tr>
                                    <td style="padding: 8px 0; color: {{ brandCharcoal }}; font-size: 14px; width: 100px; font-weight: 600;">Budget:</td>
                                    <td style="padding: 8px 0; color: {{ brandCharcoal }}; font-size: 14px; opacity: 0.8;">{{ submission.message.budget }}</td>
                                </tr>
                            {% endif %}
                        </table>
                    </td>
                </tr>

                {# --- MESSAGE --- #}
                <tr>
                    <td style="padding: 30px 40px 50px 40px;">
                        <h2 style="margin: 0 0 15px 0; color: {{ brandCharcoal }}; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; opacity: 0.5;">
                            Message / Comments
                        </h2>
                        <p style="margin: 0; color: {{ brandCharcoal }}; font-size: 15px; line-height: 1.6; white-space: pre-wrap; opacity: 0.9;">
                            {{ submission.message.inquiry|default(submission.message.message|default('No message provided')) }}
                        </p>
                    </td>
                </tr>

                {# --- FOOTER --- #}
                <tr>
                    <td style="background-color: #fcfbf7; padding: 20px 40px; text-align: center; border-top: 1px solid {{ brandTintLine }};">
                        <p style="margin: 0; color: {{ brandCharcoal }}; font-size: 11px; opacity: 0.5;">
                            This lead was generated from the <strong>foxplan.nz</strong> website.
                        </p>
                    </td>
                </tr>

            </table>
        </td>
    </tr>
</table>
</body>
</html>