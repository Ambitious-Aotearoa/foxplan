{# _emails/notification.twig #}
{% set messageData = submission.message %}
{% set formName = messageData.formName|default('Website Inquiry') %}

{# logic to match your PHP Module: if entryId exists, it's a guide/landing page request #}
{% set isGuideRequest = messageData.entryId is defined %}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>New Lead Notification</title>
</head>
<body style="margin: 0; padding: 0; font-family: Arial, sans-serif; background-color: #f5f5f5;">
<table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #f5f5f5;">
    <tr>
        <td style="padding: 40px 20px;">
            <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="600" style="max-width: 600px; margin: 0 auto; background-color: #ffffff; border: 1px solid #e0e0e0;">

                {# Header  #}
                <tr>
                    <td style="background-color: #FBC938; padding: 25px 30px;">
                        <h1 style="margin: 0; color: #270E15; font-size: 18px; font-weight: 400; line-height: 1.2; text-transform: uppercase; letter-spacing: 1px;">
                            {{ isGuideRequest ? 'Guide Download Request' : 'New Website Contact' }}
                        </h1>
                        <p style="margin: 5px 0 0 0; color: #270E15; font-size: 24px; font-weight: 700;">
                            {{ formName }}
                        </p>
                    </td>
                </tr>

                {# Contact Info Table #}
                <tr>
                    <td style="padding: 30px; border-bottom: 1px solid #e0e0e0;">
                        <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                            <tr>
                                <td style="padding: 8px 0; color: #666; font-size: 14px; width: 140px;"><strong>Name:</strong></td>
                                <td style="padding: 8px 0; color: #270E15; font-size: 14px; font-weight: 500;">
                                    {{ submission.fromName }} {{ messageData.lastName ?? '' }}
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 8px 0; color: #666; font-size: 14px;"><strong>Email:</strong></td>
                                <td style="padding: 8px 0; color: #270E15; font-size: 14px;">
                                    <a href="mailto:{{ submission.fromEmail }}" style="color: #270E15; text-decoration: underline;">{{ submission.fromEmail }}</a>
                                </td>
                            </tr>

                            {# Phone Field  #}
                            {% set phone = messageData.phone ?? null %}
                            {% if phone %}
                                <tr>
                                    <td style="padding: 8px 0; color: #666; font-size: 14px;"><strong>Phone:</strong></td>
                                    <td style="padding: 8px 0; color: #270E15; font-size: 14px;">{{ phone }}</td>
                                </tr>
                            {% endif %}

                            {# Call Preference #}
                            {% if messageData.preference is defined and messageData.preference is not empty %}
                                <tr>
                                    <td style="padding: 8px 0; color: #666; font-size: 14px;"><strong>Call Preference:</strong></td>
                                    <td style="padding: 8px 0; color: #270E15; font-size: 14px; text-transform: capitalize;">{{ messageData.preference }}</td>
                                </tr>
                            {% endif %}

                            {# Interest (for standard contact form) #}
                            {% if messageData.Interest is defined %}
                                <tr>
                                    <td style="padding: 8px 0; color: #666; font-size: 14px;"><strong>Interest:</strong></td>
                                    <td style="padding: 8px 0; color: #270E15; font-size: 14px;">{{ messageData.Interest }}</td>
                                </tr>
                            {% endif %}
                        </table>
                    </td>
                </tr>

                {# Submission Details / Body #}
                {% set bodyMessage = messageData.body ?? null %}
                {% if bodyMessage %}
                    <tr>
                        <td style="padding: 30px; background-color: #fafafa;">
                            <h2 style="margin: 0 0 12px 0; color: #666; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px;">Message / Context</h2>
                            <p style="margin: 0; color: #270E15; font-size: 14px; line-height: 1.6; white-space: pre-wrap;">{{ bodyMessage }}</p>
                        </td>
                    </tr>
                {% endif %}

            </table>
        </td>
    </tr>
</table>
</body>
</html>