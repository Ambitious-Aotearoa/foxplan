{# templates/_emails/first-home-guide-download.twig #}


{% set leadMagnetEntry = craft.entries().section('leadMagnet').one() %}
{% set pdfAsset = leadMagnetEntry.downloadableItem.one() ?? null %}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ leadMagnetEntry.emailSubject }}</title>
    <style>
        body { margin: 0; padding: 0; font-family: Arial, sans-serif; background-color: #F9EFD8; color: #270E15; }
        .email-container { max-width: 600px; margin: 0 auto; background-color: #ffffff; }
        .content { padding: 40px 30px; }
        .button {
            display: inline-block;
            background-color: #270E15;
            color: #F9EFD8;
            text-decoration: none;
            padding: 15px 30px;
            margin: 20px 0;
            font-weight: bold;
            text-transform: uppercase;
            font-size: 14px;
        }
        .footer { padding: 20px; text-align: center; font-size: 12px; color: #666; background-color: #F9EFD8; }
    </style>
</head>
<body>
<div class="email-container">
    <div class="content">
        {# 2.  Email Greeting field #}
        <h2>{{ leadMagnetEntry.emailGreeting }} {{ firstName ?? 'there' }},</h2>

        {# 3.  Email Body field #}
        <div style="line-height: 1.6;">
            {{ leadMagnetEntry.emailBody | raw }}
        </div>

        {# 4. The Download Button #}
        {% if pdfAsset %}
            <p style="text-align: center;">
                <a href="{{ pdfAsset.url }}" class="button">
                    {{ leadMagnetEntry.attachmentMessage ?? 'Download Guide' }}
                </a>
            </p>
        {% endif %}

        <p>Best regards,<br><strong>The FoxPlan Team</strong></p>
    </div>

    <div class="footer">
        <p><strong>FoxPlan</strong><br>Financial Planning & Investment Advice</p>
        <p><a href="https://foxplan.nz" style="color: #270E15;">Visit our website</a></p>
    </div>
</div>
</body>
</html>