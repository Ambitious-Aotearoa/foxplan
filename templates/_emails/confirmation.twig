{# _emails/confirmation.twig #}
{# User mail Template #}

{# FoxPlan Brand Colors #}
{% set brandCharcoal = '#270E15' %}
{% set brandBeige = '#F7F2E0' %}
{% set brandTintLine = 'rgba(39, 14, 21, 0.1)' %}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Thank you for contacting FoxPlan</title>
</head>
<body style="margin: 0; padding: 0; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; background-color: {{ brandBeige }};">
<table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: {{ brandBeige }};">
    <tr>
        <td style="padding: 60px 20px;">
            <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="600" style="max-width: 600px; margin: 0 auto; background-color: #ffffff; border: 1px solid {{ brandTintLine }};">

                {# --- HEADER / LOGO --- #}
                <tr>
                    <td style="padding: 50px 50px 10px 50px; text-align: left;">
                        <h1 style="margin: 0; color: {{ brandCharcoal }}; font-size: 26px; font-weight: 800; letter-spacing: -0.05em; text-transform: lowercase;">foxplan</h1>
                    </td>
                </tr>

                {# --- MAIN CONTENT --- #}
                <tr>
                    <td style="padding: 10px 50px 50px 50px;">
                        <div style="width: 100%; height: 1px; background-color: {{ brandCharcoal }}; opacity: 0.1; margin-bottom: 45px;"></div>

                        <h2 style="margin: 0 0 25px 0; color: {{ brandCharcoal }}; font-size: 34px; font-weight: 300; line-height: 1; letter-spacing: -0.03em;">
                            Thank you for <br>your inquiry.
                        </h2>

                        <p style="margin: 0 0 35px 0; color: {{ brandCharcoal }}; opacity: 0.8; font-size: 16px; line-height: 1.6; max-width: 480px;">
                            We have received your message. One of our financial advisers will review your details and be in touch shortly to discuss your requirements.
                        </p>

                        <table role="presentation" cellspacing="0" cellpadding="0" border="0">
                            <tr>
                                <td style="background-color: {{ brandCharcoal }}; padding: 18px 35px;">
                                    <a href="https://foxplan.nz" style="color: {{ brandBeige }}; text-decoration: none; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 2px;">
                                        Visit our website
                                    </a>
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>

                {# --- FOOTER --- #}
                <tr>
                    <td style="background-color: #fcfbf7; padding: 45px 50px; border-top: 1px solid {{ brandTintLine }};">
                        <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                            <tr>
                                <td>
                                    <p style="margin: 0 0 12px 0; color: {{ brandCharcoal }}; font-size: 10px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; opacity: 0.5;">Wellington Office</p>
                                    <p style="margin: 0; color: {{ brandCharcoal }}; opacity: 0.7; font-size: 14px; line-height: 1.5;">
                                        Level 8, 138 The Terrace<br>
                                        Wellington 6011
                                    </p>
                                </td>
                                <td style="text-align: right; vertical-align: bottom;">
                                    <p style="margin: 0; color: {{ brandCharcoal }}; font-size: 13px; font-weight: 600;">
                                        <a href="https://foxplan.nz" style="color: {{ brandCharcoal }}; text-decoration: none;">foxplan.nz</a>
                                    </p>
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>

            </table>

            {# Bottom Sub-Footer #}
            <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="600" style="max-width: 600px; margin: 25px auto;">
                <tr>
                    <td style="text-align: center; color: {{ brandCharcoal }}; opacity: 0.4; font-size: 10px; letter-spacing: 0.5px;">
                        &copy; {{ "now"|date("Y") }} FoxPlan New Zealand. <br>
                        Authorised Financial Advisers.
                    </td>
                </tr>
            </table>
        </td>
    </tr>
</table>
</body>
</html>