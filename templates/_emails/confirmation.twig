{# _emails/confirmation.twig #}
{# User mail Template #}

{# FoxPlan Brand Colors #}
{% set brandCharcoal = '#270E15' %}
{% set brandBeige = '#F7F2E0' %}
{% set brandTintLine = 'rgba(39, 14, 21, 0.1)' %}

{% set formName = submission.message.formName|default('') %}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Thank you for contacting Foxplan</title>
</head>
<body style="margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; background-color: #F7F2E0;">
<table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #F7F2E0;">
    <tr>
        <td style="padding: 40px 20px;">
            <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="600" style="max-width: 600px; margin: 0 auto; background-color: #ffffff;">

                <tr>
                    <td style="background-color: #595C47; padding: 30px 40px; text-align: center;">
                        <h1 style="margin: 0; color: #F7F2E0; font-size: 28px; font-weight: 300; letter-spacing: 2px;">Foxplan</h1>
                    </td>
                </tr>

                <tr>

                </tr>

                <tr>
                    <td style="background-color: #404040; padding: 30px 40px; text-align: center;">
                        <p style="margin: 0; color: #BBB1A0; font-size: 12px;">
                            <a href="https://foxplan.nz" style="color: #BBB1A0;">foxplan.nz</a>
                        </p>
                    </td>
                </tr>

            </table>
        </td>
    </tr>
</table>
</body>
</html>