{# templates/_sections/content-sections/accounting-grid.twig #}


<section class="w-full bg-foxplan-neutral-beige py-[clamp(2.5rem,8vh,6rem)] px-4 md:px-6 lg:px-8 border-b border-foxplan-charcoal-brown/10 overflow-hidden">


    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-[clamp(2rem,6vw,5rem)] items-start">

        {# Left Column: Heading and Intro #}
        <div class="lg:col-span-4">
            <h2 class="font-serif text-foxplan-charcoal-brown leading-[1.1] mb-8 whitespace-normal"
                style="font-size: clamp(2.5rem, 6vw, 4.5rem);">
                {{ block.paragraphHeading2 ?? '' }}
            </h2>

            {% if block.bodyText is defined and block.bodyText %}
                <div class="leading-relaxed text-foxplan-charcoal-brown/90"
                     style="font-size: clamp(1rem, 1vw + 0.5rem, 1.125rem);">
                    {{ block.bodyText | raw }}
                </div>
            {% endif %}
        </div>

        {# Right Column: Matrix Grid #}
        <div class="lg:col-span-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8 md:gap-y-[clamp(2rem,4vh,4rem)]">

                {% if block.accountingMatrix is defined %}
                    {% for item in block.accountingMatrix.all() %}
                        <div class="flex flex-col">
                            <h3 class="font-serif text-foxplan-charcoal-brown mb-3"
                                style="font-size: clamp(1.5rem, 3vw, 2rem);">
                                {{ item.mainHeading ?? '' }}
                            </h3>

                            <div class="leading-snug text-foxplan-charcoal-brown/80"
                                 style="font-size: clamp(0.9rem, 0.5vw + 0.5rem, 1rem);">
                                {{ item.bodyText | raw }}
                            </div>
                        </div>
                    {% endfor %}
                {% endif %}

            </div>
        </div>

    </div>
</section>