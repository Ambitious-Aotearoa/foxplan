{# templates/_sections/content-sections/accounting-pathways.twig #}

<section class="relative w-full bg-foxplan-neutral-beige py-[clamp(3rem,10vh,8rem)] px-4 md:px-6 lg:px-8 overflow-hidden
                after:content-[''] after:absolute after:bottom-0
                after:left-4 md:after:left-8 lg:after:left-12
                after:right-4 md:after:right-8 lg:after:right-12
                after:border-b after:border-foxplan-charcoal-brown">

    <div class="grid grid-cols-1 xl:grid-cols-12 gap-y-8 xl:gap-x-20 items-start">

        {# Left Column #}
        <div class="xl:col-span-4 w-full">
            {# Removed text-wrap: balance for mobile to ensure clean container calculation #}
            <h2 class="font-serif text-foxplan-charcoal-brown leading-[1] mb-6 md:text-wrap-balance"
                style="font-size: clamp(2.5rem, 6vw, 5rem);">
                {{ block.paragraphHeading2 ?? '' }}
            </h2>

            {% if block.bodyText is defined and block.bodyText %}
                <div class="leading-relaxed text-foxplan-charcoal-brown mb-4 xl:mb-0 w-full"
                     style="font-size: clamp(1rem, 1.2vw, 1.125rem);">
                    {{ block.bodyText | raw }}
                </div>
            {% endif %}
        </div>

        {# Right Column #}
        <div class="xl:col-span-8 w-full">

            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 lg:gap-x-20 gap-y-6 md:gap-y-8">

                {% set matrixItems = block.accountingMatrix.all() ?? [] %}

                {% if matrixItems is not empty %}
                    {% for item in matrixItems %}
                        <div class="flex flex-col w-full">
                            <h3 class="font-serif text-foxplan-charcoal-brown mb-3 leading-tight md:text-wrap-balance"
                                style="font-size: clamp(1.3rem, 2vw, 1.8rem);">
                                {{ item.mainHeading ?? '' }}
                            </h3>

                            {# Cleaned up the restrictive overflow/word-break logic to allow fluid wrapping #}
                            <div class="leading-relaxed text-foxplan-charcoal-brown opacity-90 w-full"
                                 style="font-size: clamp(0.95rem, 1vw, 1.05rem);
                                        word-wrap: break-word;
                                        overflow-wrap: break-word;">
                                {{ item.bodyText | raw }}
                            </div>
                        </div>
                    {% endfor %}
                {% endif %}

            </div>
        </div>
    </div>
</section>