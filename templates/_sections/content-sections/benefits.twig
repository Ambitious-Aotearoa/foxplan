{# templates/_sections/content-sections/benefits.twig #}
{% set data = {
    paragraphHeading: null,
    bodyText: null,
    items: [],
    backgroundColor: 'bg-foxplan-yellow',
    textColor: 'text-foxplan-charcoal-brown'
} | merge(props ?? {}) %}

{% set textBaseColor = data.textColor | replace('text-', '') %}

<section class="w-full {{ data.backgroundColor }} py-16 md:py-24 overflow-hidden relative"
         x-data="{
            yPos: 0,
            lineStart: 0,
            {# Dynamically calculate the starting point of the accordion on mobile #}
            updateMetrics() {
                if (window.innerWidth < 768 && this.$refs.accordionContainer) {
                    this.lineStart = this.$refs.accordionContainer.offsetTop;
                } else {
                    this.lineStart = 0;
                }
            },
            handleScroll() {
                this.updateMetrics();
                let container = this.$refs.lineContainer;
                if (!container) return;
                let rect = container.getBoundingClientRect();
                let windowH = window.innerHeight;
                let scrollProgress = (windowH / 2) - rect.top;
                let percentage = Math.max(0, Math.min(scrollProgress / rect.height, 1));
                this.yPos = percentage * rect.height;
            }
         }"
         x-init="updateMetrics(); handleScroll();"
         @scroll.window.passive="handleScroll()"
         @resize.window="updateMetrics()"
         x-ref="sectionWrapper">

    <div class="grid grid-cols-1 md:grid-cols-10 w-full items-start relative">

        {# --- LEFT SIDE: HEADING --- #}
        {# Standardized to px-4 for mobile alignment #}
        <div class="md:col-span-5 xl:col-span-3 px-4 md:px-8 lg:px-8 xl:pl-8 mb-12 md:mb-0">
            <h2 class="font-serif tracking-tight {{ data.textColor }} whitespace-normal"
                style="font-size: clamp(2.1rem, 10vw, 4.5rem);
                       line-height: 1.15 !important;
                       word-break: normal !important;
                       overflow-wrap: break-word !important;
                       text-wrap: balance;">
                {{ data.paragraphHeading | raw }}
            </h2>

            {% if data.bodyText and data.bodyText|trim is not empty %}
                <div class="font-aktiv opacity-90 max-w-xs mt-6 {{ data.textColor }} font-medium"
                     style="font-size: clamp(0.9rem, 0.4vw + 0.8rem, 1.1rem);
                            line-height: 1.5 !important;
                            word-break: normal !important;">
                    {{ data.bodyText | raw }}
                </div>
            {% endif %}
        </div>

        {# --- THE INTERACTIVE LINE --- #}
        <div class="flex absolute z-30 w-[2px] justify-center
            left-6 md:left-[48%] xl:left-[30%]
            bottom-0"
             x-ref="lineContainer"
                {# Binds the top position to the calculated lineStart on mobile #}
             :style="'top: ' + lineStart + 'px'">

            {# Background Dotted Line #}
            <div class="h-full w-full border-l-2 border-dashed border-foxplan-charcoal-brown opacity-20"></div>

            {# Progress Dotted Line (Active) #}
            <div id="progress-line"
                 class="absolute top-0 left-0 w-full border-l-2 border-dashed border-foxplan-charcoal-brown transition-all duration-75 ease-out"
                 :style="'height: ' + yPos + 'px'"></div>

            {# Scrolling Dot #}
            <div id="scrolling-dot"
                 class="absolute left-1/2 -translate-x-1/2 w-3 h-3 bg-foxplan-charcoal-brown rounded-full shadow-sm transition-opacity duration-300"
                 :class="yPos > 0 ? 'opacity-100' : 'opacity-0'"
                 :style="'transform: translate(-50%, -50%); top: ' + yPos + 'px'"></div>
        </div>

        {# --- RIGHT SIDE: ACCORDION CARDS --- #}
        <div class="col-span-1 md:col-span-5 xl:col-span-7 px-4 pl-12 md:pl-12 lg:pl-16 xl:pl-24 pr-8"
             x-ref="accordionContainer">
            <div class="flex flex-col space-y-6">
                {% for item in data.items %}
                    <div class="benefit-card group w-full transition-all duration-500 rounded-none"
                         x-data="{
                            isScrollActive: false,
                            checkActive() {
                                let rect = $el.getBoundingClientRect();
                                let lineRect = $refs.lineContainer.getBoundingClientRect();
                                let circleGlobalY = lineRect.top + yPos;
                                this.isScrollActive = (circleGlobalY >= rect.top && circleGlobalY <= rect.bottom);
                            }
                         }"
                         x-init="$watch('yPos', () => checkActive())"
                         :class="(isScrollActive) ? 'bg-white p-8 md:p-10 translate-x-2 md:translate-x-4 opacity-100 shadow-sm' : 'bg-transparent p-8 md:p-10 translate-x-0 opacity-40'">

                        {% if item.title %}
                            <h4 class="font-aktiv text-[10px] font-bold tracking-[0.2em] uppercase mb-4 text-foxplan-charcoal-brown/60">
                                {{ item.title }}
                            </h4>
                        {% endif %}

                        {% if item.text %}
                            <div class="font-serif text-foxplan-charcoal-brown"
                                 style="font-size: clamp(1.3rem, 2vw + 0.8rem, 2.25rem);
                                        line-height: 1.25 !important;
                                        word-break: normal !important;
                                        overflow-wrap: break-word !important;">
                                {{ item.text | raw }}
                            </div>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
</section>