{# templates/_sections/content-sections/benefits.twig #}
{% set data = {
    paragraphHeading: null,
    bodyText: null,
    items: [],
    backgroundColor: 'bg-foxplan-yellow',
    textColor: 'text-foxplan-charcoal-brown'
} | merge(props ?? {}) %}

{% set textBaseColor = data.textColor | replace('text-', '') %}

<section class="w-full {{ data.backgroundColor }} py-16 md:py-24 overflow-hidden relative"
         x-data="{
            yPos: 0,
            lineStart: 0,
            updateMetrics() {
                {# FIXED: Now treats screens < 1280px (xl) as the mobile-style layout #}
                if (window.innerWidth < 1280 && this.$refs.accordionContainer) {
                    this.lineStart = this.$refs.accordionContainer.offsetTop;
                } else {
                    this.lineStart = 0;
                }
            },
            handleScroll() {
                this.updateMetrics();
                let container = this.$refs.lineContainer;
                if (!container) return;
                let rect = container.getBoundingClientRect();
                let windowH = window.innerHeight;
                let scrollProgress = (windowH / 2) - rect.top;
                let percentage = Math.max(0, Math.min(scrollProgress / rect.height, 1));
                this.yPos = percentage * rect.height;
            }
         }"
         x-init="updateMetrics(); handleScroll();"
         @scroll.window.passive="handleScroll()"
         @resize.window="updateMetrics()"
         x-ref="sectionWrapper">

    <div class="grid grid-cols-1 xl:grid-cols-10 w-full items-start relative">

        {# --- LEFT SIDE: HEADING --- #}
        <div class="col-span-1 xl:col-span-3 px-4 md:px-8 xl:pl-8 mb-12 xl:mb-0">
            <h2 class="font-serif tracking-tight {{ data.textColor }} whitespace-normal leading-[0.9] md:leading-[0.95]"
                style="font-size: clamp(2.1rem, 10vw, 4.5rem);
           word-break: normal !important;
           overflow-wrap: break-word !important;
           text-wrap: pretty;">
                {{ data.paragraphHeading | raw }}
            </h2>

            {% if data.bodyText and data.bodyText|trim is not empty %}
                <div class="font-aktiv opacity-90 max-w-xs mt-6 {{ data.textColor }} font-medium"
                     style="font-size: clamp(0.9rem, 0.4vw + 0.8rem, 1.1rem);
                            line-height: 1.5 !important;
                            word-break: normal !important;">
                    {{ data.bodyText | raw }}
                </div>
            {% endif %}
        </div>

        {# --- THE INTERACTIVE LINE --- #}
        <div class="flex absolute z-30 w-[2px] justify-center
    left-6 xl:left-[30%]
    bottom-0"
             x-ref="lineContainer"
             :style="'top: ' + lineStart + 'px'">

            {# Background Dotted Line (The Track) #}
            <div class="h-full w-full border-l-2 border-dashed border-foxplan-charcoal-brown opacity-20"
                 :style="'clip-path: inset(' + yPos + 'px 0 0 0)'">
            </div>

            {# Progress Dotted Line (Active) #}
            <div id="progress-line"
                 class="absolute top-0 left-0 w-full border-l-2 border-dashed border-foxplan-charcoal-brown"
                 :style="'height: ' + yPos + 'px'">
            </div>

            {# Scrolling Dot (The Tip) #}
            <div id="scrolling-dot"
                 class="absolute left-1/2 -translate-x-1/2 w-3 h-3 bg-foxplan-charcoal-brown rounded-full shadow-sm"
                 :class="yPos > 0 ? 'opacity-100' : 'opacity-0'"
                 :style="'top: ' + (yPos - 6) + 'px; transition: opacity 300ms;'">
            </div>
        </div>

        {# --- RIGHT SIDE: ACCORDION CARDS --- #}

        <div class="col-span-1 xl:col-span-7 px-4 pl-12 md:pl-16 xl:pl-24 pr-8"
             x-ref="accordionContainer">
            <div class="flex flex-col space-y-6">
                {% for item in data.items %}
                    <div class="benefit-card group w-full transition-all duration-500 rounded-none"
                         x-data="{
                    isScrollActive: false,
                    checkActive() {
                        let rect = $el.getBoundingClientRect();
                        let lineRect = $refs.lineContainer.getBoundingClientRect();
                        let circleGlobalY = lineRect.top + yPos;
                        this.isScrollActive = (circleGlobalY >= rect.top && circleGlobalY <= rect.bottom);
                    }
                 }"
                         x-init="$watch('yPos', () => checkActive())"
                         :class="(isScrollActive) ? 'bg-foxplan-white p-8 md:p-10 translate-x-2 md:translate-x-4 opacity-100 shadow-sm' : 'bg-transparent p-8 md:p-10 translate-x-0 opacity-40'">

                        {% if item.title %}
                            <h4 class="font-aktiv font-bold tracking-[0.95] uppercase mb-4 text-foxplan-charcoal-brown/60"
                                style="font-weight: 400; font-size: clamp(0.625rem, 1vw, 0.75rem);">
                                {{ item.title }}
                            </h4>
                        {% endif %}

                        {% if item.text %}
                            <div class="font-serif text-foxplan-charcoal-brown benefit-text-content"
                                 style="font-size: clamp(1.3rem, 2vw + 0.8rem, 2.25rem);
                line-height: 1 !important;
                word-break: normal !important;
                overflow-wrap: break-word !important;">
                                {{ item.text | raw }}
                            </div>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
</section>

<style>
    .benefit-text-content ul {
        list-style: none !important;
        padding: 0 !important;
        margin: 0 !important;
    }

    .benefit-text-content li {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        margin-bottom: 0.5rem;
    }

    .benefit-text-content li::before {
        content: "•";
        color: currentColor;
        font-weight: bold;
        flex-shrink: 0;
    }
</style>