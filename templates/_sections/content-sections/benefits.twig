{# templates/_sections/content-sections/benefits.twig #}
{% set data = {
    paragraphHeading: null,
    bodyText: null,
    items: [],
    backgroundColor: 'bg-foxplan-yellow',
    textColor: 'text-foxplan-charcoal-brown'
} | merge(props ?? {}) %}

{% set textBaseColor = data.textColor | replace('text-', '') %}

<section class="w-full {{ data.backgroundColor }} py-20 overflow-hidden relative"
         x-data="{
            yPos: 0,
            handleScroll() {
                let container = this.$refs.lineContainer;
                if (!container) return;

                let rect = container.getBoundingClientRect();
                let windowH = window.innerHeight;

                {# Progress logic: Trigger based on viewport center #}
                let scrollProgress = (windowH / 2) - rect.top;
                let percentage = Math.max(0, Math.min(scrollProgress / rect.height, 1));

                this.yPos = percentage * rect.height;
            }
         }"
         x-init="handleScroll()"
         @scroll.window.passive="handleScroll()"
         x-ref="sectionWrapper">

    <div class="grid grid-cols-1 md:grid-cols-10 w-full items-start relative">

        {# --- LEFT SIDE: HEADING --- #}
        <div class="md:col-span-3 px-6 md:px-6 lg:px-8 md:pl-12 lg:pl-16 mb-12 md:mb-0">
            <h2 class="font-serif tracking-tight {{ data.textColor }} break-normal"
                style="font-size: clamp(2.25rem, 4vw + 1rem, 4.5rem); line-height: 0.85; word-break: keep-all;">
                {{ data.paragraphHeading | raw }}
            </h2>

            {% if data.bodyText and data.bodyText|trim is not empty %}
                <div class="font-aktiv opacity-90 max-w-xs mt-6 {{ data.textColor }} font-medium"
                     style="font-size: clamp(0.9rem, 0.4vw + 0.8rem, 1.1rem); line-height: 1.4;">
                    {{ data.bodyText | raw }}
                </div>
            {% endif %}
        </div>

        {# --- THE INTERACTIVE LINE: Restored Mobile Placement --- #}
        <div class="flex absolute z-30 w-[2px] justify-center
                    left-8 md:left-[30%]
                    top-[180px] md:top-0
                    bottom-0"
             x-ref="lineContainer">

            {# Static Track (Synced with Grow) #}
            <div class="h-full w-full border-l-2 border-dashed border-{{ textBaseColor }}/10"></div>

            {# Active Progress (Synced with Grow) #}
            <div class="absolute top-0 left-0 w-full border-l-2 border-dashed border-{{ textBaseColor }} transition-all duration-75 ease-out"
                 :style="'height: ' + yPos + 'px'"></div>

            {# Scrolling Dot (Synced with Grow) #}
            <div class="absolute left-1/2 -translate-x-1/2 w-3 h-3 bg-{{ textBaseColor }} rounded-full transition-opacity duration-300"
                 :class="yPos > 0 ? 'opacity-100' : 'opacity-0'"
                 :style="'transform: translate(-50%, -50%); top: ' + yPos + 'px'"></div>
        </div>

        {# --- RIGHT SIDE: ACCORDION CARDS --- #}
        <div class="col-span-1 md:col-span-7 px-4 pl-16 md:px-6 lg:px-8 md:pl-20 pr-[20px]">
            <div class="flex flex-col space-y-6">
                {% for item in data.items %}
                    <div class="benefit-card group w-full transition-all duration-500 rounded-none"
                         x-data="{
                            isScrollActive: false,
                            checkActive() {
                                let rect = $el.getBoundingClientRect();
                                let lineRect = $refs.lineContainer.getBoundingClientRect();

                                {# Circle position relative to the card bounds #}
                                let circleGlobalY = lineRect.top + yPos;

                                this.isScrollActive = (circleGlobalY >= rect.top && circleGlobalY <= rect.bottom);
                            }
                         }"
                         x-init="$watch('yPos', () => checkActive())"
                         :class="(isScrollActive) ? 'bg-foxplan-white p-8 md:p-10 translate-x-2 md:translate-x-4 opacity-100' : 'bg-transparent p-8 md:p-10 translate-x-0  opacity-40'">

                        {% if item.title %}
                            <h4 class="font-aktiv text-[10px] font-bold tracking-[0.2em] uppercase mb-3 text-foxplan-charcoal-brown">
                                {{ item.title }}
                            </h4>
                        {% endif %}

                        {% if item.text %}
                            <div class="font-serif text-foxplan-charcoal-brown"
                                 style="font-size: clamp(1.2rem, 2vw + 0.8rem, 2rem); line-height: 1.25;">
                                {{ item.text | raw }}
                            </div>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
</section>