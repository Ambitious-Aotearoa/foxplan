{# templates/_sections/content-sections/kiwisaver-image-text.twig #}

{% set sourceEntry = entry ?? craft.entries.section('accounting').one() %}

{% set heroImage = sourceEntry.heroImage2.one() ?? null %}

{% set defaults = {
    heroBodyText: sourceEntry.heroBodyText2 ?? '',
    bodyText: sourceEntry.bodyText4 ?? '',
    textColor: 'text-foxplan-charcoal-brown',
    stripColor: 'bg-foxplan-charcoal-brown',
    panelBgColor: '#84B8D8'
} %}

{% set data = defaults | merge(props ?? {}) %}

<section class="w-full relative z-20 overflow-hidden">
    {% if heroImage %}
        <div class="relative w-full pl-4 md:pl-6 lg:pl-8 {{ data.stripColor }}">

            {# --- Hero Image --- #}
            <div class="w-full aspect-[4/3] md:aspect-[21/9] lg:aspect-[2.3/1]">
                <img src="{{ heroImage.url }}"
                     alt="{{ heroImage.alt ?? 'Hero Image' }}"
                     class="w-full h-full object-cover block">
            </div>

            {# --- Text panel  --- #}

            <div class="static md:absolute md:bottom-0 md:right-0 w-full md:w-[700px]
            flex flex-col items-start gap-10 md:gap-[70px] py-10 md:py-12 px-5"
                 style="background-color: {{ data.panelBgColor }};">
                {% if data.heroBodyText %}
                    <h2 class="font-serif tracking-tight {{ data.textColor }} leading-[0.95]"
                        style="font-size: clamp(1.75rem, 3vw + 1rem, 3.25rem);">
                        {{ data.heroBodyText | raw }}
                    </h2>
                {% endif %}

                {% if data.bodyText %}
                    <div class="font-aktiv {{ data.textColor }} leading-relaxed"
                         style="font-size: clamp(0.85rem, 0.6vw + 0.6rem, 0.95rem);">
                        {{ data.bodyText | replace({'<p>': '', '</p>': ''}) | raw }}
                    </div>
                {% endif %}
            </div>
        </div>
    {% endif %}
</section>