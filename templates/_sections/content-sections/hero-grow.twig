{# 1. FETCH ASSETS FROM CRAFT #}
{% set section1Image = entry.image.one() %}
{% set section2Image = entry.image2.one() %}

{# Fallbacks #}
{% set fallback1 = alias('@web/dist/images/About_1.jpg') %}
{% set fallback2 = alias('@web/dist/images/About_2.jpg') %}

<section class="w-full relative overflow-hidden bg-foxplan-neutral-beige pb-0" id="scroll-container">

    {# --- THE DOTTED LINE --- #}
    <div class="hidden md:block absolute left-1/2 -translate-x-1/2 top-0 bottom-0 w-[2px] z-10 pointer-events-none">
        <div class="absolute inset-0 border-l-2 border-dashed border-foxplan-charcoal-brown/10"></div>
        <div id="progress-line"
             class="absolute inset-0 border-l-2 border-dashed border-foxplan-charcoal-brown"
             style="clip-path: inset(0 0 100% 0);"></div>
        <div id="scrolling-dot"
             class="absolute left-0 -translate-x-[45%] w-3 h-3 bg-foxplan-charcoal-brown rounded-full opacity-0 shadow-sm"
             style="top: 0px; transition: opacity 300ms;">
        </div>
    </div>

    <div class="flex flex-col md:grid md:grid-cols-12 w-full relative">

        {# --- LEFT COLUMN stack --- #}
        <div class="contents md:flex md:col-span-6 lg:col-span-5 flex-col justify-between">

            {# BLOCK A: Section 1 Text #}
            <div class="order-1 md:order-none pt-12 md:pt-24 lg:pt-32 px-4 md:pl-6 lg:pl-8 md:pr-12">
                <div class="max-w-md">
                    <h2 class="font-serif leading-[1.1] tracking-tight mb-6 text-foxplan-charcoal-brown"
                        style="font-size: clamp(2.5rem, 4vw, 4rem);">
                        {{ entry.paragraphHeading4 | raw }}
                    </h2>
                    <p class="font-aktiv text-foxplan-charcoal-brown mb-8 leading-relaxed opacity-90" style="font-size: 1.05rem;">
                        {{ entry.bodyText3 | striptags }}
                    </p>
                    {% if entry.button2 is not empty %}
                        <div class="mb-12">
                            {% include '_components/ui/button/button.twig' with {
                                props: {
                                    text: entry.button2,
                                    url: '/financial-planning',
                                    style: 'primary',
                                    backgroundColor: 'bg-foxplan-charcoal-brown',
                                    textColor: 'text-foxplan-neutral-beige',
                                }
                            } only %}
                        </div>
                    {% endif %}
                </div>
            </div>

            {# BLOCK B: Section 2 Image #}
            <div class="order-4 md:order-none px-6 md:pl-0 mt-12 md:mt-0 lg:max-w-[100%] leading-[0]">
                <img src="{{ section2Image ? section2Image.url : fallback2 }}"
                     class="w-full md:max-w-none mx-auto md:mx-0 mb-12 md:mb-0 aspect-[4/5] object-cover shadow-sm block">
            </div>
        </div>

        {# --- CENTER GAP --- #}
        <div class="hidden lg:block lg:col-span-2"></div>

        {# --- RIGHT COLUMN stack --- #}
        <div class="contents md:flex md:col-span-6 lg:col-span-5 flex-col justify-between">

            {# BLOCK C: Section 1 Image #}
            <div class="order-2 md:order-none px-4 md:pr-0 md:pl-8 pt-12 md:pt-24 lg:pt-32 max-w-[100%]">
                <img src="{{ section1Image ? section1Image.url : fallback1 }}"
                     class="w-full  md:max-w-none mx-auto md:mx-0 mb-12 md:mb-0 aspect-[4/5] object-cover shadow-sm">
            </div>

            {# BLOCK D: Section 2 Text #}
            <div class="order-3 md:order-none px-6 md:pr-12 lg:pr-24  pt-12 md:pt-24 lg:pt-40">
                <div class="max-w-md">
                    <h2 class="font-serif leading-[1.1] text-foxplan-charcoal-brown mb-6"
                        style="font-size: clamp(2.5rem, 4vw, 4rem);">
                        {{ entry.paragraphHeading5 | raw }}
                    </h2>
                    <p class="font-aktiv text-foxplan-charcoal-brown mb-12 leading-relaxed opacity-90" style="font-size: 1.05rem;">
                        {{ entry.bodyText4 | striptags }}
                    </p>
                    {% if entry.button3 is not empty %}
                        <div class="pb-16 md:pb-24 lg:pb-32">
                            {% include '_components/ui/button/button.twig' with {
                                props: {
                                    text: entry.button3,
                                    url: '/dollars-and-sense-podcast',
                                    style: 'primary',
                                    backgroundColor: 'bg-foxplan-charcoal-brown',
                                    textColor: 'text-foxplan-neutral-beige',
                                }
                            } only %}
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const dot = document.getElementById('scrolling-dot');
        const progressLine = document.getElementById('progress-line');
        const timelineWrapper = dot ? dot.parentElement : null;

        function updateTimeline() {
            if (!timelineWrapper || getComputedStyle(timelineWrapper).display === 'none') return;

            const rect = timelineWrapper.getBoundingClientRect();
            const viewHeight = window.innerHeight;

            let progress = (viewHeight / 2 - rect.top) / rect.height;
            progress = Math.max(0, Math.min(1, progress));

            dot.style.opacity = (progress > 0.01) ? "1" : "0";

            const percentage = progress * 100;
            dot.style.top = `${percentage}%`;
            progressLine.style.clipPath = `inset(0 0 ${100 - percentage}% 0)`;
        }

        window.addEventListener('scroll', updateTimeline, { passive: true });
        window.addEventListener('resize', updateTimeline);
        updateTimeline();
    });
</script>