{# _sections/content-sections/career-grow.twig #}

<section class="w-full relative overflow-hidden bg-foxplan-neutral-beige" id="career-scroll-container">

    {# --- HEADER SECTION --- #}
    <div class="w-full py-8 md:py-16 lg:py-24 text-center px-4 relative z-20">
        <h2 class="font-serif tracking-tight text-foxplan-charcoal-brown mb-6 max-w-4xl mx-auto break-normal"
            style="font-size: clamp(2.5rem, 6vw + 1rem, 6.5rem); line-height: 0.95; word-break: keep-all;">
            {{ entry.paragraphHeading2 | raw }}
        </h2>

        <div class="font-aktiv text-foxplan-charcoal-brown/70 max-w-2xl mx-auto font-medium"
             style="font-size: clamp(1rem, 0.5vw + 0.8rem, 1.25rem);">
            {{ entry.bodyText2 | raw }}
        </div>
    </div>

    {% set careerSections = [
        {
            prehead: entry.paragraphHeading3,
            title: entry.mainTitle,
            matrix: entry.shortTermMatrix.all(),
            asset: entry.image.one()
        },
        {
            prehead: entry.paragraphHeading4,
            title: entry.mainTitle2,
            matrix: entry.mediumTermMatrix.all(),
            asset: entry.image2.one()
        },
        {
            prehead: entry.paragraphHeading5,
            title: entry.mainTitle3,
            matrix: entry.longTermMatrix.all(),
            asset: entry.image3.one()
        }
    ] %}

    <div id="career-content-wrapper" class="relative">

        {# --- THE RAIL --- #}
        <div class="hidden md:block absolute left-1/2 -translate-x-1/2 top-0 bottom-0 w-[2px] z-50 pointer-events-none" id="timeline-rail">
            <div class="h-full w-full border-l-2 border-dashed border-foxplan-charcoal-brown/10"></div>

            <div id="career-progress-line"
                 class="absolute top-0 left-0 w-full border-l-2 border-dashed border-foxplan-charcoal-brown"
                 style="height: 0px;"></div>

            <div id="career-scrolling-dot"
                 class="absolute left-1/2 -translate-x-1/2 w-3 h-3 bg-foxplan-charcoal-brown rounded-full opacity-0"
                 style="top: 0px; transition: opacity 300ms;">
            </div>
        </div>

        {% for section in careerSections %}
            {% set imageOnLeft = loop.index is odd %}

            <div class="relative w-full pb-10 md:py-20 lg:py-32 career-block">
                <div class="grid grid-cols-1 md:grid-cols-10 w-full items-start gap-y-12">

                    {# Image Side #}
                    <div class="col-span-1 md:col-span-4 {{ imageOnLeft ? 'md:col-start-1' : 'md:col-start-7 md:order-2' }} px-4 md:px-0 lg:px-0">
                        <div class="w-full relative ">
                            {% if section.asset %}
                                <img src="{{ section.asset.url }}"
                                     class="w-full h-[500px] lg:h-[700px] object-cover block"
                                     alt="{{ section.title }}">
                            {% else %}
                                <img src="{{ alias('@web/dist/images/career_' ~ loop.index ~ '.jpg') }}"
                                     class="w-full h-[500px] lg:h-[700px] object-cover block"
                                     alt="Career Phase {{ loop.index }}">
                            {% endif %}
                        </div>
                    </div>

                    {# Text Side #}
                    <div class="col-span-1 md:col-span-4 pt-2 {{ imageOnLeft ? 'md:col-start-7 px-4 md:px-0 md:pr-12 lg:pr-24' : 'md:col-start-1 px-4 md:pl-12 lg:pl-16 md:order-1' }}">
                        <div class="max-w-xl">
                            <span class="text-xs font-bold uppercase tracking-widest text-foxplan-charcoal-brown/50 mb-4 block">
                                {{ section.prehead }}
                            </span>

                            <h3 class="font-serif tracking-tight text-foxplan-charcoal-brown mb-10 break-normal"
                                style="font-size: clamp(2rem, 4vw + 1rem, 3.5rem); line-height: 0.95; word-break: keep-all;">
                                {{ section.title }}
                            </h3>

                            <div class="space-y-8">
                                {% for benefit in section.matrix %}
                                    <div class="benefit-item transition-all duration-700 ease-out text-foxplan-charcoal-brown/20 translate-x-0">
                                        <h4 class="font-serif mb-1 text-inherit"
                                            style="font-size: clamp(1.25rem, 1vw + 1rem, 1.5rem); line-height: 0.95;">
                                            {{ benefit.matrixTitle }}
                                        </h4>

                                        <div class="font-aktiv leading-relaxed text-inherit font-medium"
                                             style="font-size: clamp(0.9rem, 0.4vw + 0.8rem, 1rem);">
                                            {{ benefit.bodyText | raw }}
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
</section>

<script>
    window.addEventListener('load', function() {
        const contentWrapper = document.getElementById('career-content-wrapper');
        const dot = document.getElementById('career-scrolling-dot');
        const progressLine = document.getElementById('career-progress-line');

        function updateTimeline() {
            if (!contentWrapper || !dot || !progressLine) return;

            const rect = contentWrapper.getBoundingClientRect();
            const viewHeight = window.innerHeight;

            // Math Fix: Calculate progress relative to the center of the screen
            let scrollProgress = (viewHeight / 2 - rect.top) / rect.height;

            // Visibility: Only show if within the wrapper boundaries
            if (scrollProgress >= 0 && scrollProgress <= 1) {
                dot.style.opacity = "1";
            } else {
                dot.style.opacity = "0";
            }

            // Clamp and apply percentage
            scrollProgress = Math.max(0, Math.min(1, scrollProgress));
            const percentage = scrollProgress * 100;

            dot.style.top = percentage + '%';
            progressLine.style.height = percentage + '%';
        }

        // --- Intersection Observer  ---
        const observerOptions = {
            root: null,
            rootMargin: '0px 0px -25% 0px',
            threshold: 0.1
        };

        const highlightObserver = new IntersectionObserver((entries, observer) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.remove('text-foxplan-charcoal-brown/20');
                    entry.target.classList.add('text-foxplan-charcoal-brown');
                    observer.unobserve(entry.target);
                }
            });
        }, observerOptions);

        document.querySelectorAll('.benefit-item').forEach(item => {
            highlightObserver.observe(item);
        });

        window.addEventListener('scroll', updateTimeline);
        window.addEventListener('resize', updateTimeline);
        updateTimeline();
    });
</script>