{# templates/_sections/about-grow.twig #}

<section class="w-full relative overflow-hidden" id="scroll-container">

    {# --- THE DOTTED LINE --- #}
    <div class="absolute left-1/2 -translate-x-1/2 top-[500px] bottom-[200px] md:top-0 md:bottom-0 md:h-full w-[2px] z-10 pointer-events-none">
        <div class="h-full w-full border-l-2 border-dashed border-foxplan-charcoal-brown/10"></div>

        <div id="progress-line"
             class="absolute top-0 left-0 w-full border-l-2 border-dashed border-foxplan-charcoal-brown"
             style="height: 0px;"></div>

        <div id="scrolling-dot"
             class="absolute left-1/2 -translate-x-1/2 w-3 h-3 bg-foxplan-charcoal-brown rounded-full opacity-0"
             style="top: 0px; transition: opacity 300ms;">
        </div>
    </div>

    {# --- SECTION 1: Yellow --- #}
    <div class="bg-foxplan-yellow pt-6 md:pt-12 lg:pt-24 pb-20 md:pb-12 relative">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-10 md:gap-20 lg:gap-0 w-full items-start relative">
            <div class="col-span-1 md:col-span-1 lg:col-start-7 lg:col-span-4 order-1 md:order-2 relative z-20 bg-foxplan-yellow md:bg-transparent">
                <div class="w-full px-4 md:px-0 mb-8 md:mb-0 lg:-mb-72 xl:-mb-96">
                    <img src="{{ alias('@web/dist/images/About_1.jpg') }}"
                         class="w-full aspect-[370/362] md:aspect-[4/5] lg:aspect-[4/5] object-cover ">
                </div>
            </div>
            <div class="col-span-1 md:col-span-1 lg:col-span-6 px-4 md:px-6 lg:px-8 order-2 md:order-1 relative z-20 bg-foxplan-yellow md:bg-transparent">
                <div class="max-w-2xl pb-12 md:py-12 lg:py-0">
                    <h2 class="font-serif text-4xl md:text-5xl lg:text-[5rem] leading-[1.1] md:leading-[0.9] tracking-tight mb-8 text-foxplan-charcoal-brown">
                        {{ entry.paragraphHeading | raw }}
                    </h2>
                    <div class="font-aktiv text-base md:text-xl lg:text-lg opacity-80 text-foxplan-charcoal-brown">
                        {{ entry.bodyText | raw }}
                    </div>
                </div>
            </div>
        </div>
    </div>


    {# --- SECTION 2: White --- #}
    <div class="bg-foxplan-white pt-20 md:pt-32 lg:pt-[250px] relative pb-20 md:pb-0">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-10 md:gap-20 lg:gap-0 w-full relative">
            <div class="col-span-1 md:col-span-1 lg:col-span-4 order-1 relative z-20 bg-foxplan-white md:bg-transparent">
                <div class="px-4 md:px-0 py-6 md:py-0">
                    <img src="{{ alias('@web/dist/images/About_2.jpg') }}"
                         class="w-full aspect-[370/362] md:aspect-[4/5] lg:aspect-[4/5] object-cover">
                </div>
            </div>
            <div class="col-span-1 md:col-span-1 lg:col-start-7 lg:col-span-4 px-4 md:px-0 md:pr-4 lg:pr-12  order-2 relative z-20 bg-foxplan-white md:bg-transparent">
                <div class="md:py-12 lg:mt-[200px] lg:pb-32">
                    <h2 class="font-serif text-4xl md:text-5xl lg:text-[4.5rem] leading-[1.1] md:leading-[0.9] text-foxplan-charcoal-brown mb-8">
                        {{ entry.paragraphHeading2 | raw }}
                    </h2>
                    <div class="font-aktiv text-base md:text-xl lg:text-lg text-foxplan-charcoal-brown/80">
                        {{ entry.bodyText2 | raw }}
                    </div>
                </div>
            </div>
        </div>
    </div>


    {# --- SECTION 3:  Beige --- #}
    <div class="bg-foxplan-neutral-beige relative pt-20 md:pt-12 lg:pt-0 pb-20 md:pb-0">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-10 md:gap-20 lg:gap-0 w-full items-center relative">
            <div class="col-span-1 md:col-span-1 lg:col-span-4 order-1 md:order-2 relative z-20 bg-foxplan-neutral-beige md:bg-transparent">
                <div class="w-full h-full md:pb-0 lg:py-8 lg:pr-12 px-4 md:px-0 py-6 md:py-0">
                    <img src="{{ alias('@web/dist/images/About_3.jpg') }}"
                         class="w-full aspect-[370/362] md:aspect-[4/5] lg:aspect-[4/5] object-cover">
                </div>
            </div>
            <div class="col-span-1 md:col-span-1 lg:col-span-6 px-4 md:px-8 lg:pl-16 lg:py-8 order-2 md:order-1 relative z-20 bg-foxplan-neutral-beige md:bg-transparent">
                <div class="max-w-xl pb-8 md:py-12 lg:py-0">
                    <h2 class="font-serif text-4xl md:text-5xl lg:text-[4.5rem] leading-[1.1] md:leading-[0.9] text-foxplan-charcoal-brown mb-8">
                        {{ entry.paragraphHeading3 | raw }}
                    </h2>
                    <div class="font-aktiv text-base md:text-xl lg:text-lg text-foxplan-charcoal-brown/80">
                        {{ entry.bodyText3 | raw }}
                    </div>
                </div>
            </div>
        </div>
    </div>


    {# --- SECTION 4: White --- #}
    <div class="bg-foxplan-white relative pt-20 pb-24 lg:pb-0">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-10 md:gap-20 lg:gap-0 w-full relative">
            <div class="col-span-1 md:col-span-1 lg:col-span-4 order-1 relative z-20 bg-foxplan-white md:bg-transparent">
                <div class="px-4 md:px-0 py-6 md:py-0">
                    <img src="{{ alias('@web/dist/images/About_4.jpg') }}"
                         class="w-full aspect-[370/362] md:aspect-[4/5] lg:aspect-[4/5] object-cover">
                </div>
            </div>
            <div class="col-span-1 md:col-span-1 lg:col-start-7 lg:col-span-4 px-4 md:px-0 md:pr-4 lg:pr-12  order-2 relative z-20 bg-foxplan-white md:bg-transparent">
                <div class="md:py-12 lg:mt-[200px] lg:pb-32">
                    <h2 class="font-serif text-4xl md:text-5xl lg:text-[4.5rem] leading-[1.1] md:leading-[0.9] text-foxplan-charcoal-brown mb-8">
                        {{ entry.paragraphHeading4 | raw }}
                    </h2>
                    <div class="font-aktiv text-base md:text-xl lg:text-lg text-foxplan-charcoal-brown/80">
                        {{ entry.bodyText4 | raw }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const dot = document.getElementById('scrolling-dot');
        const progressLine = document.getElementById('progress-line');
        const timelineWrapper = dot.parentElement;

        function updateTimeline() {
            const timelineRect = timelineWrapper.getBoundingClientRect();
            const viewHeight = window.innerHeight;
            let scrollProgress = (viewHeight / 2 - timelineRect.top) / timelineRect.height;

            if (scrollProgress > 0 && scrollProgress < 1.0) {
                dot.style.opacity = "1";
            } else {
                dot.style.opacity = "0";
            }

            scrollProgress = Math.max(0, Math.min(1, scrollProgress));
            const percentage = scrollProgress * 100;
            dot.style.top = percentage + '%';
            progressLine.style.height = percentage + '%';
        }

        window.addEventListener('scroll', updateTimeline);
        window.addEventListener('resize', updateTimeline);
        updateTimeline();
    });
</script>