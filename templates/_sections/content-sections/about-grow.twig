{# templates/_sections/about-grow.twig #}

<section class="relative w-full overflow-hidden" id="about-grow-timeline">

    {# --- THE DOTTED LINE --- #}
    <div class="absolute left-1/2 -translate-x-1/2 top-[500px] bottom-[200px] md:top-0 md:bottom-0 md:h-full w-[2px] z-10 pointer-events-none">
        {# 1. The Background Track (Grey) #}
        <div class="absolute inset-0 border-l-2 border-dashed border-foxplan-charcoal-brown/10"></div>

        {# 2. The Active Progress Line (Charcoal) #}
        <div id="progress-line"
             class="absolute inset-0 border-l-2 border-dashed border-foxplan-charcoal-brown"
             style="clip-path: inset(0 0 100% 0);"></div>

        {# 3. Scrolling Dot #}
        <div id="scrolling-dot"
             class="absolute left-0 -translate-x-[40%] w-3 h-3 bg-foxplan-charcoal-brown rounded-full opacity-0 shadow-sm"
             style="top: 0px; transition: opacity 300ms;">
        </div>
    </div>

    {# --- SECTION 1: Yellow --- #}
    <div class="bg-foxplan-yellow py-20 md:py-32 lg:py-40">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-10 items-start relative">
            {# Image Right #}
            <div class="col-span-1 lg:col-start-7 lg:col-span-4 order-1 md:order-2 relative z-20 bg-foxplan-yellow md:bg-transparent">
                <div class="w-full px-4 md:px-0 md:pl-12 aspect-[4/5] overflow-hidden">
                    <img src="{{ alias('@web/dist/images/About_1.jpg') }}" class="w-full h-full object-cover">
                </div>
            </div>
            {# Text Left #}
            <div class="col-span-1 lg:col-span-4 lg:col-start-1 order-2 md:order-1 relative z-20 bg-foxplan-yellow md:bg-transparent">
                <div class="px-4 md:px-0 md:pl-12 lg:pl-16 pt-12 md:pt-0">
                    <h2 class="font-serif text-foxplan-charcoal-brown mb-8 tracking-tight"
                        style="font-size: clamp(2.5rem, 6vw, 4.5rem); line-height: 1; text-wrap: balance;">
                        {{ entry.paragraphHeading | raw }}
                    </h2>
                    <div class="font-aktiv font-light text-foxplan-charcoal-brown leading-relaxed max-w-lg md:max-w-sm lg:max-w-md pr-20"
                         style="font-size: clamp(1.125rem, 1.25vw, 1.25rem);">
                        {{ entry.bodyText | raw }}
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# --- SECTION 2: White --- #}
    <div class="bg-foxplan-white py-20 md:py-32 lg:py-40">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-10 items-start relative">
            {# Image Left #}
            <div class="col-span-1 lg:col-span-4 order-1 relative z-20 bg-foxplan-white md:bg-transparent">
                <div class="w-full px-4 md:px-0 md:pr-12 aspect-[4/5] overflow-hidden">
                    <img src="{{ alias('@web/dist/images/About_2.jpg') }}" class="w-full h-full object-cover">
                </div>
            </div>
            {# Text Right #}
            <div class="col-span-1 lg:col-start-7 lg:col-span-4 order-2 relative z-20 bg-foxplan-white md:bg-transparent">
                <div class="px-4 md:px-0 md:pl-12 lg:pr-16 pt-12 md:pt-24 lg:pt-32">
                    <h2 class="font-serif text-foxplan-charcoal-brown mb-8 tracking-tight"
                        style="font-size: clamp(2.5rem, 6vw, 4.375rem); line-height: 1.05; text-wrap: balance;">
                        {{ entry.paragraphHeading2 | raw }}
                    </h2>
                    <div class="font-aktiv font-light text-foxplan-charcoal-brown/80 leading-relaxed max-w-md"
                         style="font-size: clamp(1.125rem, 1.25vw, 1.25rem);">
                        {{ entry.bodyText2 | raw }}
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# --- SECTION 3: Beige --- #}
    <div class="bg-foxplan-neutral-beige py-20 md:py-32 lg:py-40">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-10 items-start relative">
            {# Image Right #}
            <div class="col-span-1 lg:col-start-7 lg:col-span-4 order-1 md:order-2 relative z-20 bg-foxplan-neutral-beige md:bg-transparent">
                <div class="w-full px-4 md:px-0 md:pl-12 aspect-[4/5] overflow-hidden">
                    <img src="{{ alias('@web/dist/images/About_3.jpg') }}" class="w-full h-full object-cover">
                </div>
            </div>
            {# Text Left #}
            <div class="col-span-1 lg:col-span-4 lg:col-start-1 order-2 md:order-1 relative z-20 bg-foxplan-neutral-beige md:bg-transparent">
                <div class="px-4 md:px-0 md:pl-12 lg:pl-16 pt-12 md:pt-0">
                    <h2 class="font-serif text-foxplan-charcoal-brown mb-8 tracking-tight"
                        style="font-size: clamp(2.5rem, 6vw, 4.375rem); line-height: 1.05; text-wrap: balance;">
                        {{ entry.paragraphHeading3 | raw }}
                    </h2>
                    <div class="font-aktiv font-light text-foxplan-charcoal-brown/80 leading-relaxed max-w-lg md:max-w-sm lg:max-w-md pr-20"
                         style="font-size: clamp(1.125rem, 1.25vw, 1.25rem);">
                        {{ entry.bodyText3 | raw }}
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# --- SECTION 4: White --- #}
    <div class="bg-foxplan-white py-20 md:py-32 lg:py-40">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-10 items-start relative">
            {# Image Left #}
            <div class="col-span-1 lg:col-span-4 order-1 relative z-20 bg-foxplan-white md:bg-transparent">
                <div class="w-full px-4 md:px-0 md:pr-12 aspect-[4/5] overflow-hidden">
                    <img src="{{ alias('@web/dist/images/About_4.jpg') }}" class="w-full h-full object-cover">
                </div>
            </div>
            {# Text Right #}
            <div class="col-span-1 lg:col-start-7 lg:col-span-4 order-2 relative z-20 bg-foxplan-white md:bg-transparent">
                <div class="px-4 md:px-0 md:pl-12 lg:pr-16 pt-12 md:pt-24 lg:pt-32">
                    <h2 class="font-serif text-foxplan-charcoal-brown mb-8 tracking-tight"
                        style="font-size: clamp(2.5rem, 6vw, 4.375rem); line-height: 1.05; text-wrap: balance;">
                        {{ entry.paragraphHeading4 | raw }}
                    </h2>
                    <div class="font-aktiv font-light text-foxplan-charcoal-brown/80 leading-relaxed max-w-md"
                         style="font-size: clamp(1.125rem, 1.25vw, 1.25rem);">
                        {{ entry.bodyText4 | raw }}
                    </div>
                </div>
            </div>
        </div>
    </div>

</section>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const dot = document.getElementById('scrolling-dot');
        const progressLine = document.getElementById('progress-line');
        const timelineWrapper = dot ? dot.parentElement : null;

        function updateTimeline() {
            if (!timelineWrapper) return;
            const timelineRect = timelineWrapper.getBoundingClientRect();
            const viewHeight = window.innerHeight;

            // Calculate progress (0 to 1) based on center of screen
            let scrollProgress = (viewHeight / 2 - timelineRect.top) / timelineRect.height;
            scrollProgress = Math.max(0, Math.min(1, scrollProgress));

            // Toggle Dot Opacity
            dot.style.opacity = (scrollProgress > 0 && scrollProgress < 0.99) ? "1" : "0";

            const percentage = scrollProgress * 100;

            // Move the dot and reveal the charcoal line
            dot.style.top = `calc(${percentage}% - 6px)`;
            progressLine.style.clipPath = `inset(0 0 ${100 - percentage}% 0)`;
        }

        window.addEventListener('scroll', updateTimeline);
        window.addEventListener('resize', updateTimeline);
        updateTimeline();
    });
</script>