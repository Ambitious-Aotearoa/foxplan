{# templates/_sections/info-block.twig #}

{% set defaults = {
    paragraphHeading: null,
    infoBlock: [],
    backgroundColor: 'bg-foxplan-neutral-beige',
    textColor: 'text-foxplan-charcoal-brown',
} %}



{% set data = defaults | merge(props ?? {}) %}

<section class="w-full relative z-20 {{ data.backgroundColor }} overflow-hidden">

    <div class="w-full px-4 md:px-6 lg:px-8">


        <div class="flex flex-col md:flex-row w-full items-start gap-y-12 md:gap-x-16 lg:gap-x-24">

            {# --- LEFT SIDE: --- #}
            <div class="w-full md:w-[25%] shrink-0 pt-20 md:pt-32">
                {% if data.paragraphHeading %}
                    <h2 class="font-serif tracking-tight {{ data.textColor }} leading-[1] text-balance"
                        style="font-size: clamp(2.2rem, 5.5vw, 4.5rem);">
                        {{ data.paragraphHeading | raw }}
                    </h2>
                {% endif %}
            </div>

            {# --- RIGHT SIDE: Content Area --- #}
            <div class="grow pt-8 md:pt-32 pb-20 md:pb-32">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 lg:gap-x-16 gap-y-12 md:gap-y-16">
                    {% for block in data.infoBlock %}
                        <div class="flex flex-col">
                            {% if block.blockHeading %}
                                <div class="mb-3">
                                    <h3 class="font-serif leading-[1.1] {{ data.textColor }} tracking-tight"
                                        style="font-size: clamp(1.4rem, 2.2vw, 2rem); text-wrap: balance;">
                                        {{ block.blockHeading }}
                                    </h3>
                                </div>
                            {% endif %}

                            {% if block.blockBodyText %}
                                <div class="font-aktiv leading-relaxed font-normal opacity-90 {{ data.textColor }}"
                                     style="font-size: clamp(0.95rem, 1vw, 1.05rem); text-wrap: pretty;">
                                    {{ block.blockBodyText | raw }}
                                </div>
                            {% endif %}

                            {% if block.blockLinkUrl %}
                                <div class="mt-4">
                                    <a href="{{ block.blockLinkUrl }}" class="text-[10px] font-bold tracking-[0.2em] uppercase underline {{ data.textColor }} hover:opacity-70 transition-opacity">
                                        Learn More
                                    </a>
                                </div>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            </div>

        </div>
    </div>
</section>