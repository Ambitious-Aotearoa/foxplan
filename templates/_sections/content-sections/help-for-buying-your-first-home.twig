{# templates/_sections/info-block.twig #}

{% set defaults = {
    paragraphHeading: null,
    infoBlock: [],
    backgroundColor: 'bg-foxplan-neutral-beige',
    textColor: 'text-foxplan-charcoal-brown',
    borderColor: ''
} %}

{% set data = defaults | merge(props ?? {}) %}

<section class="w-full relative z-20 {{ data.backgroundColor }} py-20 md:py-32 overflow-hidden border-b {{ data.borderColor }}">
    <div class="px-4 md:px-6 lg:px-8 w-full">
        <div class="grid grid-cols-1 lg:grid-cols-10 w-full items-start">

            {# Left Side #}
            <div class="lg:col-span-3 mb-12 lg:mb-0 lg:pr-12">
                {% if data.paragraphHeading %}
                    <h2 class="font-serif tracking-tight {{ data.textColor }}"
                        style="font-size: clamp(2.4rem, 5vw, 5rem);
                   line-height: 1 !important;
                   text-wrap: balance;">
                        {{ data.paragraphHeading | raw }}
                    </h2>
                {% endif %}
            </div>



            {# Right Side #}
            <div class="lg:col-span-7">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 lg:gap-x-20 gap-y-12 md:gap-y-16">
                    {% for block in data.infoBlock %}
                        <div class="flex flex-col">
                            {% if block.blockHeading %}
                                <h3 class="font-serif leading-tight mb-4 {{ data.textColor }} tracking-tight"
                                    style="font-size: clamp(1.5rem, 3vw, 2.25rem);">
                                    {{ block.blockHeading }}
                                </h3>
                            {% endif %}

                            {% if block.blockBodyText %}
                                <div class="font-aktiv leading-relaxed font-light opacity-90 {{ data.textColor }}"
                                     style="font-size: clamp(1rem, 1.2vw, 1.15rem);">
                                    {{ block.blockBodyText }}
                                </div>
                            {% endif %}

                            {% if block.blockLinkUrl %}
                                <a href="{{ block.blockLinkUrl }}" class="mt-6 text-[10px] font-bold tracking-[0.2em] uppercase underline {{ data.textColor }} hover:opacity-70 transition-opacity">
                                    Learn More
                                </a>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
</section>