{# templates/_sections/content-sections/kiwisaver-fund-types.twig #}

{% set sourceEntry = entry ?? craft.entries.section('accounting').one() %}

{% set defaults = {
    backgroundColor: 'bg-foxplan-charcoal-brown',
    textColor: 'text-foxplan-yellow',
    mainTitle: sourceEntry.mainTitle ?? '',
    paragraphHeading: sourceEntry.paragraphHeading ?? 'Why compare KiwiSaver fund types?',
    footnoteText: sourceEntry.bodyText3 ?? '',
    accordionItems: sourceEntry.accordion.all() ?? []
} %}

{% set data = defaults | merge(props ?? {}) %}

<section class="w-full relative z-20 {{ data.backgroundColor }} pt-12 pb-12 md:pt-20 md:pb-16 lg:pt-16 lg:pb-20 overflow-hidden">
    <div class="w-full px-4 md:px-6 lg:px-8">

        {# --- Heading (Main Title + Paragraph Heading fields) --- #}
        <div class="max-w-2xl mb-16 md:mb-20">
{#            {% if data.mainTitle %}#}
{#                <span class="font-aktiv text-[10px] md:text-[12px] mb-8 font-bold uppercase tracking-[0.2em] {{ data.textColor }} leading-none block">#}
{#                    {{ data.mainTitle | raw }}#}
{#                </span>#}
{#            {% endif %}#}

            <h2 class="font-serif tracking-tight {{ data.textColor }} leading-[0.95] {{ data.mainTitle ? 'mt-4' : '' }}"
                style="font-size: clamp(2.5rem, 6vw, 4.5rem);">
                {{ data.paragraphHeading | raw }}
            </h2>
        </div>

        {# --- Four column items (Accordion Matrix field: accordionHeading + accordionBodyText) --- #}
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-10 mb-16 md:mb-20">
            {% for item in data.accordionItems %}
                <div class="accordion-item">
                    {% if item.accordionHeading %}
                        <h3 class="font-serif tracking-tight {{ data.textColor }} leading-[1.15] mb-4"
                            style="font-size: clamp(1.25rem, 2vw, 1.5rem);">
                            {{ item.accordionHeading | raw }}
                        </h3>
                    {% endif %}

                    {% if item.accordionBodyText %}
                        <div class="font-aktiv {{ data.textColor }} opacity-80 leading-relaxed"
                             style="font-size: clamp(0.8rem, 1vw, 0.9rem);">
                            {{ item.accordionBodyText | raw }}
                        </div>
                    {% endif %}
                </div>
            {% endfor %}
        </div>

        {# --- Footnote (Body Text field: bodyText3) --- #}
        {% if data.footnoteText %}
            <div class="font-aktiv {{ data.textColor }} opacity-70 text-xs max-w-4xl">
                {{ data.footnoteText | raw }}
            </div>
        {% endif %}
    </div>
</section>