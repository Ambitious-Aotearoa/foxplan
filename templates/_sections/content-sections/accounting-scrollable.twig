<section class="relative w-full h-auto lg:h-screen bg-foxplan-charcoal-brown text-foxplan-neutral-beige
                border-l-[15px] lg:border-l-[25px] border-foxplan-neutral-beige overflow-hidden
                 before:content-[''] before:absolute before:inset-0
                 before:border-l-[20px] before:border-t-[20px] before:border-b-[30px]
                 before:border-foxplan-charcoal-brown before:z-20 before:pointer-events-none px-4 md:px-6 lg:px-8">

    {# Header Area #}
    <div class="pt-10 md:pt-24 relative z-30  ">
        <div class="flex flex-col xl:flex-row xl:justify-between xl:items-end mb-10 md:mb-16 gap-6">

            <h2 class="font-serif leading-[1.1] md:leading-[1.0] xl:leading-[0.85] tracking-tight w-full"
                style="font-size: clamp(2.4rem, 10vw, 6.5rem); text-wrap: balance;">
                {{ block.paragraphHeading }}
            </h2>

            {# Desktop Navigation Arrows #}
            <div class="hidden md:flex justify-start  gap-3 flex-shrink-0 xl:mb-4">
                <button id="scrollPrev" @click="prev()" class="w-12 h-12 rounded-full bg-foxplan-yellow flex items-center justify-center text-foxplan-charcoal-brown hover:opacity-90 transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 15.21 15.41" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square">
                        <path d="M14.71,7.71H1.71"/>
                        <path d="M7.71.71L.71,7.71l7,7"/>
                    </svg>
                </button>

                <button id="scrollNext" @click="next()" class="w-12 h-12 rounded-full bg-foxplan-yellow flex items-center justify-center text-foxplan-charcoal-brown hover:opacity-90 transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 15.21 15.41" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square">
                        <path d="M.5,7.71h13"/>
                        <path d="M7.5,14.71l7-7L7.5.71"/>
                    </svg>
                </button>
            </div>
        </div>
    </div>

    {# Cards Container #}
    <div id="serviceContainer"
         class="relative z-10 flex flex-nowrap overflow-x-auto gap-6 px-4 md:px-6 lg:px-8 mb-6 md:mb-10 snap-x snap-mandatory no-scrollbar scroll-smooth">

        {% for card in block.heroMatrix.all() %}
            <div class="flex-shrink-0 min-w-[85vw] md:min-w-[45vw] lg:min-w-[calc((100%/3)-2rem)] bg-foxplan-neutral-beige p-5 md:px-6 lg:p-12 text-foxplan-charcoal-brown snap-start flex flex-col h-auto min-h-[350px] lg:h-[550px] overflow-hidden">

                <div class="mb-6 md:mb-10 flex-shrink-0">
                    {{ include('_components/ui/icons/performance-icon.twig', {
                        props: { name: card.icons.value ?? '1', color: '#270E15', size: 'w-10 h-10 md:w-16 md:h-16', classes: 'opacity-100' }
                    }) }}
                </div>

                {# Heading converted to div - styles preserved exactly #}
                <div class="font-serif mb-4 md:mb-6 leading-tight flex-shrink-0 w-full max-w-xs md:max-w-sm lg:max-w-none"
                     style="font-size: clamp(1.75rem, 2vw + 1rem, 2.5rem); text-wrap: balance;">
                    {{ card.mainHeading }}
                </div>

                {# Body text converted to div - space and constraints preserved #}
                <div class="font-aktiv leading-relaxed font-medium text-left whitespace-normal max-w-xs md:max-w-sm lg:max-w-none"
                     style="font-size: clamp(1rem, 0.5vw + 0.8rem, 1.125rem); word-break: normal;">
                    {{ card.bodyText | replace({'<p>': '<div>', '</p>': '</div>'}) | raw }}
                </div>
            </div>
        {% endfor %}
    </div>

    {# Mobile Navigation Arrows #}
    <div class="flex md:hidden relative z-30 px-6 mb-12 gap-3">
        <button id="scrollPrevMobile" class="w-12 h-12 rounded-full bg-foxplan-yellow flex items-center justify-center text-foxplan-charcoal-brown hover:opacity-90 transition-all">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 12H5M12 19l-7-7 7-7"/>
            </svg>
        </button>
        <button id="scrollNextMobile" class="w-12 h-12 rounded-full bg-foxplan-yellow flex items-center justify-center text-foxplan-charcoal-brown hover:opacity-90 transition-all">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14m-7-7 7 7-7 7"/>
            </svg>
        </button>
    </div>
</section>

<style>
    .no-scrollbar::-webkit-scrollbar { display: none !important; }
    .no-scrollbar { -ms-overflow-style: none !important; scrollbar-width: none !important; }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const container = document.getElementById('serviceContainer');
        const nextBtns = [document.getElementById('scrollNext'), document.getElementById('scrollNextMobile')];
        const prevBtns = [document.getElementById('scrollPrev'), document.getElementById('scrollPrevMobile')];

        if (container) {
            const getScrollAmount = () => {
                const firstCard = container.querySelector('div');
                return firstCard ? firstCard.offsetWidth + 24 : 300;
            };

            nextBtns.forEach(btn => {
                if(btn) btn.addEventListener('click', () => {
                    container.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
                });
            });

            prevBtns.forEach(btn => {
                if(btn) btn.addEventListener('click', () => {
                    container.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
                });
            });
        }
    });
</script>