<section class="relative w-full bg-foxplan-charcoal-brown text-foxplan-neutral-beige
                border-l-[15px] lg:border-l-[25px]
                border-b-[15px] lg:border-b-[25px]
                border-foxplan-neutral-beige overflow-hidden
                 before:content-[''] before:absolute before:inset-0
                 before:border-l-[15px] lg:before:border-l-[20px]
                 before:border-t-[20px]
                 before:border-b-[15px] lg:before:border-b-[25px]
                 before:border-foxplan-charcoal-brown before:z-20 before:pointer-events-none">

    {# Header Area #}
    <div class="pt-12 md:pt-16 lg:pt-24 px-4 md:px-6 lg:px-8 relative z-30">
        <div class="flex flex-col xl:flex-row xl:justify-between xl:items-end mb-6 md:mb-8 gap-6">
            <h2 class="font-serif leading-[1.0] lg:leading-[0.9] tracking-tight w-full max-w-5xl"
                style="font-size: clamp(2.4rem, 9vw, 6rem); text-wrap: balance;">
                {{ block.paragraphHeading }}
            </h2>

            {# Desktop Navigation Arrows #}
            <div class="hidden xl:flex gap-3 flex-shrink-0 mb-4">
                <button id="scrollPrev" class="w-11 h-11 rounded-full bg-foxplan-yellow flex items-center justify-center text-foxplan-charcoal-brown hover:scale-105 transition-all">
                    <svg viewBox="0 0 15 15" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 7.5H1M7 1L1 7.5l6 6.5"/></svg>
                </button>
                <button id="scrollNext" class="w-11 h-11 rounded-full bg-foxplan-yellow flex items-center justify-center text-foxplan-charcoal-brown hover:scale-105 transition-all">
                    <svg viewBox="0 0 15 15" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 7.5h13m-6 6.5l6-6.5-6-6.5"/></svg>
                </button>
            </div>
        </div>
    </div>

    {# Cards Container #}
    <div id="serviceContainer"
         class="relative z-10 flex flex-nowrap overflow-x-auto snap-x snap-mandatory no-scrollbar scroll-smooth
                px-8 pb-16 gap-6
                md:px-8 md:pb-16 md:gap-8 md:border-t md:border-foxplan-charcoal-brown">

        {% for card in block.heroMatrix.all() %}
            <div class="flex-shrink-0 snap-start flex flex-col bg-foxplan-neutral-beige text-foxplan-charcoal-brown
                        min-w-[85vw] p-8 h-auto
                        md:min-w-[45vw] md:p-10
                        lg:min-w-[33.3333%] lg:p-16 h-auto md:border-r md:border-foxplan-charcoal-brown last:md:border-r-0">

                <div class="mb-8 flex-shrink-0">
                    {{ include('_components/ui/icons/performance-icon.twig', {
                        props: { name: card.icons.value ?? '1', color: '#270E15', size: 'w-12 h-12 md:w-14 md:h-14' }
                    }) }}
                </div>

                <h3 class="font-serif mb-4 leading-tight flex-shrink-0 max-w-xs md:max-w-lg"
                    style="font-size: clamp(1.6rem, 2.2vw, 2.4rem); text-wrap: balance;">
                    {{ card.mainHeading }}
                </h3>

                <div class="font-aktiv leading-relaxed font-medium opacity-90 w-full max-w-xs md:max-w-md text-sm md:text-base">
                    {{ card.bodyText | replace({'<p>': '<div>', '</p>': '</div>'}) | raw }}
                </div>
            </div>
        {% endfor %}
    </div>

    {# Navigation Arrows (Mobile/Tablet) #}
    <div class="flex xl:hidden relative z-30 px-4 mb-10 mt-[-32px] gap-3">
        <button id="scrollPrevMobile" class="w-12 h-12 rounded-full bg-foxplan-yellow flex items-center justify-center text-foxplan-charcoal-brown hover:opacity-90 transition-all shadow-sm">
            <svg viewBox="0 0 15 15" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 7.5H1M7 1L1 7.5l6 6.5"/></svg>
        </button>
        <button id="scrollNextMobile" class="w-12 h-12 rounded-full bg-foxplan-yellow flex items-center justify-center text-foxplan-charcoal-brown hover:opacity-90 transition-all shadow-sm">
            <svg viewBox="0 0 15 15" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 7.5h13m-6 6.5l6-6.5-6-6.5"/></svg>
        </button>
    </div>
</section>

<style>
    .no-scrollbar::-webkit-scrollbar { display: none !important; width: 0 !important; height: 0 !important; }
    .no-scrollbar { -ms-overflow-style: none !important; scrollbar-width: none !important; }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const container = document.getElementById('serviceContainer');
        const nextBtns = document.querySelectorAll('#scrollNext, #scrollNextMobile');
        const prevBtns = document.querySelectorAll('#scrollPrev, #scrollPrevMobile');

        if (container) {
            const getScrollAmount = () => {
                const firstCard = container.querySelector('div');
                return firstCard ? firstCard.offsetWidth + 24 : 300;
            };

            nextBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    container.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
                });
            });

            prevBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    container.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
                });
            });
        }
    });
</script>