{# articles/_entry.twig #}

{# 1. FETCH DATA #}
{% set categories = entry.articleCategories.all() %}
{% set mainImage = entry.featuredImage.one() %}
{% set allFeaturedImages = entry.featuredImage.all() %}

{# 2. PREPARE SHARING DATA #}
{% set shareUrl   = entry.url | url_encode %}
{% set shareTitle = entry.title | url_encode %}

<main class="min-h-screen bg-foxplan-neutral-beige">

    {# --- HERO SECTION (Title, Date, Image) --- #}
    <section class="w-full pt-24 pb-0 overflow-hidden">
        <div class="px-4 md:px-6 lg:px-8 max-w-full mx-auto">

            {# ARTICLE TITLE: Using standard FoxPlan serif and fluid clamp #}
            <h1 class="font-serif text-foxplan-charcoal-brown leading-[0.9] tracking-tighter mb-12 max-w-[90%] lg:max-w-[80%] break-keep"
                style="font-size: clamp(3rem, 8vw, 7.5rem);">
                {{ entry.title }}
            </h1>

            <div class="grid grid-cols-1 md:grid-cols-10 gap-x-0 items-start">

                {# DATE & CATEGORIES COLUMN #}
                <div class="md:col-span-3 lg:col-span-2">
                    <div class="font-aktiv-grotesk text-[10px] uppercase tracking-[0.2em] text-foxplan-charcoal-brown pt-1 pb-8">
                        <div class="grid grid-cols-[auto_1fr] gap-y-3">
                            {% for cat in categories %}

                                {# Column 1: Date #}
                                <div class="whitespace-nowrap pr-6">
                                    {% if loop.first %}
                                        <span>{{ entry.postDate | date('j F Y') | upper }}</span>
                                    {% else %}
                                        <span class="invisible select-none" aria-hidden="true">{{ entry.postDate | date('j F Y') | upper }}</span>
                                    {% endif %}
                                </div>

                                {# Column 2: Category + Bullet aligned to a fixed path #}
                                <div class="flex items-center justify-between ">
                                    <span class="whitespace-nowrap">{{ cat.title | upper }}</span>
                                    <span class="mt-[2px] ml-auto mr-2">•</span>
                                </div>

                            {% endfor %}
                        </div>
                    </div>
                </div>

                {# FEATURED IMAGE (Right 70%) #}
                <div class="md:col-span-7 lg:col-span-8">
                    <div class="aspect-[16/9] w-full overflow-hidden bg-foxplan-charcoal-brown/5">
                        {% if mainImage %}
                            <img src="{{ mainImage.url }}"
                                 alt="{{ mainImage.title ?: entry.title }}"
                                 class="w-full h-full object-cover">
                        {% else %}
                            <div class="w-full h-full flex items-center justify-center border border-foxplan-charcoal-brown/10">
                                <span class="text-[10px] uppercase tracking-widest opacity-30 italic">No Featured Image Found</span>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# --- CONTENT SECTION --- #}
    <section class="w-full pt-8 md:pt-12 lg:pt-24 pb-12 md:pb-20 lg:pb-32">
        <div class="px-4 md:px-6 lg:px-8 mx-auto">
            <div class="grid grid-cols-1 md:grid-cols-10 gap-x-0 relative">

                {# Column Offset #}
                <div class="hidden md:block md:col-span-3 lg:col-span-2"></div>

                {# Main Body Content #}
                <div class="md:col-span-6 lg:col-span-6">
                    <div class="font-aktiv-grotesk font-light text-foxplan-charcoal-brown leading-[1.6] rich-text-content"
                         style="font-size: clamp(1rem, 1.2vw, 1.15rem);">

                        <style>
                            /* Using standard Season and Clamps for subheaders */
                            .rich-text-content h2 {
                                font-family: 'SeasonSerifTRIALLight', serif;
                                font-size: clamp(1.75rem, 3vw, 2.5rem);
                                margin-top: 3.5rem;
                                margin-bottom: 1.5rem;
                                color: #270E15;
                                line-height: 1.1;
                            }
                            .rich-text-content p { margin-bottom: 1.75rem; }
                            .rich-text-content img { width: 100%; height: auto; margin: 3rem 0; border-radius: 2px; }
                        </style>

                        {% if entry.insightBody %}
                            {{ entry.insightBody | raw }}
                        {% endif %}

                        {# Secondary Images Grid #}
                        {% if allFeaturedImages|length > 1 %}
                            <div class="mt-20 grid grid-cols-1 md:grid-cols-2 gap-6">
                                {% for image in allFeaturedImages|slice(1) %}
                                    <div class="aspect-square overflow-hidden bg-foxplan-charcoal-brown/5">
                                        <img src="{{ image.url }}" alt="{{ image.title }}" class="w-full h-full object-cover">
                                    </div>
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                </div>

                {# STICKY SOCIAL SIDEBAR #}
                <div class="hidden md:block md:col-start-10 md:col-span-1">
                    <div class="sticky top-32 flex flex-col items-end gap-3">
                        {{ include('_components/ui/icons/facebook-icon.twig', {
                            props: {
                                iconColor: 'fill-foxplan-white',
                                boxColor: 'bg-foxplan-charcoal-brown',
                                size: 'w-8 h-8',
                                url: "https://www.facebook.com/sharer/sharer.php?u=" ~ shareUrl
                            }
                        }) }}

                        {{ include('_components/ui/icons/linkedin-icon.twig', {
                            props: {
                                iconColor: 'fill-foxplan-white',
                                boxColor: 'bg-foxplan-charcoal-brown',
                                size: 'w-8 h-8',
                                url: "https://www.linkedin.com/sharing/share-offsite/?url=" ~ shareUrl
                            }
                        }) }}
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>