{# templates/_sections/content-sections/accounting-pricing.twig #}

<section class="w-full bg-foxplan-neutral-beige py-8 md:py-24 px-4 md:px-6 lg:px-8 border-b border-foxplan-charcoal-brown overflow-hidden">

    {# HEADER GRID - Made fully fluid with responsive grid spans #}
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-[clamp(2rem,6vw,5rem)] items-end mb-16 w-full">

        {# Column 1: Main Heading #}
        <div class="lg:col-span-7">
            <h2 class="font-serif text-foxplan-charcoal-brown leading-[1.1] tracking-tight break-words"
                style="font-size: clamp(2.5rem, 6vw, 4.5rem);">
                {{ block.paragraphHeading3 | raw }}
            </h2>
        </div>

        {# Column 2: Body Text #}
        <div class="lg:col-span-5">
            <div class="leading-relaxed text-foxplan-charcoal-brown font-aktiv opacity-90 break-words"
                 style="font-size: clamp(1rem, 1vw + 0.5rem, 1.125rem);">
                {{ block.bodyText2 ?? '' }}
            </div>
        </div>
    </div>

    {# PRICING TABLE #}
    <div class="w-full border border-foxplan-charcoal-brown grid grid-cols-1 md:grid-cols-3">
        {% set rows = block.accountingTable ?? [] %}
        {% set headerLabel = rows[0] ?? null %}
        {% set headerPrice = rows[1] ?? null %}
        {% set headerFocus = rows[2] ?? null %}
        {% set colHandles = ['col2', 'col3', 'col4'] %}

        {% for handle in colHandles %}

            <div class="p-6 sm:p-8 lg:p-10 border-b md:border-b-0 md:border-r border-foxplan-charcoal-brown last:border-r-0 last:border-b-0 grid grid-rows-[auto_auto_auto_1fr]">

                {# 1. Label Section #}
                <div class="block font-bold tracking-wider text-foxplan-charcoal-brown uppercase mb-2 text-xs md:text-sm">
                    {{ attribute(headerLabel, handle) ?? '' }}
                </div>

                {# 2. Price Section - Reduced size to 4xl/5xl/6xl #}
                <div class="font-serif text-foxplan-charcoal-brown mb-4 break-words text-4xl md:text-5xl lg:text-6xl"
                     style="line-height: 1.1;">
                    {{ attribute(headerPrice, handle) ?? '' }}
                </div>

                {# 3. Focus Section #}
                <div class="font-medium text-foxplan-charcoal-brown mb-8 break-words text-sm md:text-base"
                     style="line-height: 1.4;">
                     {{ attribute(headerFocus, handle) ?? '' }}
                </div>

                {# 4. Features List #}
                <ul class="space-y-0 w-full">
                    {% for row in rows %}
                        {% if loop.index > 3 %}
                            {% set cellData = attribute(row, handle) %}
                            {% if cellData %}
                                <li class="py-3 border-b border-foxplan-charcoal-brown text-foxplan-charcoal-brown last:border-0 font-light text-sm md:text-base break-words">
                                    {{ cellData }}
                                </li>
                            {% endif %}
                        {% endif %}
                    {% endfor %}
                </ul>
            </div>
        {% endfor %}
    </div>
</section>

