{# templates/_sections/content-sections/accounting-pricing.twig #}

<section class="w-full bg-foxplan-neutral-beige py-8 md:py-24 px-4 md:px-6 lg:px-8 overflow-hidden">

    {# HEADER GRID #}
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-[clamp(2rem,6vw,5rem)] items-end mb-16 w-full">
        <div class="lg:col-span-7">
            <h2 class="font-serif text-foxplan-charcoal-brown leading-[0.95] tracking-tight break-words"
                style="font-size: clamp(2.5rem, 6vw, 4.5rem);">
                {{ block.paragraphHeading3 | raw }}
            </h2>
        </div>
        <div class="lg:col-span-5">
            <div class="leading-relaxed text-foxplan-charcoal-brown font-aktiv opacity-90 break-words"
                 style="font-size: clamp(1rem, 1vw + 0.5rem, 1.125rem);">
                {{ block.bodyText2 ?? '' }}
            </div>
        </div>
    </div>

    {# PRICING TABLE #}
    <div class="w-full border border-foxplan-charcoal-brown grid grid-cols-1 md:grid-cols-3">
        {% set rows = block.accountingTable ?? [] %}

        {# Extract Headers #}
        {% set headerLabel = rows[0] ?? null %}
        {% set headerPrice = rows[1] ?? null %}
        {% set headerFocus = rows[2] ?? null %}
        {% set colHandles = ['col2', 'col3', 'col4'] %}

        {% for handle in colHandles %}
            <div class="flex flex-col p-4 lg:p-10 border-b md:border-b-0 md:border-r border-foxplan-charcoal-brown last:border-r-0 last:border-b-0 h-full">

                {# 1. Label Section #}
                <div class="font-bold tracking-wider text-foxplan-charcoal-brown uppercase mb-2 text-xs md:text-sm min-h-[2rem]">
                    {{ attribute(headerLabel, handle) ?? '' }}
                </div>

                {# 2. Price Section #}
                <div class="font-serif text-foxplan-charcoal-brown mb-4 whitespace-nowrap"
                     style="font-size: clamp(1.4rem, 3.8vw, 3.8rem); line-height: 0.95;">
                    {% set priceValue = attribute(headerPrice, handle) ?? '' %}
                    {{ priceValue | replace({
                        '/ month': '<span style="font-size: 0.5em; margin-left: 0.2em;">/ month</span>',
                        '/month': '<span style="font-size: 0.5em; margin-left: 0.2em;">/ month</span>'
                    }) | raw }}
                </div>

                {# 3. Focus Section #}
                <div class="font-medium text-foxplan-charcoal-brown mb-8 break-words text-sm md:text-base min-h-[4rem]"
                     style="line-height: 0.95;">
                    {{ attribute(headerFocus, handle) ?? '' }}
                </div>

                {# 4. Features List  #}
                <ul class="flex-grow space-y-0 w-full">
                    {% for row in rows %}
                        {% if loop.index > 3 %}
                            {% set cellData = attribute(row, handle) %}
                            <li class="py-4 border-b border-foxplan-charcoal-brown text-foxplan-charcoal-brown font-light text-sm md:text-base break-words last:border-0">
                                {{ cellData ?? '&nbsp;' | raw }}
                            </li>
                        {% endif %}
                    {% endfor %}
                </ul>
            </div>
        {% endfor %}
    </div>
</section>