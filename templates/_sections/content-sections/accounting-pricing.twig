{# templates/_sections/content-sections/accounting-pricing.twig #}


<section class="w-full bg-foxplan-neutral-beige py-8 md:py-24 px-4 md:px-6 lg:px-8 border-b border-foxplan-charcoal-brown overflow-hidden">

    {# HEADER GRID#}
    <div class="grid grid-cols-1 md:grid-cols-12 gap-0 md:gap-16 items-start mb-16">

        {# Column 1: Main Heading #}
        <div class="md:col-span-7">
            <h2 class="font-serif text-foxplan-charcoal-brown leading-[1.1] mb-8 whitespace-normal"
                style="font-size: clamp(2.5rem, 6vw, 4.5rem);">
                {{ block.paragraphHeading3 | raw }}
            </h2>

        </div>

        {# Column 2: Body Text #}
        <div class="md:col-span-5 pt-4 md:pt-14 lg:pt-24">
            <div class="leading-relaxed text-foxplan-charcoal-brown"
                 style="font-size: clamp(1rem, 1vw + 0.5rem, 1.125rem);">
                {{ block.bodyText2 ?? '' }}
            </div>
        </div>
    </div>

    {# PRICING TABLE #}
    <div class="w-full border border-foxplan-charcoal-brown grid grid-cols-1 md:grid-cols-3">
        {% set rows = block.accountingTable ?? [] %}
        {% set headerLabel = rows[0] ?? null %}
        {% set headerPrice = rows[1] ?? null %}
        {% set headerFocus = rows[2] ?? null %}
        {% set colHandles = ['col2', 'col3', 'col4'] %}

        {% for handle in colHandles %}
            <div class="p-8 lg:p-12 border-b md:border-b-0 md:border-r border-foxplan-charcoal-brown last:border-r-0 last:border-b-0">

                {# Tier Label #}
                <span class="block font-bold tracking-widest text-foxplan-charcoal-brown uppercase mb-4"
                      style="font-size: clamp(0.7rem, 0.1vw + 0.6rem, 0.85rem);">
                    {{ attribute(headerLabel, handle) ?? '' }}
                </span>

                {# Price #}
                <div class="font-serif text-foxplan-charcoal-brown mb-2 break-keep"
                     style="font-size: clamp(2.5rem, 4vw + 1rem, 4.5rem);">
                    {{ attribute(headerPrice, handle) ?? '' }}
                </div>

                {# Focus #}
                <p class="font-medium text-foxplan-charcoal-brown mb-10 italic break-normal"
                   style="font-size: clamp(0.85rem, 0.2vw + 0.75rem, 1rem);">
                    Focus: {{ attribute(headerFocus, handle) ?? '' }}
                </p>


                <ul class="space-y-0">
                    {% for row in rows %}
                        {% if loop.index > 3 %}
                            {% set cellData = attribute(row, handle) %}
                            {% if cellData %}
                                <li class="py-4 border-b border-foxplan-charcoal-brown text-foxplan-charcoal-brown last:border-0 font-light break-keep"
                                    style="font-size: clamp(0.85rem, 0.15vw + 0.75rem, 1rem);">
                                    {{ cellData }}
                                </li>
                            {% endif %}
                        {% endif %}
                    {% endfor %}
                </ul>
            </div>
        {% endfor %}
    </div>
</section>