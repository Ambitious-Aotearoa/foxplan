{# templates/_sections/content-sections/home-guide.twig #}

{% set sectionImage = entry.image.one() %}
{% set rawUrl = entry.buttonUrl ?? '' %}
{% set finalUrl = rawUrl ? url(rawUrl) : '' %}

{% set defaults = {
    title: entry.paragraphHeading2 ?? 'Get the First Home Buyers Guide',
    bodyText: entry.bodyText2 ?? '',
    buttonText: entry.button2 ?? 'Get the Guide',
    imageSrc: sectionImage ? sectionImage.url : null,
    backgroundColor: 'bg-foxplan-yellow',
    textColor: 'text-foxplan-charcoal-brown',
    buttonBgColor: 'bg-foxplan-charcoal-brown',
    buttonTextColor: 'text-foxplan-neutral-beige',
    borderColor: 'border-foxplan-charcoal-brown'
} %}

{% set data = defaults | merge(props is iterable ? props : {}) %}

<div x-data="{
    showFirstHomeOverlay: false,
    step: 1,
    initCalendly() {
        if (window.Calendly) {
            Calendly.initInlineWidget({
                url: 'https://calendly.com/foxplansales/discovery-phone-call-clone?hide_event_type_details=1&background_color=f9efd8&primary_color=270e15&text_color=270e15',
                parentElement: this.$refs.calendlyTarget
            });
        }
    }
}"
     x-init="$watch('showFirstHomeOverlay', value => {
    if (!value) setTimeout(() => step = 1, 300);
    document.body.style.overflow = value ? 'hidden' : '';
})">

    <section class="{{ data.backgroundColor }} w-full overflow-hidden border-t {{ data.borderColor }}">
        <div class="px-4 md:px-6 lg:px-8 py-12 lg:py-16 lg:pt-32 lg:pb-32">
            <div class="flex flex-wrap md:flex-nowrap w-full items-start gap-0">

                {# Left Column #}
                <div class="w-full md:w-[30%] mb-12 md:mb-0 pr-0 md:pr-8 lg:pr-12">
                    <div class="max-w-md">
                        <h2 class="font-serif tracking-tight {{ data.textColor }} mb-8"
                            style="font-size: clamp(2.25rem, 4vw + 1rem, 4.5rem); line-height: 1; text-wrap: balance;">
                            {{ data.title | raw }}
                        </h2>

                        {% if data.bodyText is not empty %}
                            <div class="font-aktiv opacity-90 {{ data.textColor }} font-medium mb-10"
                                 style="font-size: clamp(0.9rem, 0.4vw + 0.8rem, 1.1rem); line-height: 1.4;">
                                {{ data.bodyText | striptags | raw }}
                            </div>
                        {% endif %}

                        {% if data.buttonText is not empty %}
                            {# WRAPPER TO ENSURE CLICK WORKS #}
                            <div class="inline-block cursor-pointer" @click="showFirstHomeOverlay = true">
                                {{ include('_components/ui/button/button.twig', {
                                    props: {
                                        text: data.buttonText,
                                        tag: 'span',
                                        classes: 'px-10 py-4 !w-auto pointer-events-none'
                                    }
                                }) }}
                            </div>
                        {% endif %}
                    </div>
                </div>

                {# Right Side #}
                <div class="w-full md:w-[70%]">
                    <div class="w-full relative overflow-hidden">
                        <img src="{{ data.imageSrc ?: craft.vite.asset('images/Insights_4.jpg') }}"
                             alt="{{ data.title|striptags }}"
                             class="w-full h-[350px] md:h-[550px] lg:h-[650px] object-cover block">
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# Overlay #}
    <div
            x-show="showFirstHomeOverlay"
            x-cloak
            class="fixed inset-0 z-[9999] flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm"
            x-transition:enter="transition ease-out duration-300"
            x-transition:enter-start="opacity-0"
            x-transition:enter-end="opacity-100"
            x-transition:leave="transition ease-in duration-200"
            x-transition:leave-start="opacity-100"
            x-transition:leave-end="opacity-0"
    >
        <div @click.away="showFirstHomeOverlay = false" class="relative w-full max-w-4xl bg-foxplan-neutral-beige shadow-2xl p-6 md:p-12 overflow-y-auto max-h-[95vh]">

            <button @click="showFirstHomeOverlay = false" class="absolute top-6 right-6 text-foxplan-charcoal-brown hover:opacity-60 z-50">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>

            {# STEP 1: Form #}
            <div x-show="step === 1" x-transition:enter="transition duration-300">
                <h2 class="font-serif text-5xl md:text-7xl text-foxplan-charcoal-brown mb-6">Get the guide</h2>
                <p class="text-xl text-gray-700 mb-10 max-w-md">Ready to get your finances in great shape? Fill in your details below.</p>

                <form @submit.prevent="step = 2; $nextTick(() => initCalendly())" class="space-y-8">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <div>
                            <label class="block text-xs font-bold uppercase mb-2">First Name</label>
                            <input type="text" required class="w-full border-b border-foxplan-charcoal-brown py-2 bg-transparent outline-none rounded-none">
                        </div>
                        <div>
                            <label class="block text-xs font-bold uppercase mb-2">Last Name</label>
                            <input type="text" required class="w-full border-b border-foxplan-charcoal-brown py-2 bg-transparent outline-none rounded-none">
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-bold uppercase mb-2">Email Address</label>
                        <input type="email" required class="w-full border-b border-foxplan-charcoal-brown py-2 bg-transparent outline-none rounded-none">
                    </div>

                    {# GHOST BUTTON PATTERN #}
                    <div class="relative inline-block mt-4">
                        {{ include('_components/ui/button/button.twig', {
                            props: {
                                text: 'Download now',
                                tag: 'span',

                            }
                        }) }}
                        <button type="submit" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer">Submit Form</button>
                    </div>
                </form>
            </div>

            {# STEP 2: Thank You & Calendly #}
            <div x-show="step === 2" x-transition:enter="transition duration-300" class="w-full">
                <div class="text-center md:text-left mb-4">
                    <h2 class="font-serif text-5xl md:text-6xl text-foxplan-charcoal-brown mb-2">Thank You!</h2>
                    <p class="text-lg text-gray-700">Your download is on its way! Book a discovery call below.</p>
                </div>
                <div class="border-t border-foxplan-charcoal-brown pt-4 min-h-[600px]">
                    <div x-ref="calendlyTarget" class="calendly-inline-widget" style="min-width:320px;height:700px;"></div>
                </div>
            </div>
        </div>
    </div>
</div>

{% js "https://assets.calendly.com/assets/external/widget.js" %}