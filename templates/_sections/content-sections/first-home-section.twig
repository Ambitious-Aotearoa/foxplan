{# 1. Get the PDF from the Asset field you just populated #}
{% set guideFile = entry.guidePdf.one() %}
{% set guideUrl = guideFile ? guideFile.url : '' %}

{# 2. Setup images and data #}
{% set sectionImage = entry.image.one() %}
{% set defaults = {
    title: entry.paragraphHeading3 ?? 'Get the First Home Buyers Guide',
    bodyText: entry.bodyText3 ?? '',
    buttonText: entry.button2 ?? 'Download now',
    imageSrc: sectionImage ? sectionImage.url : null,
    backgroundColor: 'bg-foxplan-neutral-beige',
    textColor: 'text-foxplan-charcoal-brown',
    borderColor: 'border-foxplan-charcoal-brown'
} %}

{% set data = defaults | merge(props is iterable ? props : {}) %}

<div x-data="{
    showFirstHomeOverlay: false,
    step: 1,
    initCalendly() {
        if (window.Calendly) {
            this.$refs.calendlyTarget.innerHTML = '';
            Calendly.initInlineWidget({
                url: 'https://calendly.com/foxplansales/discovery-phone-call-clone?hide_event_type_details=1&background_color=f9efd8&primary_color=270e15&text_color=270e15',
                parentElement: this.$refs.calendlyTarget
            });
        }
    },
    async handleDownloadAndSubmit(e) {
    e.preventDefault();
    const formData = new FormData(e.target);

    // 1. Submit form (This triggers the email with the PDF attached)
    fetch('', {
        method: 'POST',
        body: formData,
        headers: { 'Accept': 'application/json' }
    });

    // 2. We NO LONGER use window.open here.
    // The user will get the file in their email instead.

    // 3. Switch to Step 2 (Calendly)
    this.step = 2;
    this.$nextTick(() => { this.initCalendly(); });
}
}"
     x-init="$watch('showFirstHomeOverlay', value => {
    if (!value) setTimeout(() => step = 1, 300);
    document.body.style.overflow = value ? 'hidden' : '';
})">

    {# Main Section UI #}
    <section class="{{ data.backgroundColor }} w-full overflow-hidden border-t {{ data.borderColor }}">
        <div class="px-4 md:px-6 lg:px-8 py-12 lg:py-16 lg:pt-32 lg:pb-32">
            <div class="flex flex-wrap md:flex-nowrap w-full items-start gap-0">
                <div class="w-full md:w-[30%] mb-12 md:mb-0 pr-0 md:pr-8 lg:pr-12">
                    <h2 class="font-serif tracking-tight {{ data.textColor }} mb-8 text-5xl lg:text-7xl">{{ data.title | raw }}</h2>
                    <div class="font-aktiv opacity-90 {{ data.textColor }} mb-10">{{ data.bodyText | raw }}</div>
                    <div @click="showFirstHomeOverlay = true" class="inline-block cursor-pointer">
                        {{ include('_components/ui/button/button.twig', { props: { text: data.buttonText, tag: 'span' } }) }}
                    </div>
                </div>
                <div class="w-full md:w-[70%]">
                    <img src="{{ data.imageSrc ?: craft.vite.asset('images/Insights_4.jpg') }}" class="w-full h-[400px] lg:h-[600px] object-cover">
                </div>
            </div>
        </div>
    </section>

    {# Overlay #}
    <div x-show="showFirstHomeOverlay" x-cloak class="fixed inset-0 z-[9999] flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm">
        <div @click.away="showFirstHomeOverlay = false" class="relative w-full max-w-4xl bg-foxplan-neutral-beige p-8 lg:p-12 overflow-y-auto max-h-[95vh]">

            <button @click="showFirstHomeOverlay = false" class="absolute top-6 right-6 text-foxplan-charcoal-brown">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12" stroke-width="1.5"></path></svg>
            </button>

            {# STEP 1: The Form #}
            <div x-show="step === 1">
                <h2 class="font-serif text-5xl text-foxplan-charcoal-brown mb-6">Get the guide</h2>
                <form @submit="handleDownloadAndSubmit($event)">
                    {{ actionInput('contact-form/send') }}
                    {{ csrfInput() }}
                    <input type="hidden" name="message[formName]" value="First Home Buyers Guide">
                    <input type="hidden" name="message[disableConfirmation]" value="1">
                    <div class="grid grid-cols-2 gap-8">
                        <div>
                            <label class="block text-xs font-bold uppercase mb-2">First Name</label>
                            <input type="text" name="fromName" required class="w-full border-b border-black bg-transparent py-2 outline-none">
                        </div>
                        <div>
                            <label class="block text-xs font-bold uppercase mb-2">Last Name</label>
                            <input type="text" name="message[LastName]" required class="w-full border-b border-black bg-transparent py-2 outline-none">
                        </div>
                    </div>
                    <div class="mt-8">
                        <label class="block text-xs font-bold uppercase mb-2">Email Address</label>
                        <input type="email" name="fromEmail" required class="w-full border-b border-black bg-transparent py-2 outline-none">
                    </div>

                    <div class="relative inline-block mt-10">
                        {{ include('_components/ui/button/button.twig', { props: { text: 'Download now', tag: 'span' } }) }}
                        <button type="submit" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer"></button>
                    </div>
                </form>
            </div>

            {# STEP 2: The Calendly Widget #}
            <div x-show="step === 2">
                <div class="text-center md:text-left mb-6">
                    <h2 class="font-serif text-5xl text-foxplan-charcoal-brown mb-2">Thank You!</h2>
                    {# Updated text below #}
                    <p class="text-lg text-gray-700 font-aktiv">Your guide is on its way to your inbox. While you wait, book your discovery call below.</p>
                </div>
                <div x-ref="calendlyTarget" style="min-width:320px;height:700px;"></div>
            </div>
        </div>
    </div>
</div>