{# templates/_sections/content-sections/kiwi-strategies.twig #}
{% set defaults = {
    mainTitle: 'How we work with you',
    paragraphHeading: '',
    backgroundColor: 'bg-foxplan-charcoal-brown',
    textColor: 'text-foxplan-yellow',
    block: null
} %}

{% set data = defaults | merge(props ?? {}) %}

<section class="w-full relative z-20 {{ data.backgroundColor }} py-12 md:py-20 lg:py-32 overflow-hidden">
    <div class="w-full px-4 md:px-6 lg:px-8">

        {# --- Top Section: Titles (Left-aligned) --- #}
        <div class="max-w-4xl mb-16 md:mb-20">
            {% if data.mainTitle %}
                <span class="font-aktiv text-[10px] md:text-[12px] mb-8 font-bold uppercase tracking-[0.2em] {{ data.textColor }} leading-none block">
                    {{ data.mainTitle | raw }}
                </span>
            {% endif %}

            <h2 class="font-serif tracking-tight {{ data.textColor }} leading-[0.9] md:leading-[0.95] mt-4"
                style="font-size: clamp(2.5rem, 8vw, 4.5rem);">
                {{ data.paragraphHeading | raw }}
            </h2>
        </div>

        {# --- Bottom Section: Body Text & Checklist (Side-by-Side) --- #}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 lg:gap-x-16 gap-y-12 items-start">

            {# -- Left Column: Body Text -- #}
            <div class="max-w-xl md:max-w-lg">
                {# Body Text from Craft Admin #}
                {% set bodyText = data.block.bodyText ?? null %}
                {% if bodyText %}
                    <div class="font-serif text-lg md:text-xl {{ data.textColor }} leading-relaxed opacity-90">
                        {{ bodyText | raw }}
                    </div>
                {% endif %}
            </div>

            {# -- Right Column: Info Block Checklist -- #}
            {# -- Right Column: Info Block Checklist -- #}
            {# Change: Removed 'grow' and let it take up full width if needed, or adjust the grid logic #}
            <div class="w-full">
                {# FIX: Change grid-cols-1 md:grid-cols-2 to only go 2-column on LARGER screens (lg),
       or keep it 1-column on md to prevent the overlap you see in the screenshot. #}
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-x-12 gap-y-10">

                    {% set infoBlocks = [] %}
                    {% if data.block and data.block.infoBlock is defined %}
                        {% set infoBlocks = data.block.infoBlock.all() %}
                    {% endif %}

                    {% for item in infoBlocks %}
                        <div class="flex items-start gap-4">
                            {# Yellow Checkmark Icon #}
                            <div class="flex-shrink-0 w-8 h-8 md:w-9 md:h-9 bg-foxplan-yellow flex items-center justify-center mt-1">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2D1B1E" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="20 6 9 17 4 12"></polyline>
                                </svg>
                            </div>

                            {# Item Heading #}
                            {# FIX: Removed mb-4 (which adds vertical space) and focused on 'text-balance'
                   to ensure it wraps cleanly within its container. #}
                            <div class="font-serif text-2xl lg:text-3xl {{ data.textColor }} leading-[1.15] tracking-tight">
                                {{ item.blockHeading ?? '' }}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>

        </div>
    </div>
</section>

