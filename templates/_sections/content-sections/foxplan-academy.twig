{# _sections/content-sections/foxplan-academy.twig #}

{% set defaults = {
    topLabel: entry.prehead ?? 'FOXPLAN ACADEMY',
    body: entry.largeParagraph ?? 'Every new adviser who joins us goes through our Foxplan Academy training programme...',
    backgroundColor: 'bg-foxplan-yellow',
    labelColor: 'text-foxplan-charcoal-brown',
    textColor: 'text-foxplan-charcoal-brown',
    containerPadding: 'px-4 lg:px-12'
} %}

{% set data = defaults | merge(props | default({})) %}

<section class="w-full {{ data.backgroundColor }} py-12 md:py-24 overflow-hidden">

    <div class="w-full {{ data.containerPadding }}">
        <div class="flex flex-col md:flex-row w-full items-start">

            {# Left Column: Label (30%) #}
            <div class="w-full md:w-[30%] mb-6 md:mb-0 pr-0 md:pr-12">
    <span class="font-aktiv {{ data.labelColor }} uppercase tracking-widest block font-normal"
          style="font-size: clamp(0.8rem, 0.9vw, 1rem); line-height: 0.95;">
        {{ data.topLabel }}
    </span>
            </div>

            {# Right Column: Body Text (70%) #}
            <div class="w-full md:w-[70%]">
                <div class="font-aktiv {{ data.textColor }} break-normal"
                     style="font-size: clamp(1.125rem, 1vw + 0.5rem, 1.6rem); line-height: 1.15; word-break: keep-all; font-weight: 300;">
                    {{ data.body | raw }}
                </div>
            </div>

        </div>
    </div>
</section>