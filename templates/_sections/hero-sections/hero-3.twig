{# templates/_sections/hero-sections/hero-3.twig #}

{# 1. DATA MAPPING #}
{% set contentSource = entry ?? block ?? null %}

{# Use hardcoded defaults if entry fields aren't populated #}
{% set entryTitle = contentSource.title ?? 'Complaints Policy' %}
{% set entryBody = contentSource.heroBodyText ?? '' %}
{% set entryButtonText = contentSource.button ?? null %}
{% set entryButtonLink = contentSource.buttonLink ?? '#' %}

{% set defaults = {
    backgroundColor: 'bg-foxplan-yellow',
    textColor: 'text-foxplan-charcoal-brown',
    titleColor: 'text-foxplan-charcoal-brown',
    imageSrc: 'images/PropertyInvestment_hero.jpg'
} %}

{% set data = defaults | merge(props | default({})) %}

{# 2. STYLES #}
{% set titleStyles = 'font-size: clamp(3.5rem, 9vw + 1rem, 9rem); line-height: 0.85; word-break: keep-all;' %}
{% set bodyStyles = 'font-size: 16px; line-height: 1.2;' %}
{% set staticImagePath = alias('@web/dist/' ~ data.imageSrc) %}

<section class="w-full {{ data.backgroundColor }} overflow-hidden relative">
    <div class="grid grid-cols-1 md:grid-cols-10 px-0">

        <div class="hidden md:block md:col-span-1"></div>

        <div class="col-span-1 md:col-span-9 flex flex-col">

            {# IMAGE BLOCK #}
            <div class="relative w-full h-[500px] lg:h-[750px] px-4 md:px-0 overflow-hidden">
                <img
                        src="{{ staticImagePath }}"
                        alt="{{ entryTitle }}"
                        class="w-full h-full object-cover"
                >

                {# TITLE OVERLAY #}
                {% if entryTitle %}
                    <div class="absolute bottom-0 left-0 px-8 md:px-12 pb-6">
                        <h1 class="font-serif {{ data.titleColor }} tracking-tighter break-normal"
                            style="{{ titleStyles }}">
                            {{ entryTitle | raw }}
                        </h1>
                    </div>
                {% endif %}
            </div>

            {# BOTTOM CONTENT BLOCK #}
            <div class="px-4 md:px-0 mt-12 mb-10">
{#                <div class="max-w-[450px]">#}

{#                    #}{# BODY TEXT #}
{#                    {% if entryBody %}#}
{#                        <p class="font-aktiv {{ data.textColor }} mb-10"#}
{#                           style="{{ bodyStyles }}">#}
{#                            {{ entryBody | raw }}#}
{#                        </p>#}
{#                    {% endif %}#}

{#                    #}{# BUTTON #}
{#                    {% if entryButtonText %}#}
{#                        <div class="flex">#}
{#                            {% include '_components/ui/button/button.twig' with {#}
{#                                props: {#}
{#                                    text: entryButtonText,#}
{#                                    url: entryButtonLink,#}
{#                                    backgroundColor: 'bg-foxplan-charcoal-brown',#}
{#                                    textColor: 'text-white',#}
{#                                    classes: 'px-8 py-4 text-[11px] tracking-[0.2em] uppercase font-aktiv font-bold rounded-none'#}
{#                                }#}
{#                            } only %}#}
{#                        </div>#}
{#                    {% endif %}#}
{#                </div>#}
            </div>
        </div>
    </div>
</section>