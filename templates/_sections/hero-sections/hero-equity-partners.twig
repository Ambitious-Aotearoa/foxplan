{# _sections/hero/hero-equity.twig #}

{% set data = {
    heading1: props.heading1 ?? 'Equity',
    heading2: props.heading2 ?? 'Partners',
    imagePath: props.imagePath ?? 'images/Equity_1.jpg',
    body: props.body ?? "If you're an established business owner, our equity programme can help you build and grow your business while sharing the support and success of our firm.",
    buttonText: props.buttonText ?? 'Get in Touch',
    buttonUrl: '/contact-us'
} %}

{% set heroImagePath = alias('@web/dist/' ~ data.imagePath) %}

<section class="w-full bg-foxplan-neutral-beige overflow-hidden font-aktiv"
         x-data="{ revealed: false }"
         x-init="setTimeout(() => revealed = true, 150)">

    {# 1. HERO CONTENT #}
    <div class="relative w-full max-w-[1400px] mx-auto px-4 h-auto pt-16 md:pt-24 lg:h-[650px] lg:pt-0 flex flex-col lg:flex-row items-center justify-center">

        {# Image container #}
        <div class="relative w-[85%] md:w-[75%] lg:w-[70%] h-[300px] md:h-[450px] lg:h-[80%] z-10">
            <img src="{{ heroImagePath }}" alt="Equity Partners" class="w-full h-full object-cover">
        </div>

        {# Heading 1: Centered and overlapping on mobile/tablet, original position on large #}
        <div class="absolute top-[4%] md:top-[3%] lg:top-[20%]
                left-1/2 -translate-x-1/2 lg:left-[-3%] lg:translate-x-0
                z-20 w-full lg:w-auto text-center lg:text-left">
            <h1 class="font-serif text-7xl md:text-9xl lg:text-[180px] leading-none text-foxplan-charcoal-brown tracking-tighter">
                {{ data.heading1 }}
            </h1>
        </div>

        {# Heading 2: Centered and overlapping on mobile/tablet, original position on large #}
        <div class="absolute bottom-[-11%] md:bottom-[-12%] lg:bottom-[8%]
                left-1/2 -translate-x-1/2 lg:left-auto lg:right-[-3%] lg:translate-x-0
                z-20 w-full lg:w-auto text-center lg:text-right">
            <h1 class="font-serif text-7xl md:text-9xl lg:text-[180px] leading-none text-foxplan-charcoal-brown tracking-tighter">
                {{ data.heading2 }}
            </h1>
        </div>
    </div>

    {# 2. THE GROWING ARROW #}
    {# Changed: Margin top added for mobile spacing #}
    <div class="relative w-full mt-20  lg:mt-0 mb-10 lg:mb-2 px-[10px]">
        <div class="overflow-hidden transition-all duration-[4500ms] h-[16px] relative"
             style="transition-timing-function: steps(60);"
             :style="revealed ? 'width: 100%; opacity: 1;' : 'width: 0%; opacity: 0;'">

            <div class="w-[calc(100vw-20px)] h-full grid grid-cols-[1fr_auto_16px] items-center relative">
                <div class="h-0 border-t-2 border-dashed border-foxplan-charcoal-brown"></div>
                <div class="flex items-center justify-center flex-shrink-0">
                    <div class="w-2 h-0 border-t-2 border-foxplan-charcoal-brown"></div>
                    <div class="w-3 h-3 border-t-2 border-r-2 border-foxplan-charcoal-brown rotate-45 transform origin-center -ml-2"></div>
                </div>
                <div></div>
            </div>
        </div>
    </div>

    {# 3. BODY TEXT & BUTTON #}
    <div class="w-full flex flex-col items-center justify-center px-6">
        <div class="max-w-2xl text-center mb-6">
            {# Increased mobile padding and slightly larger text for readability #}
            <p class="text-base md:text-lg lg:text-base text-foxplan-charcoal-brown leading-relaxed opacity-90">
                {{ data.body | raw }}
            </p>
        </div>

        <div class="flex">
            {% include '_components/ui/button/button.twig' with {
            props: {
            text: data.buttonText,
            url: data.buttonUrl,
            backgroundColor: 'bg-foxplan-charcoal-brown',
            textColor: 'text-white',
            classes: 'px-10 py-4 lg:px-8 lg:py-3 mb-12 text-[11px] lg:text-[10px] tracking-[0.2em] uppercase font-montreal rounded-none'
            }
            } only %}
        </div>
    </div>
</section>