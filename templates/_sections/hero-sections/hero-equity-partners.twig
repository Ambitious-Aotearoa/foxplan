{# _sections/hero/hero-equity.twig #}

{% set data = {
    heading1: props.heading1 ?? 'Equity',
    heading2: props.heading2 ?? 'Partners',
    imagePath: props.imagePath ?? 'images/Equity_1.jpg',
    body: props.body ?? "If you're an established business owner, our equity programme can help you build and grow your business while sharing the support and success of our firm.",
    buttonText: props.buttonText ?? 'Get in Touch',
    buttonUrl: '/contact-us'
} %}

{% set heroAsset = (entry is defined and entry.heroImage is defined) ? entry.heroImage.one() : null %}
{% set heroImagePath = heroAsset ? heroAsset.url : alias('@web/dist/' ~ data.imagePath) %}

<section class="w-full bg-foxplan-neutral-beige overflow-hidden font-aktiv"
         x-data="{ revealed: false }"
         x-init="setTimeout(() => revealed = true, 150)">

    {# 1. HERO CONTENT #}
    <div class="relative w-full max-w-[1440px] mx-auto px-6 pt-16 md:pt-24 lg:pt-32 flex flex-col items-center justify-center">

        {# Heading 1: Equity #}
        <div class="relative lg:absolute lg:top-[15%] lg:left-[5%] z-20 w-full lg:w-auto text-center lg:text-left mb-[-2rem] md:mb-[-4rem] lg:mb-0">
            <h1 class="font-serif text-[18vw] lg:text-[160px] leading-none text-foxplan-charcoal-brown tracking-tighter">
                {{ data.heading1 }}
            </h1>
        </div>

        {# Image container #}
        <div class="relative w-[85%] md:w-[75%] lg:w-[60%] aspect-[4/3] md:aspect-video lg:h-[480px] z-10">
            <img src="{{ heroImagePath }}" alt="Equity Partners" class="w-full h-full object-cover">
        </div>

        {# Heading 2: Partners #}
        <div class="relative lg:absolute lg:bottom-[5%] lg:right-[5%] z-20 w-full lg:w-auto text-center lg:text-right mt-[-1rem] md:mt-[-2rem] lg:mt-0">
            <h1 class="font-serif text-[18vw] lg:text-[160px] leading-none text-foxplan-charcoal-brown tracking-tighter">
                {{ data.heading2 }}
            </h1>
        </div>
    </div>

    {# 2. THE GROWING ARROW #}
    <div class="relative w-full mt-20 lg:mt-24 mb-10 px-8">
        <div class="overflow-hidden transition-all duration-[4500ms] h-[16px] relative"
             style="transition-timing-function: steps(60);"
             :style="revealed ? 'width: 100%; opacity: 1;' : 'width: 0%; opacity: 0;'">

            <div class="w-full h-full flex items-center relative">
                <div class="flex-grow h-0 border-t-2 border-dashed border-foxplan-charcoal-brown"></div>
                <div class="flex items-center ">
                    <div class="w-3 h-3 border-t-2 border-r-2 border-foxplan-charcoal-brown rotate-45 -ml-3"></div>
                </div>
            </div>
        </div>
    </div>

    {# 3. BODY TEXT & BUTTON #}
    <div class="w-full flex flex-col items-center justify-center px-6 pb-20">
        <div class="max-w-2xl text-center mb-8">
            <p class="text-base md:text-lg text-foxplan-charcoal-brown leading-relaxed opacity-90">
                {{ data.body | raw }}
            </p>
        </div>

        <div class="flex">
            {% include '_components/ui/button/button.twig' with {
                props: {
                    text: data.buttonText,
                    url: data.buttonUrl,
                    backgroundColor: 'bg-foxplan-charcoal-brown',
                    textColor: 'text-foxplan-white',
                }
            } only %}
        </div>
    </div>
</section>