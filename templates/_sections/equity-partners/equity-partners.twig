{# templates/_sections/equity-partners/equity-partners.twig #}

{# --- 1. CONTENT & IMAGE FETCHING --- #}
{% set heading = entry.paragraphHeading %}
{% set description = entry.mediumParagraph %}
{% set heading2 = entry.paragraphHeading2 %}
{% set body2 = entry.bodyText2 %}
{% set heading3 = entry.paragraphHeading3 %}
{% set body3 = entry.bodyText3 %}

{% set imgMain = entry.image.one() %}
{% set imgSec2 = entry.image2.one() %}
{% set imgSec3 = entry.image3.one() %}

{% set fallbackMain = alias('@web/dist/images/About_1.jpg') %}
{% set fallbackSec2 = alias('@web/dist/images/About_2.jpg') %}
{% set fallbackSec3 = alias('@web/dist/images/About_3.jpg') %}

<section class="relative w-full bg-foxplan-neutral-beige overflow-hidden" id="equity-partners-section">

    {# --- THE DOTTED LINE --- #}
    <div class="absolute left-1/2 -translate-x-1/2 top-[500px] bottom-[200px] md:top-0 md:bottom-0 md:h-full w-[2px] z-10 pointer-events-none">

        {# 1. The Background Track (Grey) #}
        <div class="absolute inset-0 border-l-2 border-dashed border-foxplan-charcoal-brown/10"></div>

        {# 2. The Active Progress Line (Charcoal) #}
        <div id="progress-line"
             class="absolute inset-0 border-l-2 border-dashed border-foxplan-charcoal-brown"
             style="clip-path: inset(0 0 100% 0);"></div>

        {# 3. Scrolling Dot #}
        <div id="scrolling-dot"
             class="absolute left-0 -translate-x-[40%] w-3 h-3 bg-foxplan-charcoal-brown rounded-full opacity-0 shadow-sm"
             style="top: 0px; transition: opacity 300ms;">
        </div>
    </div>

        {# --- SECTION 1: HERO --- #}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-10 items-start md:mt-0 lg:mt-[200px] mb-24 md:mb-40 relative">
            <div class="col-span-1 lg:col-span-4 order-1 relative z-20 bg-foxplan-neutral-beige md:bg-transparent">
                <div class="w-full px-4 md:px-0 md:pr-12 aspect-[5/4] md:aspect-[4/5] lg:aspect-[4/5] overflow-hidden py-4 md:py-0">
                    <img src="{{ imgMain ? imgMain.url : fallbackMain }}" class="w-full h-full object-cover">
                </div>
            </div>

            <div class="col-span-1 lg:col-start-7 lg:col-span-4 order-2 relative z-20 bg-foxplan-neutral-beige md:bg-transparent">
                <div class="px-4 md:px-0 md:pl-12 md:pr-12 lg:mr-[20px] pb-12 md:pb-24 lg:pb-0">
                    {# Heading #}
                    <h2 class="font-serif text-foxplan-charcoal-brown mb-8 tracking-tight whitespace-normal"
                        style="font-size: clamp(2.5rem, 6vw, 4.375rem); line-height: 1; word-break: break-word; text-wrap: balance;">
                        {{ heading }}
                    </h2>

                    {# Description #}
                    <div class="font-aktiv font-light text-foxplan-charcoal-brown leading-relaxed max-w-xl"
                         style="font-size: clamp(1.125rem, 1.25vw, 1.25rem); word-break: normal;">
                        {{ description|raw }}
                    </div>

                    <div class="w-full flex flex-col font-aktiv text-foxplan-charcoal-brown ">
                        {% set items = [
                            'Equity ownership in a growing business',
                            'Compliance, marketing & operations support',
                            'Ongoing income even after you retire',
                            'A futureproofed business exit strategy'
                        ] %}

                        {% for item in items %}
                            <div class="py-2 border-b border-foxplan-charcoal-brown"
                                 style="font-size: clamp(1rem, 1.2vw, 1.25rem);">
                                {{ item }}
                            </div>
                        {% endfor %}
                    </div>

                </div>
            </div>
        </div>

        {# --- SECTION 2 --- #}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-10 items-start mb-24 md:mb-40 relative">
            <div class="col-span-1 lg:col-start-7 lg:col-span-4 order-1 md:order-2 relative z-20 bg-foxplan-neutral-beige md:bg-transparent">
                <div class="w-full px-4 md:px-0 md:pl-12 aspect-[4/5] lg:aspect-[4/5] overflow-hidden  pb-4 md:py-0">
                    <img src="{{ imgSec2 ? imgSec2.url : fallbackSec2 }}" class="w-full h-full object-cover">
                </div>
            </div>

            <div class="col-span-1 lg:col-span-4 order-2 md:order-1 relative z-20 bg-foxplan-neutral-beige md:bg-transparent">
                <div class="px-4 md:px-0 md:pr-12 md:pl-12 lg:pl-[20px] pb-12 md:pb-24 lg:pb-0">
                    <h2 class="font-serif text-foxplan-charcoal-brown mb-8 tracking-tight whitespace-normal"
                        style="font-size: clamp(2.5rem, 6vw, 4.375rem); line-height: 1.05; word-break: break-word; text-wrap: balance;">
                        {{ heading2 }}
                    </h2>
                    <div class="font-aktiv font-light text-foxplan-charcoal-brown leading-relaxed max-w-md"
                         style="font-size: clamp(1.125rem, 1.25vw, 1.25rem); word-break: normal;">
                        {{ body2|raw }}
                    </div>
                </div>
            </div>
        </div>

        {# --- SECTION 3 --- #}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-10 items-start relative pb-0 md:pb-0">
            <div class="col-span-1 lg:col-span-4 order-1 relative z-20 bg-foxplan-neutral-beige md:bg-transparent">
                <div class="w-full px-4 md:px-0 md:pr-12 aspect-[4/3] md:aspect-[4/5] lg:aspect-[4/5] overflow-hidden  py-4 md:py-0">
                    <img src="{{ imgSec3 ? imgSec3.url : fallbackSec3 }}" class="w-full h-full object-cover">
                </div>
            </div>

            <div class="col-span-1 lg:col-start-7 lg:col-span-4 order-2 relative z-20 bg-foxplan-neutral-beige md:bg-transparent">
                <div class="px-4 md:px-0 md:pl-12 md:pr-12 lg:mr-[20px] pb-24 md:pb-24 lg:pb-0">
                    <h2 class="font-serif text-foxplan-charcoal-brown mb-8 tracking-tight whitespace-normal"
                        style="font-size: clamp(2.5rem, 6vw, 4.375rem); line-height: 1.05; word-break: break-word; text-wrap: balance;">
                        {{ heading3 }}
                    </h2>
                    <div class="font-aktiv font-light text-foxplan-charcoal-brown leading-relaxed"
                         style="font-size: clamp(1.125rem, 1.25vw, 1.25rem); word-break: normal;">
                        {{ body3|raw }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const dot = document.getElementById('scrolling-dot');
        const progressLine = document.getElementById('progress-line');
        const timelineWrapper = dot ? dot.parentElement : null;

        function updateTimeline() {
            const timelineRect = timelineWrapper.getBoundingClientRect();
            const viewHeight = window.innerHeight;

            // Calculate progress (0 to 1)
            let scrollProgress = (viewHeight / 2 - timelineRect.top) / timelineRect.height;
            scrollProgress = Math.max(0, Math.min(1, scrollProgress));

            // Toggle Dot Opacity
            dot.style.opacity = (scrollProgress > 0 && scrollProgress < 0.99) ? "1" : "0";

            const percentage = scrollProgress * 100;

            // 1. Move the dot
            dot.style.top = `calc(${percentage}% - 6px)`;

            // 2. Reveal the charcoal line using clip-path
            // This "un-clips" the line from top to bottom
            progressLine.style.clipPath = `inset(0 0 ${100 - percentage}% 0)`;
        }
        window.addEventListener('scroll', updateTimeline);
        window.addEventListener('resize', updateTimeline);
        updateTimeline();
    });
</script>