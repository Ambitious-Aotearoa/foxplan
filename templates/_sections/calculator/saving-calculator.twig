{# templates/_sections/calculator/saving-calculator.twig #}
{#
    NOTE: This include has NO x-data of its own.
    All state lives in the parent x-data scope on the page template,
    so the calculator and the projections chart share the same reactive data.
#}

{% set calcProps = {
    cardTitle: 'Your Outcome',
    backgroundColor: 'bg-foxplan-neutral-beige',
    cardBg: 'bg-white',
    textColor: 'text-foxplan-charcoal-brown',
    buttonBg: 'bg-foxplan-charcoal-brown',
    buttonTextColor: 'text-white'
} %}

<div class="{{ calcProps.backgroundColor }} w-full overflow-hidden font-aktiv"
     @click.away="openDropdown = null">

    <div class="w-full py-16">
        <div class="flex flex-wrap lg:flex-nowrap w-full items-stretch px-4 md:px-6">

            {# Left Column: Inputs #}
            <div class="w-full lg:w-1/2 flex flex-col justify-start lg:pr-12 mb-10 lg:mb-0">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-12">

                    {# Current Age #}
                    <div class="border-b border-foxplan-tint-line/30 pb-3">
                        <label class="block uppercase tracking-[0.1em] text-foxplan-charcoal-brown/50 mb-2 font-bold"
                               style="font-size: clamp(0.625rem, 0.5vw + 0.3rem, 0.75rem);">CURRENT AGE</label>
                        <input type="number" x-model.number="localAge" min="16" max="80"
                               style="font-size: clamp(1.1rem, 1.5vw + 0.5rem, 1.5rem);"
                               class="w-full bg-transparent font-serif text-foxplan-charcoal-brown focus:outline-none border-none p-0 appearance-none">
                    </div>

                    {# Goal Age #}
                    <div class="border-b border-foxplan-tint-line/30 pb-3">
                        <label class="block uppercase tracking-[0.1em] text-foxplan-charcoal-brown/50 mb-2 font-bold"
                               style="font-size: clamp(0.625rem, 0.5vw + 0.3rem, 0.75rem);">GOAL AGE</label>
                        <input type="number" x-model.number="localGoalAge" min="17" max="100"
                               style="font-size: clamp(1.1rem, 1.5vw + 0.5rem, 1.5rem);"
                               class="w-full bg-transparent font-serif text-foxplan-charcoal-brown focus:outline-none border-none p-0 appearance-none">
                    </div>

                    {# Contribution Frequency #}
                    <div class="border-b border-foxplan-tint-line/30 pb-3 relative">
                        <label class="block uppercase tracking-[0.1em] text-foxplan-charcoal-brown/50 mb-2 font-bold"
                               style="font-size: clamp(0.625rem, 0.5vw + 0.3rem, 0.75rem);">CONTRIBUTION FREQUENCY</label>
                        <div @click="openDropdown = 'freq'" class="flex justify-between items-center cursor-pointer group">
                            <span class="font-serif text-foxplan-charcoal-brown capitalize"
                                  style="font-size: clamp(1.1rem, 1.5vw + 0.5rem, 1.5rem);" x-text="localFreq"></span>
                            <span class="opacity-40 transition-transform duration-300"
                                  style="font-size: clamp(0.5rem, 0.5vw, 0.7rem);"
                                  :class="openDropdown === 'freq' ? 'rotate-180' : ''">▼</span>
                        </div>
                        <div x-show="openDropdown === 'freq'" x-cloak
                             class="absolute z-50 mt-2 w-full bg-foxplan-white border border-foxplan-tint-line/20 shadow-xl">
                            <template x-for="f in ['Weekly', 'Fortnightly', 'Monthly']">
                                <div @click="localFreq = f; openDropdown = null"
                                     class="px-5 py-3 text-xs hover:bg-foxplan-neutral-beige cursor-pointer capitalize text-foxplan-charcoal-brown"
                                     x-text="f"></div>
                            </template>
                        </div>
                    </div>

                    {# Contribution Amount #}
                    <div class="border-b border-foxplan-tint-line/30 pb-3">
                        <label class="block uppercase tracking-[0.1em] text-foxplan-charcoal-brown/50 mb-2 font-bold"
                               style="font-size: clamp(0.625rem, 0.5vw + 0.3rem, 0.75rem);">CONTRIBUTION AMOUNT ($)</label>
                        <input type="number" x-model.number="localContribution" min="0"
                               style="font-size: clamp(1.1rem, 1.5vw + 0.5rem, 1.5rem);"
                               class="w-full bg-transparent font-serif text-foxplan-charcoal-brown focus:outline-none border-none p-0 appearance-none">
                    </div>

                    {# Starting Balance #}
                    <div class="border-b border-foxplan-tint-line/30 pb-3">
                        <label class="block uppercase tracking-[0.1em] text-foxplan-charcoal-brown/50 mb-2 font-bold"
                               style="font-size: clamp(0.625rem, 0.5vw + 0.3rem, 0.75rem);">STARTING BALANCE ($)</label>
                        <input type="number" x-model.number="localBalance" min="0"
                               style="font-size: clamp(1.1rem, 1.5vw + 0.5rem, 1.5rem);"
                               class="w-full bg-transparent font-serif text-foxplan-charcoal-brown focus:outline-none border-none p-0 appearance-none">
                    </div>

                    {# Interest Rate #}
                    <div class="border-b border-foxplan-tint-line/30 pb-3 relative">
                        <label class="block uppercase tracking-[0.1em] text-foxplan-charcoal-brown/50 mb-2 font-bold"
                               style="font-size: clamp(0.625rem, 0.5vw + 0.3rem, 0.75rem);">INTEREST RATE</label>
                        <div @click="openDropdown = 'rate'" class="flex justify-between items-center cursor-pointer group">
                            <span class="font-serif text-foxplan-charcoal-brown"
                                  style="font-size: clamp(1.1rem, 1.5vw + 0.5rem, 1.5rem);"
                                  x-text="ratePresets[localRateIdx].label"></span>
                            <span class="opacity-40 transition-transform duration-300"
                                  style="font-size: clamp(0.5rem, 0.5vw, 0.7rem);"
                                  :class="openDropdown === 'rate' ? 'rotate-180' : ''">▼</span>
                        </div>
                        <div x-show="openDropdown === 'rate'" x-cloak
                             class="absolute z-50 mt-2 w-full bg-foxplan-white border border-foxplan-tint-line/20 shadow-xl">
                            <template x-for="(preset, i) in ratePresets" :key="i">
                                <div @click="localRateIdx = i; openDropdown = null"
                                     class="px-5 py-3 text-xs hover:bg-foxplan-neutral-beige cursor-pointer text-foxplan-charcoal-brown"
                                     x-text="preset.label"></div>
                            </template>
                        </div>
                    </div>

                    {# Compounding Frequency #}
                    <div class="border-b border-foxplan-tint-line/30 pb-3 relative">
                        <label class="block uppercase tracking-[0.1em] text-foxplan-charcoal-brown/50 mb-2 font-bold"
                               style="font-size: clamp(0.625rem, 0.5vw + 0.3rem, 0.75rem);">COMPOUNDING</label>
                        <div @click="openDropdown = 'compound'" class="flex justify-between items-center cursor-pointer group">
                            <span class="font-serif text-foxplan-charcoal-brown capitalize"
                                  style="font-size: clamp(1.1rem, 1.5vw + 0.5rem, 1.5rem);" x-text="localCompound"></span>
                            <span class="opacity-40 transition-transform duration-300"
                                  style="font-size: clamp(0.5rem, 0.5vw, 0.7rem);"
                                  :class="openDropdown === 'compound' ? 'rotate-180' : ''">▼</span>
                        </div>
                        <div x-show="openDropdown === 'compound'" x-cloak
                             class="absolute z-50 mt-2 w-full bg-foxplan-white border border-foxplan-tint-line/20 shadow-xl">
                            <template x-for="c in ['Monthly', 'Quarterly', 'Annually']">
                                <div @click="localCompound = c; openDropdown = null"
                                     class="px-5 py-3 text-xs hover:bg-foxplan-neutral-beige cursor-pointer capitalize text-foxplan-charcoal-brown"
                                     x-text="c"></div>
                            </template>
                        </div>
                    </div>

                </div>
            </div>

            {# Right Column: Results #}
            <div class="w-full lg:w-1/2 {{ calcProps.cardBg }} px-8 lg:px-12 py-10 lg:ml-6 flex flex-col justify-between">
                <div>
                    <h2 class="font-serif mb-10 {{ calcProps.textColor }} tracking-tighter"
                        style="font-size: clamp(1.75rem, 3vw, 2.25rem);">{{ calcProps.cardTitle }}</h2>

                    <div class="space-y-8">

                        {# Contribution slider #}
                        <div>
                            <div class="flex justify-between items-end mb-3">
                                <span class="font-bold uppercase tracking-[0.1em] opacity-40 text-[10px]" x-text="localFreq + ' Contribution ($)'"></span>
                                <span class="font-light text-foxplan-charcoal-brown"
                                      style="font-size: clamp(1.25rem, 2vw, 1.75rem);"
                                      x-text="'$' + localContribution.toLocaleString()"></span>
                            </div>
                            <input type="range" min="0" max="5000" step="10"
                                   x-model.number="localContribution"
                                   class="w-full accent-foxplan-charcoal-brown h-1">
                        </div>

                        {# Starting balance slider #}
                        <div>
                            <div class="flex justify-between items-end mb-3">
                                <span class="font-bold uppercase tracking-[0.1em] opacity-40 text-[10px]">Starting Balance ($)</span>
                                <span class="font-light text-foxplan-charcoal-brown"
                                      style="font-size: clamp(1.25rem, 2vw, 1.75rem);"
                                      x-text="'$' + localBalance.toLocaleString()"></span>
                            </div>
                            <input type="range" min="0" max="500000" step="1000"
                                   x-model.number="localBalance"
                                   class="w-full accent-foxplan-charcoal-brown h-1">
                        </div>

                    </div>

                    {# Results #}
                    <div class="mt-10 pt-8 border-t border-foxplan-tint-line/30 space-y-5">

                        <div class="flex justify-between items-center">
                            <span class="opacity-40 uppercase font-bold tracking-[0.2em] text-[10px]">Duration</span>
                            <span class="font-serif text-foxplan-charcoal-brown"
                                  style="font-size: clamp(1.1rem, 1.5vw, 1.5rem);"
                                  x-text="yearsToGoal + ' years'"></span>
                        </div>

                        <div class="flex justify-between items-center">
                            <span class="opacity-40 uppercase font-bold tracking-[0.2em] text-[10px]">Total Contributions</span>
                            <span class="font-serif text-foxplan-charcoal-brown"
                                  style="font-size: clamp(1.1rem, 1.5vw, 1.5rem);"
                                  x-text="'$' + totalContributions.toLocaleString()"></span>
                        </div>

                        <div class="flex justify-between items-center">
                            <span class="opacity-40 uppercase font-bold tracking-[0.2em] text-[10px]">Interest Earned</span>
                            <span class="font-serif text-foxplan-charcoal-brown"
                                  style="font-size: clamp(1.1rem, 1.5vw, 1.5rem);"
                                  x-text="'$' + interestEarned.toLocaleString()"></span>
                        </div>

                        <div class="flex justify-between items-center pt-6 border-t border-foxplan-tint-line/30 {{ calcProps.textColor }}">
                            <span class="font-bold opacity-40 uppercase tracking-[0.3em] text-[11px]">Final Balance</span>
                            <span class="font-serif"
                                  style="font-size: clamp(2rem, 5vw, 3.5rem);"
                                  x-text="'$' + finalBalance.toLocaleString()"></span>
                        </div>

                    </div>
                </div>

                <div class="mt-10">
                    {{ include('_components/ui/button/button.twig', {
                        props: {
                            text: 'SEE PROJECTIONS',
                            style: 'primary',
                            backgroundColor: 'bg-foxplan-charcoal-brown',
                            textColor: 'text-white',
                            classes: 'px-10 py-4 tracking-[0.2em] !w-full font-bold uppercase text-[11px]',
                            attributes: { '@click': 'updateProjections()' }
                        }
                    }) }}
                </div>
            </div>

        </div>
    </div>
</div>
