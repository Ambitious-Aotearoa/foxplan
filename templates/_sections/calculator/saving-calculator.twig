{# templates/_sections/calculator/investment-calculator.twig #}

{# templates/_sections/calculator/investment-calculator.twig #}

{# 1. Configuration #}
{% set calcProps = {
    mainTitle: 'Investment <br> Calculator',
    cardTitle: 'Savings Details',
    bodyText: 'Investing is one of the best ways to fund a big life goal, save for retirement or leave a legacy for loved ones. See how your portfolio mix may impact your investments over time.',
    backgroundColor: 'bg-foxplan-neutral-beige',
    cardBg: 'bg-white',
    textColor: 'text-foxplan-charcoal-brown',
    buttonBg: 'bg-foxplan-charcoal-brown',
    buttonTextColor: 'text-white'
} %}

<section class="{{ calcProps.backgroundColor }} w-full overflow-hidden font-aktiv"
         x-data="{
            localMonthly: $store.calculator.monthly,
            localInitial: $store.calculator.initial,
            localYears: $store.calculator.years,
            localAge: $store.calculator.age,
            localFreq: $store.calculator.frequency,
            localIdx: $store.calculator.portfolioIdx,
            openDropdown: null,

            updateProjections() {
                $store.calculator.monthly = this.localMonthly;
                $store.calculator.initial = this.localInitial;
                $store.calculator.years = this.localYears;
                $store.calculator.age = this.localAge;
                $store.calculator.frequency = this.localFreq;
                $store.calculator.portfolioIdx = this.localIdx;
                document.getElementById('projections-section')?.scrollIntoView({ behavior: 'smooth' });
            },

            get periods() {
                return this.localFreq === 'Weekly' ? 52 : (this.localFreq === 'Fortnightly' ? 26 : 12);
            },

            get totalContributions() {
                return (parseFloat(this.localMonthly) || 0) * this.periods * (parseFloat(this.localYears) || 0);
            },

            get currentFinalBalance() {
                const p = parseFloat(this.localInitial) || 0;
                const pmt = parseFloat(this.localMonthly) || 0;
                const r_annual = $store.calculator.rates[this.localIdx];
                const r_period = r_annual / this.periods;
                const n_periods = this.localYears * this.periods;
                if (r_period === 0) return p + (pmt * n_periods);
                const fv = p * Math.pow((1 + r_annual), this.localYears) + pmt * ((Math.pow((1 + r_period), n_periods) - 1) / r_period);
                return Math.round(fv);
            },

            get totalEarnings() {
                const val = this.currentFinalBalance - (parseFloat(this.localInitial) || 0) - this.totalContributions;
                return val > 0 ? val : 0;
            }
         }"
         @click.away="openDropdown = null">

    <div class="w-full pt-24 pb-12 pr-[10px]">
        <div class="mb-16 px-4 md:px-8">
            <h1 class="font-serif {{ calcProps.textColor }} tracking-tight leading-[0.85]"
                style="font-size: clamp(3.5rem, 8vw, 7.5rem);">
                {{ calcProps.mainTitle | raw }}
            </h1>
        </div>

        <div class="flex flex-wrap lg:flex-nowrap w-full items-stretch px-4 md:px-8">
            {# Left Column: Narrative & Selectors #}
            <div class="w-full lg:w-1/2 flex flex-col justify-start lg:pr-12 mb-10 lg:mb-0">
                <p class="mb-12 opacity-90 max-w-xl text-foxplan-charcoal-brown"
                   style="font-size: clamp(0.95rem, 1vw + 0.5rem, 1.15rem); leading: 1.4;">{{ calcProps.bodyText }}</p>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-12">
                    {# YOUR AGE #}
                    <div class="border-b border-foxplan-tint-line/30 pb-3 relative">
                        <label class="block uppercase tracking-[0.1em] text-foxplan-charcoal-brown/50 mb-2 font-bold"
                               style="font-size: clamp(0.625rem, 0.5vw + 0.3rem, 0.75rem);">YOUR AGE</label>
                        <div @click="openDropdown = 'age'" class="flex justify-between items-center cursor-pointer group">
                            <span class="font-serif text-foxplan-charcoal-brown"
                                  style="font-size: clamp(1.1rem, 1.5vw + 0.5rem, 1.5rem);" x-text="localAge + ' years old'"></span>
                            <span class="opacity-40 transition-transform duration-300"
                                  style="font-size: clamp(0.5rem, 0.5vw, 0.7rem);" :class="openDropdown === 'age' ? 'rotate-180' : ''">▼</span>
                        </div>
                    </div>

                    {# MONTHLY SAVINGS ($) #}
                    <div class="border-b border-foxplan-tint-line/30 pb-3">
                        <label class="block uppercase tracking-[0.1em] text-foxplan-charcoal-brown/50 mb-2 font-bold"
                               style="font-size: clamp(0.625rem, 0.5vw + 0.3rem, 0.75rem);">MONTHLY SAVINGS ($)</label>
                        <input type="number" x-model.number="localMonthly"
                               style="font-size: clamp(1.1rem, 1.5vw + 0.5rem, 1.5rem);"
                               class="w-full bg-transparent font-serif text-foxplan-charcoal-brown focus:outline-none border-none p-0 appearance-none">
                    </div>

                    {# FREQUENCY #}
                    <div class="border-b border-foxplan-tint-line/30 pb-3 relative">
                        <label class="block uppercase tracking-[0.1em] text-foxplan-charcoal-brown/50 mb-2 font-bold"
                               style="font-size: clamp(0.625rem, 0.5vw + 0.3rem, 0.75rem);">FREQUENCY</label>
                        <div @click="openDropdown = 'freq'" class="flex justify-between items-center cursor-pointer group">
                            <span class="font-serif text-foxplan-charcoal-brown"
                                  style="font-size: clamp(1.1rem, 1.5vw + 0.5rem, 1.5rem);" x-text="localFreq"></span>
                            <span class="opacity-40 transition-transform duration-300"
                                  style="font-size: clamp(0.5rem, 0.5vw, 0.7rem);" :class="openDropdown === 'freq' ? 'rotate-180' : ''">▼</span>
                        </div>
                    </div>

                    {# DURATION (YEARS) #}
                    <div class="border-b border-foxplan-tint-line/30 pb-3">
                        <label class="block uppercase tracking-[0.1em] text-foxplan-charcoal-brown/50 mb-2 font-bold"
                               style="font-size: clamp(0.625rem, 0.5vw + 0.3rem, 0.75rem);">DURATION (YEARS)</label>
                        <input type="number" x-model.number="localYears"
                               style="font-size: clamp(1.1rem, 1.5vw + 0.5rem, 1.5rem);"
                               class="w-full bg-transparent font-serif text-foxplan-charcoal-brown focus:outline-none border-none p-0 appearance-none">
                    </div>
                </div>
            </div>

            {# Right Column: Savings Details Card #}
            <div class="w-full lg:w-1/2 {{ calcProps.cardBg }} px-8 lg:px-12 py-12 shadow-2xl lg:ml-6 flex flex-col justify-between">
                <div>
                    <h2 class="font-serif text-foxplan-charcoal-brown uppercase tracking-tight mb-12"
                        style="font-size: clamp(1.75rem, 3vw, 2.5rem);">{{ calcProps.cardTitle }}</h2>

                    <div class="space-y-10">
                        <div>
                            <div class="flex justify-between items-end mb-3">
                                <span class="uppercase font-bold tracking-[0.1em] opacity-40"
                                      style="font-size: clamp(0.55rem, 0.4vw + 0.35rem, 0.7rem);">Monthly Savings</span>
                                <span class="font-serif text-foxplan-charcoal-brown"
                                      style="font-size: clamp(1.5rem, 2.5vw, 2.25rem);" x-text="'$' + localMonthly.toLocaleString()"></span>
                            </div>
                            <input type="range" min="0" max="5000" step="10" x-model.number="localMonthly" class="w-full accent-foxplan-charcoal-brown h-1">
                        </div>
                        <div>
                            <div class="flex justify-between items-end mb-3">
                                <span class="uppercase font-bold tracking-[0.1em] opacity-40"
                                      style="font-size: clamp(0.55rem, 0.4vw + 0.35rem, 0.7rem);">Initial Value</span>
                                <span class="font-serif text-foxplan-charcoal-brown"
                                      style="font-size: clamp(1.5rem, 2.5vw, 2.25rem);" x-text="'$' + localInitial.toLocaleString()"></span>
                            </div>
                            <input type="range" min="0" max="1000000" step="1000" x-model.number="localInitial" class="w-full accent-foxplan-charcoal-brown h-1">
                        </div>
                        <div>
                            <div class="flex justify-between items-end mb-3">
                                <span class="uppercase font-bold tracking-[0.1em] opacity-40"
                                      style="font-size: clamp(0.55rem, 0.4vw + 0.35rem, 0.7rem);">Portfolio Mix</span>
                                <span class="font-serif text-foxplan-charcoal-brown"
                                      style="font-size: clamp(1.5rem, 2.5vw, 2.25rem);" x-text="$store.calculator.mixLabels[localIdx]"></span>
                            </div>
                            <input type="range" min="0" max="3" step="1" x-model.number="localIdx" class="w-full accent-foxplan-charcoal-brown h-1">
                        </div>
                    </div>

                    {# Detail Lines with fluid text-sm/base equivalent #}
                    <div class="mt-12 pt-8 border-t border-foxplan-tint-line/20 space-y-4">
                        <div class="flex justify-between items-center text-foxplan-charcoal-brown">
                            <span class="opacity-40 uppercase font-bold tracking-[0.15em]"
                                  style="font-size: clamp(0.55rem, 0.4vw + 0.35rem, 0.7rem);">Initial Investment</span>
                            <span class="font-serif" style="font-size: clamp(1.1rem, 1.5vw + 0.2rem, 1.7rem);" x-text="'$' + (parseFloat(localInitial) || 0).toLocaleString()"></span>
                        </div>
                        <div class="flex justify-between items-center text-foxplan-charcoal-brown">
                            <span class="opacity-40 uppercase font-bold tracking-[0.15em]"
                                  style="font-size: clamp(0.55rem, 0.4vw + 0.35rem, 0.7rem);">Contributions Total</span>
                            <span class="font-serif" style="font-size: clamp(1.1rem, 1.5vw + 0.2rem, 1.7rem);" x-text="'$' + totalContributions.toLocaleString()"></span>
                        </div>
                        <div class="flex justify-between items-center text-foxplan-charcoal-brown">
                            <span class="opacity-40 uppercase font-bold tracking-[0.15em]"
                                  style="font-size: clamp(0.55rem, 0.4vw + 0.35rem, 0.7rem);">Investment Earnings</span>
                            <span class="font-serif" style="font-size: clamp(1.1rem, 1.5vw + 0.2rem, 1.7rem);" x-text="'$' + totalEarnings.toLocaleString()"></span>
                        </div>
                        <div class="flex justify-between items-center pt-8 mt-4 border-t border-foxplan-tint-line/20 {{ calcProps.textColor }}">
                            <span class="font-bold opacity-40 uppercase tracking-[0.2em]"
                                  style="font-size: clamp(0.65rem, 0.6vw + 0.3rem, 0.85rem);">Final Balance</span>
                            <span class="font-serif" style="font-size: clamp(2.5rem, 5vw, 4.5rem);" x-text="'$' + currentFinalBalance.toLocaleString()"></span>
                        </div>
                    </div>
                </div>

                <div class="mt-12">
                    {{ include('_components/ui/button/button.twig', {
                        props: {
                            text: 'SEE PROJECTIONS',
                            style: 'primary',
                            backgroundColor: 'bg-foxplan-charcoal-brown',
                            textColor: 'text-white',
                            classes: 'px-12 py-5 tracking-[0.25em] !w-full md:!w-auto font-bold',
                            attributes: {
                                '@click': 'updateProjections()',
                                'style': 'font-size: clamp(0.65rem, 0.5vw + 0.3rem, 0.8rem);'
                            }
                        }
                    }) }}
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    document.addEventListener('alpine:init', () => {
        if (!Alpine.store('calculator')) {
            Alpine.store('calculator', {
                monthly: 300,
                initial: 100000,
                years: 20,
                age: 30,
                frequency: 'Monthly',
                portfolioIdx: 1,
                rates: [0.038, 0.0544, 0.0461, 0.0661],
                mixLabels: ['30 / 70', '50 / 50', '70 / 30', '98 / 2']
            });
        }
    });
</script>