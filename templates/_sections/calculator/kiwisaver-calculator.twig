{# templates/_sections/calculator/kiwisaver-calculator.twig #}
{#
    NOTE: This include has NO x-data of its own.
    All state (localAge, localSalary, totalSavings etc.) lives in the
    parent x-data scope on the page template. This means changes here
    reactively update the projections graph below automatically.
#}

{% set calcProps = {
    cardTitle: 'Your Outcome',
    backgroundColor: 'bg-foxplan-neutral-beige',
    cardBg: 'bg-white',
    textColor: 'text-foxplan-charcoal-brown',
    buttonBg: 'bg-foxplan-charcoal-brown',
    buttonTextColor: 'text-white'
} %}

<div class="{{ calcProps.backgroundColor }} w-full overflow-hidden font-aktiv"
     @click.away="openDropdown = null">

    <div class="w-full py-16">
        <div class="flex flex-wrap lg:flex-nowrap w-full items-stretch px-4 md:px-6">

            {# ── Left Column: Inputs ── #}
            <div class="w-full lg:w-1/2 flex flex-col justify-start lg:pr-12 mb-10 lg:mb-0">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-12">

                    {# Employment Status #}
                    <div class="border-b border-foxplan-tint-line/30 pb-3 relative">
                        <label class="block uppercase tracking-[0.1em] text-foxplan-charcoal-brown/50 mb-2 font-bold"
                               style="font-size: clamp(0.625rem, 0.5vw + 0.3rem, 0.75rem);">EMPLOYMENT STATUS</label>
                        <div @click="openDropdown = 'employment'" class="flex justify-between items-center cursor-pointer group">
                            <span class="font-serif text-foxplan-charcoal-brown capitalize"
                                  style="font-size: clamp(1.1rem, 1.5vw + 0.5rem, 1.5rem);" x-text="localEmployment"></span>
                            <span class="opacity-40 transition-transform duration-300"
                                  style="font-size: clamp(0.5rem, 0.5vw, 0.7rem);"
                                  :class="openDropdown === 'employment' ? 'rotate-180' : ''">▼</span>
                        </div>
                        <div x-show="openDropdown === 'employment'" x-cloak
                             class="absolute z-50 mt-2 w-full bg-foxplan-white border border-foxplan-tint-line/20 shadow-xl">
                            <template x-for="status in ['employed', 'self-employed', 'not working']">
                                <div @click="localEmployment = status; openDropdown = null"
                                     class="px-5 py-3 text-xs hover:bg-foxplan-neutral-beige cursor-pointer capitalize text-foxplan-charcoal-brown"
                                     x-text="status"></div>
                            </template>
                        </div>
                    </div>

                    {# Your Contribution #}
                    <div class="border-b border-foxplan-tint-line/30 pb-3 relative">
                        <label class="block uppercase tracking-[0.1em] text-foxplan-charcoal-brown/50 mb-2 font-bold"
                               style="font-size: clamp(0.625rem, 0.5vw + 0.3rem, 0.75rem);">YOUR CONTRIBUTION</label>

                        {# Self-employed: free-type percentage; employed: dropdown of IRD rates #}
                        <template x-if="localEmployment === 'self-employed'">
                            <div class="flex items-center gap-1">
                                <input type="number" x-model.number="localContribution" min="1" max="100"
                                       class="w-full bg-transparent font-serif text-foxplan-charcoal-brown focus:outline-none border-none p-0 appearance-none"
                                       style="font-size: clamp(1.1rem, 1.5vw + 0.5rem, 1.5rem);">
                                <span class="font-serif text-foxplan-charcoal-brown opacity-60"
                                      style="font-size: clamp(1.1rem, 1.5vw + 0.5rem, 1.5rem);">%</span>
                            </div>
                        </template>
                        <template x-if="localEmployment !== 'self-employed'">
                            <div>
                                <div @click="openDropdown = 'contrib'" class="flex justify-between items-center cursor-pointer group">
                                    <span class="font-serif text-foxplan-charcoal-brown"
                                          style="font-size: clamp(1.1rem, 1.5vw + 0.5rem, 1.5rem);"
                                          x-text="localContribution + '%'"></span>
                                    <span class="opacity-40" style="font-size: clamp(0.5rem, 0.5vw, 0.7rem);">▼</span>
                                </div>
                                <div x-show="openDropdown === 'contrib'" x-cloak
                                     class="absolute z-50 mt-2 w-full bg-foxplan-white border border-foxplan-tint-line/20 shadow-xl">
                                    <template x-for="c in [3, 4, 6, 8, 10]">
                                        <div @click="localContribution = c; openDropdown = null"
                                             class="px-5 py-3 text-xs hover:bg-foxplan-neutral-beige cursor-pointer text-foxplan-charcoal-brown"
                                             x-text="c + '%'"></div>
                                    </template>
                                </div>
                            </div>
                        </template>
                    </div>

                    {# Employer Contribution — hidden for self-employed / not working #}
                    <div class="border-b border-foxplan-tint-line/30 pb-3 relative"
                         :class="hasEmployer ? 'opacity-100' : 'opacity-30 pointer-events-none'">
                        <label class="block uppercase tracking-[0.1em] text-foxplan-charcoal-brown/50 mb-2 font-bold"
                               style="font-size: clamp(0.625rem, 0.5vw + 0.3rem, 0.75rem);">EMPLOYER CONTRIBUTION</label>
                        <template x-if="hasEmployer">
                            <div>
                                <div @click="openDropdown = 'employer'" class="flex justify-between items-center cursor-pointer group">
                                    <span class="font-serif text-foxplan-charcoal-brown"
                                          style="font-size: clamp(1.1rem, 1.5vw + 0.5rem, 1.5rem);"
                                          x-text="localEmployerContribution + '%'"></span>
                                    <span class="opacity-40" style="font-size: clamp(0.5rem, 0.5vw, 0.7rem);">▼</span>
                                </div>
                                <div x-show="openDropdown === 'employer'" x-cloak
                                     class="absolute z-50 mt-2 w-full bg-foxplan-white border border-foxplan-tint-line/20 shadow-xl">
                                    <template x-for="ec in [3, 4]">
                                        <div @click="localEmployerContribution = ec; openDropdown = null"
                                             class="px-5 py-3 text-xs hover:bg-foxplan-neutral-beige cursor-pointer text-foxplan-charcoal-brown"
                                             x-text="ec + '%'"></div>
                                    </template>
                                </div>
                            </div>
                        </template>
                        <template x-if="!hasEmployer">
                            <span class="font-serif text-foxplan-charcoal-brown opacity-40"
                                  style="font-size: clamp(1.1rem, 1.5vw + 0.5rem, 1.5rem);">N/A</span>
                        </template>
                        {# Helper text for self-employed #}
                        <p x-show="localEmployment === 'self-employed'"
                           class="text-[10px] opacity-50 mt-1">Self-employed — no employer contribution</p>
                        <p x-show="localEmployment === 'not working'"
                           class="text-[10px] opacity-50 mt-1">No employer contribution while not working</p>
                    </div>

                    {# Life Cycle Toggle #}
                    <div class="border-b border-foxplan-tint-line/30 pb-3 flex justify-between items-center">
                        <div>
                            <label class="block uppercase tracking-[0.1em] text-foxplan-charcoal-brown/50 mb-2 font-bold"
                                   style="font-size: clamp(0.625rem, 0.5vw + 0.3rem, 0.75rem);">USE LIFE CYCLE</label>
                            <span class="font-serif text-foxplan-charcoal-brown"
                                  style="font-size: clamp(1.1rem, 1.5vw + 0.5rem, 1.5rem);"
                                  x-text="useLifeCycle ? 'Enabled' : 'Disabled'"></span>
                        </div>
                        <button @click="useLifeCycle = !useLifeCycle" type="button"
                                class="relative inline-flex shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-200 ease-in-out focus:outline-none"
                                style="height: clamp(24px, 2vw, 32px); width: clamp(44px, 4vw, 56px);"
                                :class="useLifeCycle ? 'bg-foxplan-charcoal-brown' : 'bg-foxplan-charcoal-brown/10'">
                            <span class="sr-only">Toggle Life Cycle</span>
                            <span aria-hidden="true"
                                  class="pointer-events-none inline-block transform rounded-full bg-foxplan-neutral-beige shadow ring-0 transition duration-200 ease-in-out"
                                  style="height: clamp(18px, 1.5vw, 24px); width: clamp(18px, 1.5vw, 24px); margin-top: 1px;"
                                  :class="useLifeCycle ? 'translate-x-full ml-1' : 'translate-x-1'"></span>
                        </button>
                    </div>

                    {# Current Age #}
                    <div class="border-b border-foxplan-tint-line/30 pb-3">
                        <label class="block uppercase tracking-[0.1em] text-foxplan-charcoal-brown/50 mb-2 font-bold"
                               style="font-size: clamp(0.625rem, 0.5vw + 0.3rem, 0.75rem);">CURRENT AGE</label>
                        <input type="number" x-model.number="localAge" min="18" max="64"
                               style="font-size: clamp(1.1rem, 1.5vw + 0.5rem, 1.5rem);"
                               class="w-full bg-transparent font-serif text-foxplan-charcoal-brown focus:outline-none border-none p-0 appearance-none">
                    </div>

                    {# Annual Salary #}
                    <div class="border-b border-foxplan-tint-line/30 pb-3">
                        <label class="block uppercase tracking-[0.1em] text-foxplan-charcoal-brown/50 mb-2 font-bold"
                               style="font-size: clamp(0.625rem, 0.5vw + 0.3rem, 0.75rem);">ANNUAL SALARY ($)</label>
                        <input type="number" x-model.number="localSalary"
                               style="font-size: clamp(1.1rem, 1.5vw + 0.5rem, 1.5rem);"
                               class="w-full bg-transparent font-serif text-foxplan-charcoal-brown focus:outline-none border-none p-0 appearance-none">
                    </div>

                    {# Current Balance #}
                    <div class="border-b border-foxplan-tint-line/30 pb-3">
                        <label class="block uppercase tracking-[0.1em] text-foxplan-charcoal-brown/50 mb-2 font-bold"
                               style="font-size: clamp(0.625rem, 0.5vw + 0.3rem, 0.75rem);">CURRENT BALANCE ($)</label>
                        <input type="number" x-model.number="localBalance" min="0"
                               style="font-size: clamp(1.1rem, 1.5vw + 0.5rem, 1.5rem);"
                               class="w-full bg-transparent font-serif text-foxplan-charcoal-brown focus:outline-none border-none p-0 appearance-none">
                    </div>

                </div>
            </div>

            {# ── Right Column: Results ── #}
            <div class="w-full lg:w-1/2 {{ calcProps.cardBg }} px-8 lg:px-12 py-10 lg:ml-6 flex flex-col justify-between">
                <div>
                    <h2 class="font-serif mb-10 {{ calcProps.textColor }} tracking-tighter"
                        style="font-size: clamp(1.75rem, 3vw, 2.25rem);">{{ calcProps.cardTitle }}</h2>

                    <div class="space-y-8">

                        {# Monthly Voluntary slider #}
                        <div>
                            <div class="flex justify-between items-end mb-3">
                                <span class="font-bold uppercase tracking-[0.1em] opacity-40 text-[10px]">Monthly Voluntary ($)</span>
                                <span class="font-light text-foxplan-charcoal-brown"
                                      style="font-size: clamp(1.25rem, 2vw, 1.75rem);"
                                      x-text="'$' + localVoluntary.toLocaleString()"></span>
                            </div>
                            <input type="range" min="0" max="5000" step="10"
                                   x-model.number="localVoluntary"
                                   class="w-full accent-foxplan-charcoal-brown h-1">
                        </div>

                        {# KiwiSaver Scheme slider — disabled if life cycle #}
                        <div>
                            <div class="flex justify-between items-end mb-3">
                                <span class="font-bold uppercase tracking-[0.1em] opacity-40 text-[10px]">KiwiSaver Scheme</span>
                                <span class="font-light text-foxplan-charcoal-brown"
                                      style="font-size: clamp(1.25rem, 2vw, 1.75rem);"
                                      x-text="useLifeCycle ? 'Life Cycle' : schemes[localSchemeIdx].name"></span>
                            </div>
                            <input type="range" min="0" max="4" step="1"
                                   x-model.number="localSchemeIdx"
                                   :disabled="useLifeCycle"
                                   class="w-full accent-foxplan-charcoal-brown h-1 disabled:opacity-20">
                            {# Fee indicator #}
                            <div class="flex justify-between mt-2 text-[10px] opacity-30 font-bold uppercase tracking-widest">
                                <span>Defensive</span>
                                <span x-show="!useLifeCycle"
                                      x-text="'Fee: ' + (schemes[localSchemeIdx].fee * 100).toFixed(2) + '% p.a.'"></span>
                                <span x-show="useLifeCycle">Fee: 0.85% p.a.</span>
                                <span>Aggressive</span>
                            </div>
                        </div>

                    </div>

                    {# Results #}
                    <div class="mt-10 pt-8 border-t border-foxplan-tint-line/30 space-y-5">

                        <div class="flex justify-between items-center">
                            <span class="opacity-40 uppercase font-bold tracking-[0.2em] text-[10px]">Govt Contribution (yr)</span>
                            <span class="font-serif text-foxplan-charcoal-brown"
                                  style="font-size: clamp(1.1rem, 1.5vw, 1.5rem);"
                                  x-text="'$' + govContribAnnual.toFixed(0)"></span>
                        </div>

                        <div class="flex justify-between items-center">
                            <span class="opacity-40 uppercase font-bold tracking-[0.2em] text-[10px]">Monthly into Fund</span>
                            <span class="font-serif text-foxplan-charcoal-brown"
                                  style="font-size: clamp(1.1rem, 1.5vw, 1.5rem);"
                                  x-text="'$' + Math.round(monthlyContribution).toLocaleString()"></span>
                        </div>

                        <div class="flex justify-between items-center">
                            <span class="opacity-40 uppercase font-bold tracking-[0.2em] text-[10px]">Weekly Drawdown</span>
                            <span class="font-serif text-foxplan-charcoal-brown"
                                  style="font-size: clamp(1.1rem, 1.5vw, 1.5rem);"
                                  x-text="'$' + weeklyAmount.toLocaleString()"></span>
                        </div>

                        <div class="flex justify-between items-center pt-6 border-t border-foxplan-tint-line/30 {{ calcProps.textColor }}">
                            <span class="font-bold opacity-40 uppercase tracking-[0.3em] text-[11px]">Final Balance</span>
                            <span class="font-serif"
                                  style="font-size: clamp(2rem, 5vw, 3.5rem);"
                                  x-text="'$' + totalSavings.toLocaleString()"></span>
                        </div>

                    </div>
                </div>

                <div class="mt-10">
                    {{ include('_components/ui/button/button.twig', {
                        props: {
                            text: 'SEE PROJECTIONS',
                            style: 'primary',
                            backgroundColor: 'bg-foxplan-charcoal-brown',
                            textColor: 'text-white',
                            classes: 'px-10 py-4 tracking-[0.2em] !w-full font-bold uppercase text-[11px]',
                            attributes: { '@click': 'updateProjections()' }
                        }
                    }) }}
                </div>
            </div>

        </div>
    </div>
</div>
