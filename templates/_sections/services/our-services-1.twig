{# templates/_sections/services/our-services-1.twig #}

{% set defaults = {
    title: 'Explore<br>insurance',
    description: '',
    backgroundColor: 'bg-[#F9F1E2]',
    items: [],
    buttonBgColor: 'bg-foxplan-charcoal-brown',
    buttonTextColor: 'text-foxplan-white'
} %}

{% set data = defaults | merge(props | default({})) %}
{% set groupedItems = data.items | batch(3) %}



<section class="w-full relative z-20 py-12 md:py-20 lg:py-28 {{ data.backgroundColor }} overflow-hidden">
    <div class="w-full px-4 md:px-6 lg:px-8">

        <div class="flex flex-col md:flex-row w-full items-start gap-y-12 md:gap-x-16 lg:gap-x-24">

            {# --- LEFT SIDE --- #}
            <div class="w-full md:w-[25%] shrink-0">
                <h2 class="font-serif tracking-tighter text-foxplan-charcoal-brown leading-[0.85] text-balance"
                    style="font-size: clamp(3rem, 5.5vw + 1rem, 7rem);">
                    {{ data.title | raw }}
                </h2>
            </div>

            {# --- RIGHT SIDE -- #}
            <div class="grow">
                {% for group in groupedItems %}
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-x-8 lg:gap-x-12 gap-y-16">

                        {% for item in group %}
                            <div class="flex flex-col h-full items-start">
                                <div class="w-full md:min-h-[4.5rem] lg:min-h-[5.5rem] flex items-start mb-4">
                                    <h3 class="font-serif leading-[1] text-foxplan-charcoal-brown w-full"
                                        style="font-size: clamp(1.4rem, 1.6vw + 0.5rem, 2rem);">
                                        {{ item.title }}
                                    </h3>
                                </div>

                                <div class="font-aktiv text-foxplan-charcoal-brown leading-snug mb-6 md:mb-8 font-medium opacity-90 w-full"
                                     style="font-size: clamp(0.9rem, 0.4vw + 0.6rem, 1.5rem);">
                                    {{ item.text | raw }}
                                </div>

                                {# BUTTON #}
                                <div class="mt-auto">
                                    {% include '_components/ui/button/button.twig' with {
                                        props: {
                                            text: 'LEARN MORE',
                                            url: item.link,
                                            backgroundColor: data.buttonBgColor,
                                            textColor: data.buttonTextColor
                                        }
                                    } only %}
                                </div>
                            </div>
                        {% endfor %}

                    </div>
                {% endfor %}
            </div>

        </div>
    </div>
</section>