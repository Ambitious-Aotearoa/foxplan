{# templates/_sections/services/our-services.twig #}

{% set defaults = {
    title: 'Services',
    description: '',
    backgroundColor: 'bg-foxplan-white',
    items: [],
    buttonBgColor: 'bg-foxplan-charcoal-brown',
    buttonTextColor: 'text-foxplan-white'
} %}

{% set data = defaults | merge(props | default({})) %}
{% set groupedItems = data.items | batch(2) %}

<section class="w-full relative z-20 py-8 md:py-16 lg:py-24 {{ data.backgroundColor }} overflow-hidden">
    <div class="grid grid-cols-1 md:grid-cols-10 w-full items-start">

        {# --- LEFT SIDE --- #}
        <div class="col-span-1 md:col-span-3 pl-4 md:pl-8 pr-8">
            <div class="w-full">
                <h2 class="font-serif tracking-tight text-foxplan-charcoal-brown mb-8 leading-[1] text-balance md:max-w-[10ch]"
                    style="font-size: clamp(2.2rem, 5.5vw, 4.5rem); word-break: keep-all;">
                    {{ data.title | raw }}
                </h2>

                {% if data.description %}
                    <div class="font-aktiv leading-relaxed text-foxplan-charcoal-brown font-medium opacity-90"
                         style="font-size: clamp(0.95rem, 1vw, 1.05rem);">
                        {{ data.description | raw }}
                    </div>
                {% endif %}
            </div>
        </div>

        {# --- RIGHT SIDE #}
        <div class="col-span-1 md:col-span-7 pl-4 md:pl-8 pr-8 lg:pr-32">
            <div class="w-full">
                {% for group in groupedItems %}

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 lg:gap-x-20 mb-2 md:mb-12 last:mb-0 md:grid-rows-[auto_1fr_auto]">

                        {% for item in group %}

                            <div class="md:contents flex flex-col mb-8 md:mb-0">

                                {# 1. TITLE ROW #}
                                <h3 class="font-serif leading-tight text-foxplan-charcoal-brown mb-4 md:row-start-1"
                                    style="font-size: clamp(1.75rem, 2vw + 1rem, 2.5rem); word-break: keep-all;">
                                    {{ item.title }}
                                </h3>

                                {# 2. BODY TEXT ROW  #}
                                <div class="font-aktiv text-foxplan-charcoal-brown/90 leading-relaxed mb-8 w-full font-medium md:row-start-2"
                                     style="font-size: clamp(1rem, 0.5vw + 0.8rem, 1.25rem);">
                                    {{ item.text | raw }}
                                </div>

                                {# 3. BUTTON ROW #}
                                <div class="md:row-start-3">
                                    {% include '_components/ui/button/button.twig' with {
                                        props: {
                                            text: 'LEARN MORE',
                                            url: item.link,
                                            style: 'primary',
                                            backgroundColor: data.buttonBgColor,
                                            textColor: data.buttonTextColor,
                                       
                                        }
                                    } only %}
                                </div>
                            </div>
                        {% endfor %}

                    </div>
                {% endfor %}
            </div>
        </div>

    </div>
</section>